---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BciVisionToggle from '../components/BciVisionToggle';
import FloatingOrbs from '../components/FloatingOrbs';
import KinectVision from '../components/KinectVision';
import ScrollCounter from '../components/ScrollCounter';
import '../styles/global.css';
import registry from '@shared/qtara-registrar.json';

const techniques = (registry as any).techniques ?? [];
const totalThreats = techniques.length;
const therapeuticCount = techniques.filter((t: any) => t?.tara?.clinical?.therapeutic_analog).length;
const dualUsePercent = Math.round((therapeuticCount / totalThreats) * 100);
---

<BaseLayout title="BCI Vision — Qinnovate" description="Nobody should go through what I lived through. I will not stop until I build a world where we can feel safe." ogImage="/images/og-bci-vision.png">
  <Nav />

  <!-- Scroll progress indicator -->
  <div id="scroll-progress" class="fixed top-0 left-0 h-[2px] z-50" style="width: 0%; background: linear-gradient(to right, #3b82f6, #8b5cf6, #22c55e); box-shadow: 0 0 8px rgba(59,130,246,0.5), 0 0 20px rgba(139,92,246,0.3);"></div>
  <script is:inline>
    (function() {
      var bar = document.getElementById('scroll-progress');
      window.addEventListener('scroll', function() {
        var scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
        var scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
        var pct = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        bar.style.width = pct + '%';
      });
    })();
  </script>

  <script is:inline>
    document.documentElement.setAttribute('data-theme', 'dark');
    document.documentElement.setAttribute('data-vision', 'on');
  </script>

  <FloatingOrbs client:idle />

  <!-- Consent Gate -->
  <div id="vision-consent" class="fixed inset-0 z-[200] flex items-center justify-center" style="background: radial-gradient(ellipse at center, #0a0a0f 0%, #050508 100%);">
    <div class="max-w-lg mx-auto px-6 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[rgba(139,92,246,0.3)] mb-6" style="background: rgba(139,92,246,0.08);">
          <span class="w-2 h-2 rounded-full bg-violet-500 animate-pulse"></span>
          <span class="text-[10px] font-mono tracking-[0.2em] uppercase text-violet-400">Entering Theoretical Space</span>
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6 leading-snug">Before you step in</h2>
        <div class="space-y-4 text-sm text-zinc-400 leading-relaxed text-left">
          <p>What you're about to see is an <span class="text-white font-medium">active investigation</span>, not a finished product. This vision reflects where BCI security research leads when you follow the physics.</p>
          <p>If you are a BCI patient, we want to hear from you. It's for you, after all.</p>
        </div>
      </div>
      <button id="consent-btn" class="px-8 py-3 rounded-xl text-sm font-semibold transition-all cursor-pointer" style="background: rgba(139,92,246,0.3); color: #a78bfa; border: 1px solid rgba(139,92,246,0.3);">
        I understand &mdash; let me explore
      </button>
    </div>
  </div>

  <script is:inline>
    (function() {
      var consent = document.getElementById('vision-consent');
      var btn = document.getElementById('consent-btn');
      // First-visit only — localStorage persists across sessions
      if (localStorage.getItem('vision-consent-seen') === 'yes') {
        if (consent) consent.style.display = 'none';
        return;
      }
      btn.onmouseenter = function() { btn.style.background = 'rgba(139,92,246,0.5)'; };
      btn.onmouseleave = function() { btn.style.background = 'rgba(139,92,246,0.3)'; };
      btn.onfocus = function() { btn.style.background = 'rgba(139,92,246,0.5)'; btn.style.outline = '2px solid #a78bfa'; btn.style.outlineOffset = '2px'; };
      btn.onblur = function() { btn.style.background = 'rgba(139,92,246,0.3)'; btn.style.outline = 'none'; };
      btn.addEventListener('click', function() {
        localStorage.setItem('vision-consent-seen', 'yes');
        consent.style.transition = 'opacity 0.4s ease';
        consent.style.opacity = '0';
        setTimeout(function() { consent.style.display = 'none'; }, 400);
      });
    })();
  </script>


  <!-- ═══ MISSION + KINECTVISION HEROES ═══ -->
  <section class="relative py-20 sm:py-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-16">
      <p class="text-xl sm:text-2xl text-[var(--color-text-muted)] leading-relaxed mb-10 reveal-elastic">No security framework existed for the brain-computer interface.</p>

      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold leading-[1.25] mb-12 reveal-elastic" style="transition-delay: 150ms;">
        <span class="text-[var(--color-text-primary)]">The security layer that should have existed before these devices touched anyone's nervous system</span> —
        <span class="bg-gradient-to-r from-emerald-500 via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">we're building it.</span>
      </h1>

      <div class="space-y-6 text-lg text-[var(--color-text-muted)] leading-relaxed text-left max-w-2xl mx-auto">
        <p class="reveal-elastic" style="transition-delay: 300ms;">A blind person should be able to see their service dog.</p>
        <p class="reveal-elastic" style="transition-delay: 400ms;">{therapeuticCount} of {totalThreats} attack techniques have therapeutic counterparts. Blindness. Parkinson's. Depression. Tinnitus. Dementia. Every one of these conditions has a security counterpart in the atlas — and every one of them deserves the same protection.</p>
        <p class="reveal-elastic text-base" style="transition-delay: 500ms;">That's why this framework is open source. Not because it's finished — because it can't be finished by one person.</p>
        <p class="reveal-elastic text-center mt-4" style="transition-delay: 600ms;"><a href="/research/papers/2026-02-06-field-journal-004-the-all-nighter-seven-layers-neural-protocols-and-the-vision/" class="text-xs text-[var(--color-accent-primary)] hover:underline">Read the session that started this &rarr;</a></p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Vision Restoration hero -->
        <div>
          <div class="rounded-xl overflow-hidden border border-[rgba(34,197,94,0.2)] cursor-pointer transition-all hover:border-emerald-500/50 hover:shadow-[0_0_30px_rgba(34,197,94,0.1)]" data-hero="green" role="button" tabindex="0" aria-label="Expand Vision Restoration details">
            <KinectVision client:only="react" variant="green" />
          </div>
          <div class="mt-4 text-center">
            <p class="text-sm font-semibold text-emerald-500 mb-1">Vision Restoration</p>
            <p class="text-xs text-[var(--color-text-faint)]">Depth sensor captures the environment, AI reconstructs color. Click to explore the pipeline.</p>
          </div>
        </div>
        <!-- Neural Terminal hero -->
        <div>
          <div class="rounded-xl overflow-hidden border border-[rgba(59,130,246,0.2)] cursor-pointer transition-all hover:border-blue-500/50 hover:shadow-[0_0_30px_rgba(59,130,246,0.1)]" data-hero="white" role="button" tabindex="0" aria-label="Expand Neural Terminal details">
            <KinectVision client:only="react" variant="white" />
          </div>
          <div class="mt-4 text-center">
            <p class="text-sm font-semibold text-blue-500 mb-1">Neural Terminal</p>
            <p class="text-xs text-[var(--color-text-faint)]">White phosphenes as the universal BCI interface. Click to explore the architecture.</p>
          </div>
        </div>
      </div>

      <!-- ═══ EXPANDED: Vision Restoration ═══ -->
      <div id="detail-green" class="hidden mt-8 glass rounded-2xl overflow-hidden" style="border-color: rgba(34,197,94,0.2);">
        <div class="grid md:grid-cols-[1.2fr_1fr] gap-0">
          <!-- Left: larger render -->
          <div class="p-4 sm:p-6">
            <div class="rounded-xl overflow-hidden border border-[rgba(34,197,94,0.15)]">
              <KinectVision client:only="react" variant="green" />
            </div>
          </div>
          <!-- Right: explanation -->
          <div class="p-6 sm:p-8 border-t md:border-t-0 md:border-l border-[rgba(34,197,94,0.1)]">
            <div class="flex items-center justify-between mb-6">
              <h3 class="text-lg font-bold text-emerald-500">How Vision Restoration Works</h3>
              <button data-close="green" class="text-[var(--color-text-faint)] hover:text-[var(--color-text-primary)] transition-colors cursor-pointer" aria-label="Close">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
            </div>

            <div class="space-y-5 text-sm text-[var(--color-text-muted)] leading-relaxed">
              <!-- Sensor layer -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                  <p class="text-xs font-semibold text-emerald-400 uppercase tracking-wider">Depth Sensor — The Hardware Failsafe</p>
                </div>
                <p>Structured-light depth sensors — the same technology in Xbox Kinect, Meta Quest, and iPhone LiDAR — capture the 3D environment as a point cloud. This runs at the hardware level with no AI dependency. If every software layer above fails, the sensor still produces raw depth data. The patient never loses spatial awareness.</p>
                <p class="mt-2">The sensor is built into the <strong class="text-[var(--color-text-primary)]">system-level kernel</strong> at I0 — it cannot be disabled by software, providing emergency terminal access regardless of application state.</p>
              </div>

              <!-- AI layer -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-violet-500"></span>
                  <p class="text-xs font-semibold text-violet-400 uppercase tracking-wider">AI Color Reconstruction — Local Only</p>
                </div>
                <p>AI renders color and object recognition on top of the depth data using on-device computer vision (OCR for text, object classification for scene understanding). All processing stays local. No frames leave the device. Only hashed metadata — never raw imagery — is transmitted, encrypted via post-quantum key encapsulation (ML-KEM-768) through NSP.</p>
              </div>

              <!-- Runemate -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                  <p class="text-xs font-semibold text-amber-400 uppercase tracking-wider">Runemate — The Rendering Engine</p>
                </div>
                <p>Runemate compiles the fused sensor + AI output into a neural-optimized stream for cortical delivery. It compresses the visual data to fit within the bandwidth and power constraints of an implanted BCI — targeting 65-90% compression in simulation. The compiler runs on-device at S2, producing phosphene-mapped stimulation patterns the visual cortex can interpret.</p>
              </div>

              <!-- NSP -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-cyan-500"></span>
                  <p class="text-xs font-semibold text-cyan-400 uppercase tracking-wider">NSP — Post-Quantum Security Envelope</p>
                </div>
                <p>Every packet between S2 (Runemate) and I0 (Neurowall) is wrapped in NSP's five defense layers. What leaves the rendering pipeline is cryptographically authenticated — if a packet is modified in transit, Neurowall rejects it at the hardware boundary before it reaches neural tissue.</p>
              </div>

              <!-- Security implications -->
              <div class="pt-4 border-t border-[rgba(34,197,94,0.1)]">
                <p class="text-xs font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-2">Security Implications</p>
                <ul class="space-y-2 text-xs">
                  <li class="flex items-start gap-2">
                    <span class="text-emerald-500 mt-0.5 shrink-0">&#10003;</span>
                    <span><strong class="text-[var(--color-text-primary)]">Emergency terminal access</strong> — depth sensor renders a minimal spatial interface at the kernel level, independent of all software. If Runemate crashes, NSP is compromised, or AI hallucinates, the patient retains basic spatial vision through raw sensor data</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-emerald-500 mt-0.5 shrink-0">&#10003;</span>
                    <span><strong class="text-[var(--color-text-primary)]">Blockchain configuration versioning</strong> — every kernel configuration state is hashed to a tamper-proof chain. If an accidental misconfiguration occurs, the system can roll back to any previous verified state — version control for the hardware boundary, not just source code</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-emerald-500 mt-0.5 shrink-0">&#10003;</span>
                    <span><strong class="text-[var(--color-text-primary)]">Zero raw data exfiltration</strong> — visual frames never leave the device. NSP transmits only hashed metadata (scene classification, object counts, navigation events) encrypted with post-quantum key encapsulation. No reconstructable imagery crosses the wire</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ EXPANDED: Neural Terminal ═══ -->
      <div id="detail-white" class="hidden mt-8 glass rounded-2xl overflow-hidden" style="border-color: rgba(59,130,246,0.2);">
        <div class="grid md:grid-cols-[1.2fr_1fr] gap-0">
          <!-- Left: larger render -->
          <div class="p-4 sm:p-6">
            <div class="rounded-xl overflow-hidden border border-[rgba(59,130,246,0.15)]">
              <KinectVision client:only="react" variant="white" />
            </div>
          </div>
          <!-- Right: explanation -->
          <div class="p-6 sm:p-8 border-t md:border-t-0 md:border-l border-[rgba(59,130,246,0.1)]">
            <div class="flex items-center justify-between mb-6">
              <h3 class="text-lg font-bold text-blue-500">The Neural Terminal</h3>
              <button data-close="white" class="text-[var(--color-text-faint)] hover:text-[var(--color-text-primary)] transition-colors cursor-pointer" aria-label="Close">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              </button>
            </div>

            <div class="space-y-5 text-sm text-[var(--color-text-muted)] leading-relaxed">
              <!-- Terminal concept -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                  <p class="text-xs font-semibold text-blue-400 uppercase tracking-wider">Why Terminals Persist</p>
                </div>
                <p>CLI survived GUI. GUI survived mobile. Mobile survived spatial computing. Across every paradigm shift, the terminal persists — a minimal, reliable rendering surface that gives users direct control. White phosphene stimulation is the simplest, most power-efficient rendering primitive for cortical prosthetics. The neural terminal is the BCI equivalent of the command line.</p>
              </div>

              <!-- Rendering -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-violet-500"></span>
                  <p class="text-xs font-semibold text-violet-400 uppercase tracking-wider">Runemate — Terminal Rendering</p>
                </div>
                <p>Runemate compiles interactive content into phosphene-mapped stimulation patterns. Text, UI elements, navigation — all translated into the spatial encoding the visual cortex can process. The patient interacts with their AI, their data, their device configuration through a terminal they control.</p>
              </div>

              <!-- Privacy -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-cyan-500"></span>
                  <p class="text-xs font-semibold text-cyan-400 uppercase tracking-wider">NSP — What Leaves the Device</p>
                </div>
                <p>Terminal sessions are local. Input commands and rendered output never leave the device unencrypted. When external data is needed, NSP wraps the request in post-quantum encryption (ML-KEM-768 key exchange, ML-DSA signatures). Responses are verified by Neurowall before rendering. The patient sees only authenticated content.</p>
              </div>

              <!-- Blockchain -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-2 h-2 rounded-full bg-amber-500"></span>
                  <p class="text-xs font-semibold text-amber-400 uppercase tracking-wider">Blockchain — Tamper-Proof Access Logs</p>
                </div>
                <p>Every terminal session, every configuration change, every access event is logged to a blockchain-based chain of evidence. Patients can audit exactly what accessed their device, when, and what changed. If a misconfiguration occurs — accidental or malicious — the blockchain provides version-controlled rollback to any previous verified kernel state. Think git for your neural interface hardware.</p>
              </div>

              <!-- Security implications -->
              <div class="pt-4 border-t border-[rgba(59,130,246,0.1)]">
                <p class="text-xs font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-2">Security Architecture</p>
                <ul class="space-y-2 text-xs">
                  <li class="flex items-start gap-2">
                    <span class="text-blue-500 mt-0.5 shrink-0">&#10003;</span>
                    <span><strong class="text-[var(--color-text-primary)]">Emergency terminal</strong> — kernel-level fallback renders a minimal terminal via depth sensor data alone, independent of Runemate, NSP, or AI. If all software layers fail, the patient still has a basic interface</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-blue-500 mt-0.5 shrink-0">&#10003;</span>
                    <span><strong class="text-[var(--color-text-primary)]">Configuration rollback</strong> — blockchain-versioned kernel states enable rollback to any prior verified configuration. No configuration change is permanent or unrecoverable. Every state transition is auditable</span>
                  </li>
                  <li class="flex items-start gap-2">
                    <span class="text-blue-500 mt-0.5 shrink-0">&#10003;</span>
                    <span><strong class="text-[var(--color-text-primary)]">Full patient agency</strong> — the terminal gives patients direct, unmediated control over their device. No intermediary application layer can prevent terminal access. This is cognitive liberty implemented as system architecture</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero expand/collapse logic -->
  <script is:inline>
    (function() {
      document.querySelectorAll('[data-hero]').forEach(function(hero) {
        hero.addEventListener('click', function() {
          var variant = hero.getAttribute('data-hero');
          var detail = document.getElementById('detail-' + variant);
          var other = document.getElementById('detail-' + (variant === 'green' ? 'white' : 'green'));
          if (other && !other.classList.contains('hidden')) {
            other.classList.add('hidden');
          }
          if (detail) {
            detail.classList.toggle('hidden');
            if (!detail.classList.contains('hidden')) {
              detail.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
        });
        hero.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); hero.click(); }
        });
      });
      document.querySelectorAll('[data-close]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var variant = btn.getAttribute('data-close');
          var detail = document.getElementById('detail-' + variant);
          if (detail) detail.classList.add('hidden');
        });
      });
    })();
  </script>


  <!-- ═══ HOOK: The surprise ═══ -->
  <section class="relative min-h-[80vh] flex items-center justify-center py-24 sm:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8 text-lg sm:text-xl text-[var(--color-text-muted)] leading-relaxed">
        <p class="reveal-elastic">I was cataloguing ways to attack a brain-computer interface.</p>
        <p class="reveal-elastic" style="transition-delay: 150ms;">Somewhere around technique 40, the catalog started reading differently.</p>
        <p class="reveal-elastic" style="transition-delay: 300ms;"><span class="text-[var(--color-text-primary)] font-semibold">Signal injection</span> — where an attacker sends crafted signals through an electrode — uses the same physical mechanism as <span class="text-emerald-500 font-semibold">deep brain stimulation</span>. The therapy that treats Parkinson's in over 160,000 patients.</p>
        <p class="reveal-elastic" style="transition-delay: 450ms;"><span class="text-[var(--color-text-primary)] font-semibold">Neural entrainment manipulation</span> — forcing the brain into an unnatural frequency — is the same mechanism as <span class="text-emerald-500 font-semibold">therapeutic tACS</span> for depression.</p>
        <p class="reveal-elastic text-2xl sm:text-3xl font-semibold" style="transition-delay: 600ms;">
          Same electrode. Same current. Same physics.<br/>
          <span class="bg-gradient-to-r from-red-500 via-amber-500 to-emerald-500 bg-clip-text text-transparent">Different intent.</span>
        </p>
        <p class="reveal-elastic mt-4" style="transition-delay: 750ms;"><a href="/research/papers/2026-02-09-tara-therapeutic-atlas-of-risks-and-applications/" class="text-xs text-[var(--color-accent-primary)] hover:underline">Read how the dual-use discovery unfolded &rarr;</a></p>
      </div>

      <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-2xl mx-auto reveal">
        <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-[var(--color-accent-primary)]"><ScrollCounter client:idle end={totalThreats} suffix="+" /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">techniques catalogued</p></div>
        <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-emerald-500"><ScrollCounter client:idle end={therapeuticCount} /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">with clinical analogs</p></div>
        <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-amber-500"><ScrollCounter client:idle end={dualUsePercent} suffix="%" /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">dual-use overlap</p></div>
      </div>
    </div>
  </section>


  <!-- ═══ THE CROSSING ═══ -->
  <section class="relative py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-8 text-lg sm:text-xl text-[var(--color-text-muted)] leading-relaxed">
        <p class="reveal-elastic">I was looking at a diagram of the thalamus when it hit me.</p>
        <p class="reveal-elastic" style="transition-delay: 120ms;">Every signal entering the cortex passes through this one relay. If you compromise it, you control what a person perceives. I had built the exact same chokepoint — in network security. A SIEM correlation engine. All signals in, one classification out. Compromise the engine, and the analyst sees whatever you want them to see.</p>
        <p class="reveal-elastic" style="transition-delay: 240ms;">That wasn't a metaphor. That was architecture.</p>
      </div>

      <div class="mt-12 glass rounded-xl p-6 reveal" style="border-color: rgba(59,130,246,0.15);">
        <div class="grid sm:grid-cols-3 gap-4 text-center text-sm">
          <div>
            <p class="text-[var(--color-text-primary)] font-semibold mb-1">Attack the spinal cord</p>
            <p class="text-xs text-[var(--color-text-faint)]">Involuntary movement</p>
          </div>
          <div>
            <p class="text-[var(--color-text-primary)] font-semibold mb-1">Attack the thalamus</p>
            <p class="text-xs text-[var(--color-text-faint)]">Altered perception</p>
          </div>
          <div>
            <p class="text-[var(--color-text-primary)] font-semibold mb-1">Attack the neocortex</p>
            <p class="text-xs text-[var(--color-text-faint)]">Thought extraction</p>
          </div>
        </div>
        <p class="text-center text-xs text-[var(--color-text-faint)] mt-4">Each layer has a distinct threat profile because each brain region has a distinct function.</p>
      </div>

      <div class="mt-16 space-y-6 text-[var(--color-text-muted)] leading-relaxed reveal">
        <p>AI already proved that other disciplines can transform neuroscience. Deep learning decodes speech at 62 words per minute. Neural networks reconstruct vision from electrode arrays. The understanding problem is being solved.</p>
        <p>But understanding is not protection. And the same AI that enables healing enables attack.</p>
        <div class="grid sm:grid-cols-2 gap-4 mt-6">
          <div class="rounded-xl p-5" style="background: rgba(139,92,246,0.06); border: 1px solid rgba(139,92,246,0.15);">
            <p class="text-[10px] font-mono tracking-[0.15em] uppercase text-[var(--color-accent-tertiary)] mb-3">What AI built</p>
            <p class="text-sm">Speech decoding. Vision restoration. Subvocal thought detection. Neural trajectory synthesis.</p>
          </div>
