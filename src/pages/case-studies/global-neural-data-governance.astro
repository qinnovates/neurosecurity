              <th class="text-left py-3 px-3 text-[var(--color-text-faint)] font-medium">Year</th>
              <th class="text-left py-3 px-3 text-[var(--color-text-faint)] font-medium">Scope</th>
              <th class="text-left py-3 px-3 text-[var(--color-text-faint)] font-medium">Status</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[var(--color-border)]/50 bg-[#10b981]/5">
              <td class="py-3 px-3 font-semibold">Chile</td>
              <td class="py-3 px-3 text-[var(--color-text-muted)]">Constitutional Amendment (Law 21.383, Art. 19)</td>
