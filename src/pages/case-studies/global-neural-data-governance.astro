              <td class="py-3 px-3 font-[family-name:var(--font-mono)]">2023</td>
              <td class="py-3 px-3 text-[var(--color-text-muted)]">State constitutional</td>
              <td class="py-3 px-3 text-[#10b981] font-semibold">Enacted</td>
