              <td class="py-3 px-3 font-[family-name:var(--font-mono)]">2021</td>
              <td class="py-3 px-3 text-[var(--color-text-muted)]">National law</td>
              <td class="py-3 px-3 text-[#10b981] font-semibold">Enacted</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]/50">
