---
import PageLayout from '@/layouts/PageLayout.astro';
import EEGBrowser from '@/components/data-studio/EEGBrowser';
import fs from 'node:fs';
import path from 'node:path';

// Load EEG samples registry at build time
let samples: any[] = [];
try {
  const raw = fs.readFileSync(path.resolve('shared/eeg-samples.json'), 'utf-8');
  const registry = JSON.parse(raw);
  samples = registry.samples || [];
} catch { /* registry not yet available */ }

const redistributableCount = samples.filter((s: any) => s.redistributable).length;
const taraCount = samples.filter((s: any) => s.taraId).length;
---

<PageLayout
  title="EEG Sample Browser — QIF Data Studio"
  description={`Browse ${samples.length} EEG datasets for BCI security research. ${redistributableCount} freely redistributable, ${taraCount} with TARA technique mappings.`}
  breadcrumbs={[
    { label: 'Research', href: '/research/' },
    { label: 'Data Studio', href: '/data-studio/' },
    { label: 'EEG Samples' },
  ]}
  wide={true}
>
  <div class="min-h-screen -mt-4 pt-4">
    <div class="max-w-[1400px] mx-auto">
      <!-- Hero -->
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-16">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-[11px] font-semibold text-slate-400 uppercase tracking-widest">Data Studio</span>
            <span class="w-1 h-1 rounded-full bg-slate-300"></span>
            <span class="text-[11px] font-semibold text-blue-500 uppercase tracking-widest">EEG Samples</span>
          </div>
          <h1 class="text-5xl sm:text-7xl font-semibold tracking-tight text-slate-900 mb-6">
            EEG Sample Browser
          </h1>
          <p class="text-2xl text-slate-500 font-medium leading-relaxed tracking-tight">
            {samples.length} curated EEG datasets for BCI security research.
            Real clinical recordings, synthetic baselines, and simulated attack scenarios
            — each tagged with conditions, TARA technique mappings, and license metadata.
          </p>
        </div>

        <div class="flex flex-row sm:flex-col gap-4">
          <div class="bg-white px-8 py-5 rounded-[2rem] border border-slate-100 shadow-sm min-w-[200px]">
            <span class="block text-[11px] text-slate-400 font-semibold mb-1">Datasets</span>
            <span class="text-3xl font-semibold text-slate-900">{samples.length}</span>
          </div>
          <div class="bg-slate-900 px-8 py-5 rounded-[2rem] shadow-xl shadow-slate-900/10 min-w-[200px]">
            <span class="block text-[11px] text-slate-500 font-semibold mb-1">TARA Mapped</span>
            <span class="text-3xl font-semibold text-red-400">{taraCount}</span>
          </div>
          <div class="bg-emerald-50 px-8 py-5 rounded-[2rem] border border-emerald-100 shadow-sm min-w-[200px]">
            <span class="block text-[11px] text-emerald-500 font-semibold mb-1">Redistributable</span>
            <span class="text-3xl font-semibold text-emerald-700">{redistributableCount}</span>
          </div>
        </div>
      </div>

      <!-- About this page -->
      <div class="bg-slate-50 rounded-2xl p-8 mb-12 border border-slate-100">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">About This Registry</h2>
        <div class="grid md:grid-cols-3 gap-6 text-sm text-slate-600 leading-relaxed">
          <div>
            <h3 class="font-semibold text-slate-700 mb-1">Real Clinical Data</h3>
            <p>
              Published EEG recordings from PhysioNet, IEEE DataPort, and university repositories.
              ADHD, epilepsy, sleep, motor imagery, and emotion datasets with known provenance.
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-slate-700 mb-1">TARA Mappings</h3>
            <p>
              Datasets are linked to TARA technique IDs where their signal characteristics
              correspond to what a specific attack technique would produce (for threat modeling purposes).
            </p>
          </div>
          <div>
            <h3 class="font-semibold text-slate-700 mb-1">Simulated Attacks</h3>
            <p>
              QIF-internal synthetic datasets generated by Neurosim and Neurowall tools.
              Signal injection, evasion, and feedback cascade attack scenarios for detection testing.
            </p>
          </div>
        </div>
      </div>

      <!-- EEG Browser (React island) -->
      <EEGBrowser
        client:load
        samples={samples}
      />

      <!-- Data usage note -->
      <div class="mt-16 pt-8 border-t border-slate-100 max-w-3xl">
        <h2 class="text-xl font-semibold text-slate-900 mb-3">Data Usage</h2>
        <p class="text-sm text-slate-500 leading-relaxed mb-3">
          Each dataset has its own license. Datasets marked "Redistributable" can be freely shared
          with attribution. "Academic Only" datasets require institutional access and cannot be redistributed.
          "Internal" datasets are QIF-generated synthetics available for research use.
        </p>
        <p class="text-sm text-slate-500 leading-relaxed">
          TARA technique mappings are proposed correspondences for threat modeling purposes.
          They do not constitute clinical or diagnostic claims.
          See <a href="/guardrails/" class="text-blue-600 underline">Guardrails</a> for epistemic constraints.
        </p>
      </div>
    </div>
  </div>
</PageLayout>
