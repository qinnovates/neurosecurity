---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import BciVisionToggle from '@/components/BciVisionToggle';
import ScrollCounter from '@/components/ScrollCounter';
import KinectVision from '@/components/KinectVision';
import HeroParticles from '@/components/HeroParticles';
import OniSpheres from '@/components/OniSpheres';
import PublicationCard from '@/components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import { getPostDate } from '@/lib/utils';
import { HOURGLASS_BANDS, HOURGLASS_WIDTHS, PILLARS, TARA_TECHNIQUES } from '@/lib/qif-constants';
import '@/styles/global.css';
import registry from '@shared/qtara-registrar.json';

const techniques = (registry as any).techniques ?? [];
const totalThreats = techniques.length;
const therapeuticCount = techniques.filter((t: any) => t?.tara?.clinical?.therapeutic_analog).length;
const neurorightsSet = new Set<string>();
techniques.forEach((t: any) => (t?.neurorights?.affected ?? []).forEach((r: string) => neurorightsSet.add(r)));
const neurorightsCount = neurorightsSet.size;

const sampleTechniques = techniques.slice(0, 9).map((t: any) => ({
  id: t.id,
  name: t.name,
  band: t.tara?.primary_band || 'I0',
  niss: t.niss?.final_score || 0,
}));

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(getPostDate(b.data)).getTime() - new Date(getPostDate(a.data)).getTime())
  .slice(0, 4);

const bandZoneColor = (id: string) => {
  if (id.startsWith('N')) return '#22c55e';
  if (id === 'I0') return '#f59e0b';
  return '#3b82f6';
};
---

<BaseLayout title="Qinnovate — Neural Interface Security and Governance Research" description="A security engineer's research portfolio studying how neural-interface risks can be modeled, communicated, and governed responsibly.">
  <Nav />
  <BciVisionToggle client:idle />

  <!-- ╔══════════════════════════════════════════════════════════╗ -->
  <!-- ║                  ACADEMIC MODE (Default)                 ║ -->
  <!-- ╚══════════════════════════════════════════════════════════╝ -->
  <div class="academic-only">

    <section class="relative min-h-screen flex flex-col items-center justify-center px-4 overflow-hidden" style="background: var(--color-bg-deep);">
      <HeroParticles client:only="react" />
      <div class="relative z-10 text-center max-w-4xl mx-auto pt-24">
        <p class="text-xs font-medium tracking-[0.2em] uppercase mb-6 text-[var(--color-text-faint)]"><strong>Neural Interface Security Research by</strong> Kevin L. Qi</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6 leading-[1.15]">
          <span class="text-[var(--color-text-primary)]">Modeling Security Risks</span><br />
          <span class="gradient-text">for Brain-Computer Interfaces.</span>
        </h1>
        <p class="text-base sm:text-lg text-[var(--color-text-muted)] mb-10 max-w-2xl mx-auto leading-relaxed">{totalThreats} attack techniques catalogued across 24 commercial devices. A proposed framework bridging neurosecurity and neuroethics.</p>
        <div class="grid grid-cols-3 gap-3 sm:gap-4 max-w-2xl mx-auto mb-10">
          <a href="/governance/rights/" class="glass rounded-xl p-4 text-center card-hover"><p class="text-2xl sm:text-3xl font-bold text-emerald-500">{neurorightsCount}</p><p class="text-[10px] sm:text-xs text-[var(--color-text-muted)] mt-1 leading-tight">neurorights<br/>mapped</p></a>
          <a href="/atlas/tara/" class="glass rounded-xl p-4 text-center card-hover"><p class="text-2xl sm:text-3xl font-bold text-[var(--color-accent-primary)]">{totalThreats}</p><p class="text-[10px] sm:text-xs text-[var(--color-text-muted)] mt-1 leading-tight">attack techniques<br/>catalogued</p></a>
          <a href="/atlas/therapeutics/" class="glass rounded-xl p-4 text-center card-hover"><p class="text-2xl sm:text-3xl font-bold text-[var(--color-accent-secondary)]">{therapeuticCount}</p><p class="text-[10px] sm:text-xs text-[var(--color-text-muted)] mt-1 leading-tight">therapeutic analogs<br/>identified</p></a>
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
          <a href="/atlas/tara/" class="px-6 py-3 rounded-xl bg-[var(--color-accent-primary)] text-white font-medium hover:opacity-90 transition-opacity">Explore the Threat Atlas</a>
          <a href="/research/whitepaper/" class="px-6 py-3 rounded-xl glass text-[var(--color-text-primary)] font-medium hover:bg-white/10 transition-colors">Read the Whitepaper</a>
        </div>
      </div>
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce"><svg class="w-5 h-5 text-[var(--color-text-faint)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg></div>
    </section>

    <section class="py-16" style="background: var(--color-bg-surface);">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 reveal">
          <div><h2 class="text-xl font-bold mb-5">What This Work Is</h2><ul class="space-y-3 text-sm text-[var(--color-text-muted)] leading-relaxed"><li class="flex items-start gap-2"><span class="text-[var(--color-accent-primary)] mt-0.5 shrink-0">&#8250;</span>A transparent research portfolio — open source, open data, open to critique.</li><li class="flex items-start gap-2"><span class="text-[var(--color-accent-primary)] mt-0.5 shrink-0">&#8250;</span>Proposed methods for threat modeling and risk scoring in neural-interface contexts.</li><li class="flex items-start gap-2"><span class="text-[var(--color-accent-primary)] mt-0.5 shrink-0">&#8250;</span>A bridge between technical security and neurorights/policy discussions.</li></ul></div>
          <div><h2 class="text-xl font-bold mb-5">What This Work Is Not</h2><ul class="space-y-3 text-sm text-[var(--color-text-muted)] leading-relaxed"><li class="flex items-start gap-2"><span class="text-[var(--color-text-faint)] mt-0.5 shrink-0">&times;</span>Not a clinical tool or diagnostic instrument.</li><li class="flex items-start gap-2"><span class="text-[var(--color-text-faint)] mt-0.5 shrink-0">&times;</span>Not a regulatory standard or adopted specification.</li><li class="flex items-start gap-2"><span class="text-[var(--color-text-faint)] mt-0.5 shrink-0">&times;</span>Not independently validated on clinical data.</li></ul></div>
        </div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="text-center mb-10 reveal"><p class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-accent-tertiary)] mb-4">How It Connects</p><h2 class="text-2xl sm:text-3xl font-bold mb-3">Three proposed systems, one security posture</h2><p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">Each system stands alone. Together they form a proposed security architecture for neurotechnology.</p></div>
      <div class="grid md:grid-cols-3 gap-4 max-w-4xl mx-auto reveal-stagger reveal">
        {PILLARS.map((pillar) => (
          <a href={pillar.href} class="glass rounded-xl p-5 card-hover group text-left">
            <div class="flex items-center gap-2 mb-3"><div class="text-xl" style={`color: ${pillar.color}`} set:html={pillar.icon} /><h3 class="text-base font-semibold group-hover:text-[var(--color-accent-primary)] transition-colors">{pillar.name}</h3></div>
            <p class="text-xs text-[var(--color-text-faint)] mb-1.5 font-medium">{pillar.tagline}</p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{pillar.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="py-20" style="background: var(--color-bg-surface);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 reveal"><h2 class="text-3xl font-bold mb-4">The Hourglass Architecture</h2><p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">Every threat and neurorights mapping traces to specific bands of this proposed 11-layer model.</p></div>
        <div class="max-w-xl mx-auto reveal">
          <div class="flex items-stretch gap-4">
            <div class="flex flex-col items-center justify-between py-2 shrink-0 w-6"><span class="text-[10px] text-[var(--color-text-faint)]">&uarr;</span><span class="text-[10px] text-[var(--color-text-faint)] [writing-mode:vertical-rl] rotate-180 tracking-[0.12em] uppercase">Indeterministic</span><span class="text-[10px] text-[var(--color-text-faint)] [writing-mode:vertical-rl] rotate-180 tracking-[0.12em] uppercase mt-1">Deterministic</span><span class="text-[10px] text-[var(--color-text-faint)]">&darr;</span></div>
            <div class="flex-1 flex flex-col gap-0">
              <div class="flex items-center gap-2 py-1"><div class="flex-1 h-px bg-[var(--color-border)]"></div><span class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text-faint)] whitespace-nowrap">Neural Domain</span><div class="flex-1 h-px bg-[var(--color-border)]"></div></div>
              {HOURGLASS_BANDS.map((band, i) => (<>
                {band.id === 'I0' && (<div class="flex items-center gap-2 py-1"><div class="flex-1 h-px bg-[var(--color-border)]"></div><span class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text-faint)] whitespace-nowrap">I0 — Interface Bottleneck</span><div class="flex-1 h-px bg-[var(--color-border)]"></div></div>)}
                {band.id === 'S1' && (<div class="flex items-center gap-2 py-1"><div class="flex-1 h-px bg-[var(--color-border)]"></div><span class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text-faint)] whitespace-nowrap">Synthetic Domain</span><div class="flex-1 h-px bg-[var(--color-border)]"></div></div>)}
                <a href={`/atlas/#${band.id}`} class="flex items-center gap-3 py-[3px] group cursor-pointer rounded hover:bg-black/[0.03] transition-all" title={band.description}>
                  <span class="text-xs text-[var(--color-text-faint)] w-7 text-right font-mono shrink-0">{band.id}</span>
                  <div class="flex-1 flex justify-center"><div class="h-7 rounded-[3px] transition-all group-hover:scale-[1.03]" style={`width: ${HOURGLASS_WIDTHS[i]}%; background: ${band.color}30; border: 1px solid ${band.color}50;`}></div></div>
                  <span class="text-xs text-[var(--color-text-muted)] w-28 shrink-0 truncate group-hover:text-[var(--color-text-primary)] transition-colors">{band.name}</span>
                </a>
              </>))}
              <div class="text-center pt-3 pb-1"><div class="text-[10px] uppercase tracking-[0.15em] text-[var(--color-text-faint)]">&larr; Spatial Scale &rarr;</div></div>
            </div>
          </div>
        </div>
        <div class="text-center mt-8"><a href="/atlas/" class="text-sm text-[var(--color-accent-primary)] hover:text-[var(--color-accent-secondary)] transition-colors">Explore the full interactive atlas &rarr;</a></div>
      </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <a href="/guardrails/" class="block glass rounded-2xl p-8 sm:p-10 card-hover group relative overflow-hidden reveal" style="border: 1px solid rgba(139,92,246,0.2); background: linear-gradient(135deg, rgba(139,92,246,0.05) 0%, rgba(59,130,246,0.05) 100%);">
        <div class="flex flex-col sm:flex-row sm:items-center gap-6">
          <div class="flex-1"><p class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-accent-tertiary)] mb-2">Proposed Guardrails</p><h2 class="text-xl sm:text-2xl font-bold mb-3 group-hover:text-[var(--color-accent-tertiary)] transition-colors">Neurowall + NSP + Runemate</h2><p class="text-sm text-[var(--color-text-muted)] leading-relaxed max-w-2xl">Three proposed guardrails for BCI defense: a signal-layer firewall, a post-quantum wire protocol, and an on-device policy compiler.</p></div>
          <div class="text-[var(--color-accent-tertiary)] opacity-60 group-hover:opacity-100 transition-opacity shrink-0"><svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></div>
        </div>
      </a>
    </section>

    {posts.length > 0 && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
        <div class="flex items-center justify-between mb-8 reveal"><div><h2 class="text-3xl font-bold">Latest Work</h2><p class="text-sm text-[var(--color-text-muted)] mt-1">Field journals and research notes.</p></div><a href="/news/" class="text-sm text-[var(--color-accent-primary)]">All posts &rarr;</a></div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 reveal-stagger reveal">{posts.map((post) => (<PublicationCard title={post.data.title} date={post.data.date_posted || post.data.date || new Date()} tags={post.data.tags} slug={post.id} body={post.body || ''} compact />))}</div>
      </section>
    )}

    <section class="py-16" style="background: var(--color-bg-surface);">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 reveal">
        <h2 class="text-xl font-bold mb-6">For Reviewers</h2>
        <ol class="space-y-2 text-sm text-[var(--color-text-muted)]">
          <li class="flex items-start gap-3"><span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">1.</span><a href="/research/whitepaper/">Research Question and Derivation</a></li>
          <li class="flex items-start gap-3"><span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">2.</span><a href="/research/landscape/">Literature and Prior Work</a></li>
          <li class="flex items-start gap-3"><span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">3.</span><a href="/atlas/tara/">Methods (taxonomy + scoring)</a></li>
          <li class="flex items-start gap-3"><span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">4.</span><a href="/research/validation/">Validation</a></li>
          <li class="flex items-start gap-3"><span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">5.</span><a href="/research/whitepaper/#limitations">Limitations</a></li>
          <li class="flex items-start gap-3"><span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">6.</span><a href="/governance/">Policy Translation</a></li>
        </ol>
      </div>
    </section>

    <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center reveal">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">The research is open. Start anywhere.</h2>
      <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto mb-8">No login, no paywall. Published for researchers, clinicians, and policymakers to evaluate and build upon.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/research/whitepaper/" class="px-8 py-3.5 rounded-xl bg-[var(--color-accent-primary)] text-white font-medium hover:opacity-90 transition-opacity">Read the Whitepaper</a>
        <a href="https://github.com/qinnovates/qinnovate" target="_blank" rel="noopener noreferrer" class="px-8 py-3.5 rounded-xl glass font-medium">View on GitHub</a>
      </div>
    </section>
  </div>

  <!-- ╔══════════════════════════════════════════════════════════╗ -->
  <!-- ║                BCI VISION MODE (Toggle ON)               ║ -->
  <!-- ╚══════════════════════════════════════════════════════════╝ -->
  <div class="vision-only">

    <div class="sticky top-16 z-40 text-center py-2 text-[10px] tracking-[0.15em] uppercase font-mono" style="background: rgba(139,92,246,0.1); border-bottom: 1px solid rgba(139,92,246,0.2); color: var(--color-accent-tertiary);">Theoretical Vision — Research directions and possibilities, not validated results</div>

    <!-- VISION HERO: Kinect on right, text on left -->
    <section class="relative min-h-screen flex items-center overflow-hidden" style="background: #050a08;">
      <div class="absolute top-0 right-0 bottom-0 w-full lg:w-1/2 z-0">
        <KinectVision client:only="react" fullBleed={true} />
      </div>
      <div class="relative z-10 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-24">
        <div class="max-w-lg">
          <p class="text-xs font-mono tracking-[0.2em] uppercase mb-6 text-[var(--color-accent-tertiary)]">BCI Vision</p>
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-6 leading-[1.1]">
            <span class="text-white">The Future of</span><br /><span class="gradient-text">Neural Interface Security.</span>
          </h1>
          <p class="text-lg text-zinc-400 mb-10 leading-relaxed">A theoretical vision of where BCI security research leads — from threat modeling to content delivery for cortical prosthetics.</p>
          <div class="flex flex-wrap gap-4">
            <a href="/research/whitepaper/" class="px-6 py-3 rounded-xl bg-[var(--color-accent-primary)] text-white font-medium hover:opacity-90 transition-opacity">Read the Whitepaper</a>
            <a href="/atlas/" class="px-6 py-3 rounded-xl glass font-medium transition-colors">Explore the Atlas</a>
          </div>
        </div>
      </div>
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce z-10"><svg class="w-5 h-5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg></div>
    </section>

    <!-- TRANSPARENCY -->
    <section class="py-20" style="background: var(--color-bg-surface);">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-6 reveal-stagger reveal">
          <div class="glass rounded-xl p-6"><h3 class="text-lg font-bold mb-4">What This Work Is</h3><ul class="space-y-2 text-sm text-[var(--color-text-muted)]"><li>&#8250; Open-source research portfolio</li><li>&#8250; Proposed threat modeling methods</li><li>&#8250; Bridge between security and neurorights</li></ul></div>
          <div class="glass rounded-xl p-6"><h3 class="text-lg font-bold mb-4">What This Work Is Not</h3><ul class="space-y-2 text-sm text-[var(--color-text-muted)]"><li>&times; Not a clinical or diagnostic tool</li><li>&times; Not an adopted standard</li><li>&times; Not independently validated</li></ul></div>
        </div>
        <p class="text-center mt-6 font-mono text-xs text-[var(--color-text-faint)] tracking-[0.1em] reveal">PROPOSED &middot; NOT VALIDATED &middot; OPEN TO CRITIQUE</p>
      </div>
    </section>

    <!-- QIF HOURGLASS -->
    <section class="py-20 vision-section-cool">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 reveal">
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[var(--color-accent-primary)] mb-4">The Framework</p>
          <h2 class="text-3xl sm:text-4xl font-bold mb-4">11 bands. Every surface mapped.</h2>
          <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">The Quantified Interconnection Framework maps every surface between neuron and silicon.</p>
        </div>
        <div class="max-w-3xl mx-auto">
          <div class="flex flex-col gap-1 reveal-stagger reveal">
            <div class="flex items-center gap-2 py-1 mb-2"><div class="flex-1 h-px" style="background: rgba(34,197,94,0.3);"></div><span class="text-[10px] uppercase tracking-[0.12em] text-emerald-500/70 font-mono">Neural Domain</span><div class="flex-1 h-px" style="background: rgba(34,197,94,0.3);"></div></div>
            {HOURGLASS_BANDS.map((band, i) => (<>
              {band.id === 'I0' && (<div class="flex items-center gap-2 py-2 my-1"><div class="flex-1 h-px" style="background: rgba(245,158,11,0.4);"></div><span class="text-[10px] uppercase tracking-[0.12em] text-amber-500/80 font-mono">I0 — The Bottleneck</span><div class="flex-1 h-px" style="background: rgba(245,158,11,0.4);"></div></div>)}
              {band.id === 'S1' && (<div class="flex items-center gap-2 py-2 my-1"><div class="flex-1 h-px" style="background: rgba(59,130,246,0.3);"></div><span class="text-[10px] uppercase tracking-[0.12em] text-blue-500/70 font-mono">Synthetic Domain</span><div class="flex-1 h-px" style="background: rgba(59,130,246,0.3);"></div></div>)}
              <a href={`/atlas/#${band.id}`} class="flex items-center gap-4 py-1 group rounded-lg px-2 transition-all hover:bg-white/[0.02]" title={band.description}>
                <span class="text-xs font-mono w-8 text-right shrink-0" style={`color: ${band.color}99;`}>{band.id}</span>
                <div class="flex-1 flex justify-center"><div class="h-9 rounded transition-all group-hover:scale-[1.02]" style={`width: ${HOURGLASS_WIDTHS[i]}%; background: ${band.color}15; border: 1px solid ${band.color}30;`}></div></div>
                <span class="text-xs w-32 shrink-0 truncate text-[var(--color-text-muted)] group-hover:text-[var(--color-text-primary)] transition-colors">{band.name}</span>
              </a>
            </>))}
          </div>
          <div class="text-center mt-6"><a href="/research/whitepaper/" class="text-sm text-[var(--color-accent-primary)]">Read the full specification &rarr;</a></div>
        </div>
      </div>
    </section>

    <!-- TARA ATLAS -->
    <section class="py-20" style="background: var(--color-bg-surface);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12 reveal">
          <p class="text-xs font-mono tracking-[0.15em] uppercase text-[var(--color-accent-secondary)] mb-4">Threat Intelligence</p>
          <h2 class="text-3xl sm:text-4xl font-bold mb-4">The TARA Atlas</h2>
          <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">Every technique scored, every device mapped, every neuroright traced.</p>
        </div>
        <div class="grid grid-cols-3 gap-6 max-w-2xl mx-auto mb-16 reveal">
          <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-[var(--color-accent-primary)]"><ScrollCounter client:idle end={totalThreats} suffix="+" /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">techniques</p></div>
          <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-[var(--color-accent-secondary)]"><ScrollCounter client:idle end={24} /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">devices</p></div>
          <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-emerald-500"><ScrollCounter client:idle end={neurorightsCount} /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">neurorights</p></div>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 max-w-4xl mx-auto reveal-stagger reveal">
          {sampleTechniques.map((t: any) => (
            <a href={`/TARA/${t.id}/`} class="glass rounded-xl p-4 card-hover group relative overflow-hidden">
              <div class="absolute left-0 top-0 bottom-0 w-1 rounded-l-xl" style={`background: ${bandZoneColor(t.band)};`}></div>
