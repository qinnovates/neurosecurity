---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TrustBar from '../components/TrustBar.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import { getPostDate } from '../lib/utils';
import { HOURGLASS_BANDS, HOURGLASS_WIDTHS } from '../lib/qif-constants';
import HeroParticles from '../components/HeroParticles';
import HourglassReveal from '../components/HourglassReveal';
import ThreatAtlasViz from '../components/ThreatAtlasViz';
import DualUseSplit from '../components/DualUseSplit';
import NeurorightsPentagon from '../components/NeurorightsPentagon';
import BciVisionToggle from '../components/BciVisionToggle';
import '../styles/global.css';
import registry from '@shared/qtara-registrar.json';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(getPostDate(b.data)).getTime() - new Date(getPostDate(a.data)).getTime())
  .slice(0, 6);

// Compute hero metrics from registrar (build-time)
const techniques = (registry as any).techniques ?? [];
const totalThreats = techniques.length;
const therapeuticCount = techniques.filter((t: any) => t?.tara?.clinical?.therapeutic_analog).length;
const dsm5Count = techniques.filter((t: any) => t?.tara?.dsm5?.primary?.length > 0).length;
const confirmed = techniques.filter((t: any) => t.status === 'CONFIRMED').length;
const demonstrated = techniques.filter((t: any) => t.status === 'DEMONSTRATED').length;
const theoretical = techniques.filter((t: any) => ['THEORETICAL', 'EMERGING', 'PLAUSIBLE', 'SPECULATIVE'].includes(t.status)).length;
const neurorightsSet = new Set<string>(['EA']); // Equal Access is structural, not threat-mapped
techniques.forEach((t: any) => (t?.neurorights?.affected ?? []).forEach((r: string) => neurorightsSet.add(r)));
const neurorightsCount = neurorightsSet.size;

// Compute severity breakdown from registrar (build-time)
const bySeverity: Record<string, number> = { critical: 0, high: 0, medium: 0, low: 0 };
techniques.forEach((t: any) => {
  const sev = t.niss?.severity || t.severity || 'low';
  if (bySeverity[sev] !== undefined) bySeverity[sev]++;
});

// Compute neurorights counts from registrar (build-time)
const neurorightsCounts: Record<string, number> = { MI: 0, MP: 0, CL: 0, PC: 0, EA: 0 };
techniques.forEach((t: any) => {
  (t?.neurorights?.affected ?? []).forEach((r: string) => {
    if (neurorightsCounts[r] !== undefined) neurorightsCounts[r]++;
  });
});

// Essential reading: latest 6 non-changelog posts (excludes auto-generated summaries)
const allPosts = await getCollection('blog');
const essentialPosts = allPosts
  .filter(p => !p.id.includes('changelog-summary'))
  .sort((a, b) => {
    const dateA = new Date(a.data.date_posted || a.data.date || 0);
    const dateB = new Date(b.data.date_posted || b.data.date || 0);
    return dateB.getTime() - dateA.getTime();
  })
  .slice(0, 6);

---

<BaseLayout title="Qinnovate — No Security Framework Existed for the Brain-Computer Interface" description="An $8 billion industry by 2032. 135 catalogued attack techniques. Zero published security frameworks. QIF (Quantified Interconnection Framework) is the first open framework bridging neurosecurity and neuroethics.">
  <Nav />

  <!-- ═══ BEAT 1: THE INCIDENT — Hybrid Hero ═══ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-4 overflow-hidden">
    <!-- Gradient background -->
    <div class="absolute inset-0 bg-[var(--color-bg-deep)]">
      <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 50% 30%, rgba(59,130,246,0.15) 0%, transparent 60%), radial-gradient(ellipse at 30% 70%, rgba(6,182,212,0.1) 0%, transparent 50%), radial-gradient(ellipse at 70% 60%, rgba(139,92,246,0.08) 0%, transparent 50%);"></div>
    </div>

    <HeroParticles client:idle />

    <div class="relative z-10 text-center max-w-4xl mx-auto pt-24">
      <p class="text-xs font-medium tracking-[0.2em] uppercase mb-6 text-[var(--color-text-faint)]">
        <strong>Brain-Computer Interface Research by</strong> Kevin L. Qi
      </p>

      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-[family-name:var(--font-heading)] tracking-tight mb-6 leading-[1.15]">
        <span class="text-[var(--color-text-primary)]">The First Open Security Framework</span>
        <br />
        <span class="bg-gradient-to-r from-[var(--color-accent-primary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">
          for Brain-Computer Interfaces
        </span>
      </h1>

      <p class="text-base sm:text-lg text-[var(--color-text-muted)] mb-10 max-w-2xl mx-auto leading-relaxed">
        An <a href="/bci/landscape/" class="text-[var(--color-accent-primary)] hover:underline">$8 billion industry by 2032</a>.* {totalThreats} attack techniques catalogued across 24 commercial devices. QIF (Quantified Interconnection Framework) is the first open framework bridging neurosecurity and neuroethics — from threat model to defense specification.
      </p>

      <!-- Dual-audience CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a
          href="/TARA/"
          class="px-6 py-3 rounded-lg bg-[var(--color-accent-primary)] text-white font-medium hover:bg-[var(--color-accent-primary)]/90 transition-colors"
        >
          See the Threat Atlas
        </a>
        <a
          href="/whitepaper/"
          class="px-6 py-3 rounded-lg glass text-[var(--color-text-primary)] font-medium hover:bg-white/10 transition-colors"
        >
          Read the Framework
        </a>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-3 mt-6 text-xs" style="color: var(--color-text-faint)">
        <span>I am a</span>
        <a href="/atlas/tara/" class="px-3 py-1.5 rounded-full transition-colors hover:text-[var(--color-text-primary)]" style="background: var(--color-glass-bg); border: 1px solid var(--color-glass-border)">Security Researcher</a>
        <a href="/atlas/clinical/" class="px-3 py-1.5 rounded-full transition-colors hover:text-[var(--color-text-primary)]" style="background: var(--color-glass-bg); border: 1px solid var(--color-glass-border)">Clinician</a>
        <a href="/governance/" class="px-3 py-1.5 rounded-full transition-colors hover:text-[var(--color-text-primary)]" style="background: var(--color-glass-bg); border: 1px solid var(--color-glass-border)">Policymaker</a>
        <a href="/research/api/" class="px-3 py-1.5 rounded-full transition-colors hover:text-[var(--color-text-primary)]" style="background: var(--color-glass-bg); border: 1px solid var(--color-glass-border)">Developer</a>
      </div>

      <p class="text-[10px] text-[var(--color-text-faint)] mt-4">
        *Median estimate across <a href="/bci/landscape/" class="underline hover:text-[var(--color-text-muted)] transition-colors">9 market research firms</a>.
      </p>
      <p class="text-[10px] mt-1" style="color: var(--color-text-faint)">{confirmed} confirmed · {demonstrated} demonstrated · {theoretical} theoretical</p>

      <TrustBar />
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-5 h-5 text-[var(--color-text-faint)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </section>

  <!-- ═══ THE DESCENT — Scroll-driven visual narrative ═══ -->

  <!-- ACT 1: THE ARCHITECTURE -->
  <section class="relative min-h-[80vh] flex flex-col items-center justify-center px-4 overflow-hidden">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[var(--color-accent-primary)] mb-3">The Architecture</p>
      <h2 class="text-xl sm:text-2xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] mb-10">
        We mapped every layer.
      </h2>
      <HourglassReveal
        client:visible
        bands={HOURGLASS_BANDS as unknown as any[]}
        widths={HOURGLASS_WIDTHS as unknown as number[]}
      />
      <p class="text-sm text-[var(--color-text-muted)] mt-8 max-w-md mx-auto leading-relaxed">
        11 bands. From neocortex to cloud. One framework.
      </p>
    </div>
  </section>

  <!-- ACT 2: THE ATLAS -->
  <section class="relative min-h-[80vh] flex flex-col items-center justify-center px-4 overflow-hidden">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#f97316] mb-3">The Atlas</p>
      <h2 class="text-xl sm:text-2xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] mb-6">
        {totalThreats} ways in.
      </h2>
      <ThreatAtlasViz
        client:visible
        total={totalThreats}
        bySeverity={bySeverity}
      />
      <p class="text-sm text-[var(--color-text-muted)] mt-8 max-w-md mx-auto leading-relaxed">
        Attack techniques catalogued, scored, and mapped across 11 bands.
      </p>
    </div>
  </section>

  <!-- ACT 3: THE MIRROR -->
  <section class="relative min-h-[80vh] flex flex-col items-center justify-center px-4 overflow-hidden">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-emerald-500 mb-3">The Mirror</p>
      <h2 class="text-xl sm:text-2xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] mb-6">
        Every weapon has a cure.
      </h2>
      <DualUseSplit
        client:visible
        therapeutic={therapeuticCount}
        siliconOnly={totalThreats - therapeuticCount}
        total={totalThreats}
      />
      <p class="text-sm text-[var(--color-text-muted)] mt-8 max-w-md mx-auto leading-relaxed">
        {therapeuticCount} of those same mechanisms are already used in medicine.
      </p>
    </div>
  </section>

  <!-- ACT 4: THE RIGHTS -->
  <section class="relative min-h-[80vh] flex flex-col items-center justify-center px-4 overflow-hidden">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-[#8b5cf6] mb-3">The Rights</p>
      <h2 class="text-xl sm:text-2xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] mb-6">
        Five rights. Quantified.
      </h2>
      <NeurorightsPentagon
        client:visible
        rights={[
          { code: 'MI', name: 'Mental Integrity', count: neurorightsCounts.MI, color: '#ef4444' },
          { code: 'MP', name: 'Mental Privacy', count: neurorightsCounts.MP, color: '#f59e0b' },
          { code: 'CL', name: 'Cognitive Liberty', count: neurorightsCounts.CL, color: '#3b82f6' },
          { code: 'PC', name: 'Psychological Continuity', count: neurorightsCounts.PC, color: '#8b5cf6' },
          { code: 'EA', name: 'Equal Access', count: neurorightsCounts.EA, color: '#10b981' },
        ]}
      />
      <p class="text-sm text-[var(--color-text-muted)] mt-8 max-w-md mx-auto leading-relaxed">
        Mental Integrity. Privacy. Liberty. Continuity. Access.
      </p>
    </div>
  </section>

  <!-- ═══ BEAT 3: THE DISCOVERY — I mapped every known attack ═══ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="reveal">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-accent-secondary)] mb-4 text-center">The Discovery</p>
      <h2 class="text-2xl sm:text-3xl font-bold font-[family-name:var(--font-heading)] mb-8 text-center">No one had catalogued the threats</h2>
      <div class="space-y-4 text-sm text-[var(--color-text-muted)] leading-relaxed">
        <div class="grid sm:grid-cols-2 gap-3">
          <div class="glass rounded-lg p-4">
            <p class="font-semibold text-[var(--color-text-primary)] mb-1">FDA</p>
            <p>Requires medical device cybersecurity assessments, but has <strong class="text-[var(--color-text-primary)]">no BCI-specific attack taxonomy</strong>. Guidance says "assess risk per ISO 14971" without defining what BCI threats look like.</p>
          </div>
          <div class="glass rounded-lg p-4">
            <p class="font-semibold text-[var(--color-text-primary)] mb-1">MITRE</p>
            <p>Published a medical device threat modeling playbook (2021), but it is methodology-generic. <strong class="text-[var(--color-text-primary)]">No neural-specific techniques. No BCI entries in ATT&CK.</strong></p>
          </div>
          <div class="glass rounded-lg p-4">
            <p class="font-semibold text-[var(--color-text-primary)] mb-1">CISA</p>
            <p>Created a <a href="https://www.cisa.gov/resources-tools/resources/matrix-game-brain-computer-interfaces" class="text-[var(--color-accent-primary)] hover:underline" target="_blank" rel="noopener noreferrer">tabletop foresight game</a> for BCI futures planning. A board game for brainstorming, not a security framework.</p>
          </div>
          <div class="glass rounded-lg p-4">
            <p class="font-semibold text-[var(--color-text-primary)] mb-1">BCI Manufacturers</p>
            <p>Neuralink, Synchron, Blackrock, Precision Neuroscience: <strong class="text-[var(--color-text-primary)]">zero public security documentation.</strong> No threat models, no vulnerability disclosure policies.</p>
          </div>
        </div>
        <div class="glass rounded-lg p-4" style="border-left: 3px solid var(--color-accent-primary);">
          <p class="font-semibold text-[var(--color-text-primary)] mb-1">So I built it</p>
          <p>I catalogued every known way to attack a brain-computer interface, scored each one for neural impact, traced the affected brain regions to psychiatric outcomes, and mapped the neurorights each technique could violate. <strong class="text-[var(--color-text-primary)]">{totalThreats} techniques. {dsm5Count} diagnostic outcomes. {neurorightsCount} neurorights operationalized.</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BEAT 4: THE TEST — Can it be falsified? ═══ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="reveal">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-accent-tertiary)] mb-4 text-center">The Test</p>
      <h2 class="text-2xl sm:text-3xl font-bold font-[family-name:var(--font-heading)] mb-3 text-center">Does the framework hold up?</h2>
      <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto mb-8 text-center">
        A framework that can't be tested is a story. Here's how the atlas validates against real hardware, real physics, and real neuroscience.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-4 max-w-4xl mx-auto reveal reveal-stagger">
      <!-- Empirical validation -->
      <a href="/atlas/analysis/t0079-anc-fingerprint/" class="glass rounded-xl p-5 card-hover group text-left">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-full bg-[var(--color-accent-primary)]/10 flex items-center justify-center text-[var(--color-accent-primary)]">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          </div>
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] group-hover:text-[var(--color-accent-primary)] transition-colors">
            Hardware Validation
          </h3>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          28 consumer sensor exploitation techniques validated with real devices. ANC earbuds extract ear canal biometrics at &minus;47 dB below music. No firmware exploit. Just physics.
        </p>
      </a>

      <!-- Endogenous case study -->
      <a href="/atlas/analysis/" class="glass rounded-xl p-5 card-hover group text-left">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-full bg-[var(--color-accent-secondary)]/10 flex items-center justify-center text-[var(--color-accent-secondary)]">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>
          </div>
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] group-hover:text-[var(--color-accent-secondary)] transition-colors">
            Endogenous Case Study
          </h3>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          The framework's first test case: COVID + PTSD as a dual-vector endogenous attack chain. Same neural pathways, same failure modes, no device required.
        </p>
      </a>

      <!-- Dual-use discovery -->
      <a href="/atlas/clinical/#therapeutics" class="glass rounded-xl p-5 card-hover group text-left">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-8 h-8 rounded-full bg-emerald-400/10 flex items-center justify-center text-emerald-400">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>
          </div>
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] group-hover:text-emerald-400 transition-colors">
            Dual-Use Discovery
          </h3>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          {therapeuticCount} of {totalThreats} attack techniques have direct therapeutic counterparts. The same mechanism that treats Parkinson's can, if misconfigured, cause psychiatric harm.
        </p>
      </a>
    </div>
  </section>

  <!-- ═══ MILESTONE CALLOUT: Neural Impact Chain ═══ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="glass rounded-xl p-6 sm:p-8 reveal" style="border-left: 4px solid var(--color-accent-secondary);">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex-1">
          <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-accent-secondary)] mb-2">Key Finding</p>
          <h3 class="text-lg font-bold font-[family-name:var(--font-heading)] mb-2">
            The Neural Impact Chain
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            A six-stage research mapping that traces BCI attack techniques from their physical mechanism through the affected neural structure to their potential psychiatric outcome. {dsm5Count} techniques map to symptoms matching DSM-5-TR criteria — from acute stress disorder to neurocognitive impairment. These mappings require clinical validation.
          </p>
          <p class="text-[10px] mt-2" style="color: var(--color-text-faint)">
            Following Poldrack (2006), brain region disruption does not uniquely predict psychiatric outcomes. These mappings are research hypotheses requiring clinical validation.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a
            href="/TARA/#diagnostic"
            class="px-5 py-2.5 rounded-lg bg-[var(--color-accent-secondary)] text-white font-medium text-sm hover:bg-[var(--color-accent-secondary)]/90 transition-colors text-center"
          >
            Explore Diagnostic View
          </a>
          <a
            href="/atlas/clinical/"
            class="px-5 py-2.5 rounded-lg glass text-[var(--color-text-primary)] font-medium text-sm hover:bg-white/10 transition-colors text-center"
          >
            Read More
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ HOURGLASS ARCHITECTURE (earned after narrative) ═══ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
    <div class="text-center mb-12 reveal">
      <h2 class="text-3xl font-bold font-[family-name:var(--font-heading)] mb-4">The Hourglass Architecture</h2>
      <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Every threat, therapeutic, and neurorights violation maps to specific bands of this 11-layer model. Biology above, silicon below, with the physical neural interface at the bottleneck where security either holds or fails.
      </p>
      <p class="text-sm text-[var(--color-text-muted)] mt-3 max-w-2xl mx-auto">
        Three systems connect what no one had connected: threats, outcomes, and rights — mapped together. Each stands alone. Together they form a complete security posture for neurotechnology.
      </p>
    </div>

    <!-- Flat interactive hourglass preview -->
    <div class="max-w-xl mx-auto reveal" id="hourglass-preview">
      <div class="flex items-stretch gap-4">
        <!-- Y-axis label -->
        <div class="flex flex-col items-center justify-between py-2 shrink-0 w-6">
          <span class="text-[10px] text-[var(--color-text-faint)]">&uarr;</span>
          <span class="text-[10px] text-[var(--color-text-faint)] [writing-mode:vertical-rl] rotate-180 tracking-[0.12em] uppercase">Indeterministic</span>
          <span class="text-[10px] text-[var(--color-text-faint)] [writing-mode:vertical-rl] rotate-180 tracking-[0.12em] uppercase mt-1">Deterministic</span>
          <span class="text-[10px] text-[var(--color-text-faint)]">&darr;</span>
        </div>

        <!-- Bands -->
        <div class="flex-1 flex flex-col gap-0">
          <!-- Neural Domain separator -->
          <div class="flex items-center gap-2 py-1">
            <div class="flex-1 h-px bg-[var(--color-border)]"></div>
            <span class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text-faint)] whitespace-nowrap">Neural Domain</span>
            <div class="flex-1 h-px bg-[var(--color-border)]"></div>
          </div>

          {HOURGLASS_BANDS.map((band, i) => (
            <>
              {band.id === 'I0' && (
                <div class="flex items-center gap-2 py-1">
                  <div class="flex-1 h-px bg-[var(--color-border)]"></div>
                  <span class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text-faint)] whitespace-nowrap">I0 — Interface Bottleneck</span>
                  <div class="flex-1 h-px bg-[var(--color-border)]"></div>
                </div>
              )}
              {band.id === 'S1' && (
                <div class="flex items-center gap-2 py-1">
                  <div class="flex-1 h-px bg-[var(--color-border)]"></div>
                  <span class="text-[10px] uppercase tracking-[0.1em] text-[var(--color-text-faint)] whitespace-nowrap">Synthetic Domain</span>
                  <div class="flex-1 h-px bg-[var(--color-border)]"></div>
                </div>
              )}
              <a
                href={`/atlas/#${band.id}`}
                class="flex items-center gap-3 py-[3px] group cursor-pointer rounded hover:bg-black/[0.03] transition-all"
                title={band.description}
              >
                <span class="text-xs text-[var(--color-text-faint)] w-7 text-right font-mono shrink-0">{band.id}</span>
                <div class="flex-1 flex justify-center">
                  <div
                    class="h-7 rounded-[3px] transition-all group-hover:scale-[1.03] group-hover:brightness-110"
                    style={`width: ${HOURGLASS_WIDTHS[i]}%; background: ${band.color}30; border: 1px solid ${band.color}50;`}
                  ></div>
                </div>
