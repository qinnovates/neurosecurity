---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';
---

<BaseLayout title="Qinnovate — Neural Interface Security and Governance Research" description="A security engineer's research portfolio studying how neural-interface risks can be modeled, communicated, and governed responsibly.">
  <Nav />

  <!-- ═══ HERO ═══ -->
  <section class="relative min-h-[70vh] flex items-center justify-center px-4 overflow-hidden">
    <div class="absolute inset-0 bg-[var(--color-bg-deep)]">
      <div class="absolute inset-0 opacity-20" style="background: radial-gradient(ellipse at 50% 40%, rgba(59,130,246,0.12) 0%, transparent 60%);"></div>
    </div>

    <div class="relative z-10 text-center max-w-3xl mx-auto pt-24 pb-16">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-[family-name:var(--font-heading)] tracking-tight mb-6 leading-[1.15] text-[var(--color-text-primary)]">
        Neural Interface Security<br />and Governance
      </h1>
      <p class="text-xs font-medium tracking-[0.2em] uppercase text-[var(--color-text-faint)] mb-8">
        Research Portfolio
      </p>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed">
        I am a security engineer studying how neural-interface risks can be modeled, communicated, and governed responsibly.
      </p>
      <p class="text-base text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed mt-4">
        This site presents early-stage research artifacts that connect technical security analysis with neuroethics and neurorights questions.
      </p>
    </div>
  </section>

  <!-- ═══ WHAT THIS WORK IS / IS NOT ═══ -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-deep)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-5 text-[var(--color-text-primary)]">What This Work Is</h2>
          <ul class="space-y-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent-primary)] mt-0.5 shrink-0">&#8250;</span>
              A transparent research portfolio.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent-primary)] mt-0.5 shrink-0">&#8250;</span>
              Proposed methods for threat modeling and risk scoring in neural-interface contexts.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-accent-primary)] mt-0.5 shrink-0">&#8250;</span>
              A bridge between technical security concerns and policy/rights discussions.
            </li>
          </ul>
        </div>
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-5 text-[var(--color-text-primary)]">What This Work Is Not</h2>
          <ul class="space-y-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-text-faint)] mt-0.5 shrink-0">&times;</span>
              Not a clinical tool.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-text-faint)] mt-0.5 shrink-0">&times;</span>
              Not a regulatory standard.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-text-faint)] mt-0.5 shrink-0">&times;</span>
              Not independently validated on clinical data.
            </li>
            <li class="flex items-start gap-2">
              <span class="text-[var(--color-text-faint)] mt-0.5 shrink-0">&times;</span>
              Not a claim of consensus.
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHY THIS MATTERS ═══ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-5 text-[var(--color-text-primary)]">Why This Matters</h2>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-3xl">
      Neural interfaces raise familiar cybersecurity questions (integrity, access, misuse) and unfamiliar human questions (agency, cognitive liberty, psychological continuity, consent under vulnerability).
    </p>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-3xl mt-4">
      Security failures in this domain may affect not just systems, but persons.
    </p>
  </section>

  <!-- ═══ CURRENT ARTIFACTS ═══ -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-deep)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-8 text-[var(--color-text-primary)]">Current Artifacts</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <a href="/atlas/tara/" class="glass rounded-xl p-6 card-hover group">
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">
            Threat Modeling Draft (TARA)
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            Proposed taxonomy of neural-interface attack patterns.
          </p>
        </a>
        <a href="/atlas/scoring/" class="glass rounded-xl p-6 card-hover group">
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">
            Risk Scoring Draft (NISS)
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            Proposed severity framework for neural-specific harms.
          </p>
        </a>
        <a href="/research/validation/" class="glass rounded-xl p-6 card-hover group">
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-tertiary)] transition-colors">
            Simulation Results
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            Internal validation in synthetic environments.
          </p>
        </a>
        <a href="/governance/" class="glass rounded-xl p-6 card-hover group">
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[#b8860b] transition-colors">
            Policy Translation Drafts
          </h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            Governance and standards-oriented analysis.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ EVIDENCE STATUS ═══ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-6 text-[var(--color-text-primary)]">Evidence Status (Current)</h2>
    <div class="glass rounded-xl overflow-hidden">
      <table class="w-full text-sm">
        <tbody>
          <tr class="border-b border-[var(--color-border)]">
            <td class="px-5 py-3 text-[var(--color-text-muted)]">Literature synthesis</td>
            <td class="px-5 py-3 text-right"><span class="text-[var(--color-status-safe)] font-medium">Yes</span></td>
          </tr>
          <tr class="border-b border-[var(--color-border)]">
            <td class="px-5 py-3 text-[var(--color-text-muted)]">Simulation-based testing</td>
            <td class="px-5 py-3 text-right"><span class="text-[var(--color-status-safe)] font-medium">Yes</span></td>
          </tr>
          <tr class="border-b border-[var(--color-border)]">
            <td class="px-5 py-3 text-[var(--color-text-muted)]">Real-world adversarial validation</td>
            <td class="px-5 py-3 text-right"><span class="text-[var(--color-text-faint)]">No</span></td>
          </tr>
          <tr class="border-b border-[var(--color-border)]">
            <td class="px-5 py-3 text-[var(--color-text-muted)]">Clinical validation</td>
            <td class="px-5 py-3 text-right"><span class="text-[var(--color-text-faint)]">No</span></td>
          </tr>
          <tr>
            <td class="px-5 py-3 text-[var(--color-text-muted)]">Independent third-party audit</td>
            <td class="px-5 py-3 text-right"><span class="text-[var(--color-text-faint)]">No</span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ═══ NEUROETHICS POSITION ═══ -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-deep)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-5 text-[var(--color-text-primary)]">Neuroethics and Neurorights Position</h2>
      <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-3xl">
        This project is grounded in neuroethics and informed by neurorights.
        Neurorights are treated here as normative constraints that should shape technical design and governance, not as marketing labels.
      </p>
    </div>
  </section>

  <!-- ═══ MY CONTRIBUTION ═══ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-5 text-[var(--color-text-primary)]">My Contribution</h2>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-3xl">
      This work is a scaffold, not a finished framework. My contribution is technical structuring: threat models, risk representation, and transparent assumptions. Its main value is showing what becomes testable when security, neuroscience, and bioethics collaborate.
    </p>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-3xl mt-4">
      The current artifacts define hypotheses, assumptions, and evaluation targets that a larger interdisciplinary team can validate, refine, or reject. Domain conclusions that require clinical, legal, or normative authority are presented as open questions, not settled claims.
    </p>
  </section>

  <!-- ═══ FOR REVIEWERS ═══ -->
  <section class="border-y border-[var(--color-border)] bg-[var(--color-bg-deep)]">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-6 text-[var(--color-text-primary)]">For Reviewers</h2>
      <p class="text-base text-[var(--color-text-muted)] leading-relaxed mb-6">
        If you are assessing rigor, start with:
      </p>
      <ol class="space-y-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
        <li class="flex items-start gap-3">
          <span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">1.</span>
          <a href="/research/whitepaper/" class="hover:text-[var(--color-accent-primary)] transition-colors">Research Question</a>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">2.</span>
          <a href="/research/landscape/" class="hover:text-[var(--color-accent-primary)] transition-colors">Literature and Prior Work</a>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">3.</span>
          <a href="/atlas/tara/" class="hover:text-[var(--color-accent-primary)] transition-colors">Methods (taxonomy + scoring)</a>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">4.</span>
          <a href="/research/validation/" class="hover:text-[var(--color-accent-primary)] transition-colors">Validation</a>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">5.</span>
          <a href="/research/whitepaper/#limitations" class="hover:text-[var(--color-accent-primary)] transition-colors">Limitations</a>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-[var(--color-accent-primary)] font-mono font-bold shrink-0">6.</span>
          <a href="/governance/" class="hover:text-[var(--color-accent-primary)] transition-colors">Policy Translation</a>
        </li>
      </ol>
    </div>
  </section>

  <!-- ═══ COMMITMENT ═══ -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-5 text-[var(--color-text-primary)]">Commitment</h2>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-3xl">
      This portfolio is an invitation to interdisciplinary verification: a security-derived starting point designed to be improved through collaboration, not accepted on authority. Every major claim should be traceable to a source, dataset, or explicit hypothesis label. Where evidence is weak, claims should be narrowed.
    </p>
    <p class="text-base text-[var(--color-text-muted)] leading-relaxed max-w-3xl mt-4">
      I welcome critique from security researchers, clinicians, bioethicists, and policy experts.
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a href="/research/whitepaper/" class="px-6 py-2.5 rounded-lg bg-[var(--color-accent-primary)] text-white font-medium text-sm hover:opacity-90 transition-opacity">
        Read the Whitepaper
      </a>
      <a href="https://github.com/qinnovates/qinnovate" target="_blank" rel="noopener noreferrer" class="px-6 py-2.5 rounded-lg glass text-[var(--color-text-primary)] font-medium text-sm hover:bg-white/10 transition-colors">
        View on GitHub
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
