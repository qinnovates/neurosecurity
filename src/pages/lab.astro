---
import PageLayout from '@/layouts/PageLayout.astro';
import { HOURGLASS_BANDS } from '@/lib/qif-constants';
import { THREAT_VECTORS } from '@/lib/threat-data';

const bands = [...HOURGLASS_BANDS];
---

<PageLayout
  title="QIF Lab"
  description="Interactive tools for exploring the QIF framework — hourglass architecture, threat mapping, and equation sandbox."
  breadcrumbs={[{ label: 'Lab' }]}
  wide={true}
>
  <div class="mb-12">
    <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-heading)] mb-4">QIF Lab</h1>
    <p class="text-lg text-[var(--color-text-muted)] max-w-2xl">
      Interactive tools for exploring the QIF framework. Visualize the hourglass architecture and map threat vectors.
    </p>
  </div>

  <!-- Tool Cards -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
    <a href="/news/derivation/hourglass.html" class="lab-card glass rounded-xl p-6 block group">
      <div class="text-2xl mb-3 text-[var(--color-status-warn)]">&#9632;</div>
      <h2 class="text-lg font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">Layer Explorer</h2>
      <p class="text-sm text-[var(--color-text-muted)] mb-4">
        Drill into all {bands.length} hourglass bands with attack vectors, BCI devices, and frequency spectrum.
      </p>
      <span class="text-xs font-[family-name:var(--font-mono)] text-[var(--color-accent-secondary)]">&rarr; /news/derivation/hourglass.html</span>
    </a>
    <a href="/atlas/tara/" class="lab-card glass rounded-xl p-6 block group">
      <div class="text-2xl mb-3 text-[var(--color-status-danger)]">&#9888;</div>
      <h2 class="text-lg font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">QIF Threat Map</h2>
      <p class="text-sm text-[var(--color-text-muted)] mb-4">
        {THREAT_VECTORS.length} attack vectors mapped across bands and categories with severity heatmapping.
      </p>
      <span class="text-xs font-[family-name:var(--font-mono)] text-[var(--color-accent-secondary)]">&rarr; /atlas/tara/</span>
    </a>
  </div>

  <!-- Section divider -->
  <div class="flex items-center gap-4 mb-10">
    <div class="flex-1 h-px bg-[var(--color-border)]"></div>
    <span class="text-xs text-[var(--color-text-faint)] uppercase tracking-wider">Equation Sandbox</span>
    <div class="flex-1 h-px bg-[var(--color-border)]"></div>
  </div>

  <div class="max-w-3xl">
    <!-- QI Equation Sandbox -->
    <div class="glass rounded-xl p-8">
      <div class="flex items-center gap-3 mb-2">
        <h2 class="text-xl font-semibold font-[family-name:var(--font-heading)]">QI Equation Sandbox</h2>
        <span class="text-xs px-2 py-0.5 rounded-full border border-[var(--color-accent-tertiary)]/30 text-[var(--color-accent-tertiary)]">
          Coming Soon
        </span>
      </div>
      <p class="text-sm text-[var(--color-text-muted)] mb-6">
        Interactive exploration of QI candidate equations — test both additive and tensor formulations with synthetic BCI data.
      </p>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="glass-subtle rounded-lg p-4">
          <h3 class="text-sm font-semibold mb-2">Candidate 1: Additive</h3>
          <code class="text-xs font-[family-name:var(--font-mono)] text-[var(--color-accent-tertiary)] break-all">
            QI(t) = C<sub>class</sub> + (1&minus;&Gamma;<sub>D</sub>(t))&middot;[Q<sub>i</sub> + Q<sub>entangle</sub>] &minus; Q<sub>tunnel</sub>
          </code>
        </div>
        <div class="glass-subtle rounded-lg p-4">
          <h3 class="text-sm font-semibold mb-2">Candidate 2: Tensor</h3>
          <code class="text-xs font-[family-name:var(--font-mono)] text-[var(--color-accent-tertiary)] break-all">
            QI = C<sub>class</sub> &otimes; e<sup>&minus;S<sub>quantum</sub></sup>
          </code>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

<style>
  .lab-card {
    transition: transform 0.2s ease, border-color 0.2s ease;
    text-decoration: none;
  }
  .lab-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-hover);
  }
</style>
