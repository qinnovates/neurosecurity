---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BciVisionToggle from '../components/BciVisionToggle';
import HeroParticles from '../components/HeroParticles';
import KinectVision from '../components/KinectVision';
import ScrollCounter from '../components/ScrollCounter';
import PublicationCard from '../components/PublicationCard.astro';
import { getCollection } from 'astro:content';
import { getPostDate } from '../lib/utils';
import { HOURGLASS_BANDS, HOURGLASS_WIDTHS, PILLARS } from '../lib/qif-constants';
import '../styles/global.css';
import registry from '@shared/qtara-registrar.json';

const techniques = (registry as any).techniques ?? [];
const totalThreats = techniques.length;
const therapeuticCount = techniques.filter((t: any) => t?.tara?.clinical?.therapeutic_analog).length;
const neurorightsSet = new Set<string>();
techniques.forEach((t: any) => (t?.neurorights?.affected ?? []).forEach((r: string) => neurorightsSet.add(r)));
const neurorightsCount = neurorightsSet.size;

const sampleTechniques = techniques.slice(0, 9).map((t: any) => ({
  id: t.id,
  name: t.name,
  band: t.tara?.primary_band || 'I0',
  niss: t.niss?.final_score || 0,
}));

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(getPostDate(b.data)).getTime() - new Date(getPostDate(a.data)).getTime())
  .slice(0, 4);

const bandZoneColor = (id: string) => {
  if (id.startsWith('N')) return '#22c55e';
  if (id === 'I0') return '#f59e0b';
  return '#3b82f6';
};
---

<BaseLayout title="BCI Vision — Qinnovate" description="A theoretical vision of where BCI security research leads — from threat modeling to content delivery for cortical prosthetics.">
  <Nav />

  <!-- Force dark theme for this page -->
  <script is:inline>
    document.documentElement.setAttribute('data-theme', 'dark');
    document.documentElement.setAttribute('data-vision', 'on');
  </script>

  <!-- Consent Gate -->
  <div id="vision-consent" class="fixed inset-0 z-[200] flex items-center justify-center" style="background: radial-gradient(ellipse at center, #0a0f0d 0%, #050805 100%);">
    <div class="max-w-lg mx-auto px-6 text-center">
      <div class="mb-8">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-[rgba(139,92,246,0.3)] mb-6" style="background: rgba(139,92,246,0.08);">
          <span class="w-2 h-2 rounded-full bg-violet-500 animate-pulse"></span>
          <span class="text-[10px] font-mono tracking-[0.2em] uppercase text-violet-400">Entering Theoretical Space</span>
        </div>
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6 leading-snug">Before you step in</h2>
        <div class="space-y-4 text-sm text-zinc-400 leading-relaxed text-left">
          <p>What you're about to see is an <span class="text-white font-medium">active investigation</span>, not a finished product. This vision reflects my current understanding of where BCI security and neuroethics intersect — an understanding that is growing, shifting, and far from complete.</p>
          <p>None of this is a claim of what I've built. It's a map of <span class="text-white font-medium">what I believe needs to exist</span> — drawn by someone learning in public, revising constantly, and following wherever the research leads.</p>
          <p>New ideas will emerge. Assumptions will break. The scope will expand. That's the point.</p>
          <p>If you are a BCI patient, we want to hear from you for your feedback to help improve your experience of this website. It&rsquo;s for you after all, thank you.</p>
        </div>
      </div>

      <div class="glass rounded-xl p-4 mb-8 text-left" style="border-color: rgba(139,92,246,0.2);">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-violet-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a9 9 0 11-18 0V5.25" />
          </svg>
          <div>
            <p class="text-xs text-zinc-300 font-medium mb-1">Best experience</p>
            <p class="text-xs text-zinc-500">This page uses WebGL for 3D visualizations. Chrome or Firefox recommended for best results.</p>
          </div>
        </div>
      </div>

      <button
        id="consent-btn"
        class="px-8 py-3 rounded-xl text-sm font-semibold transition-all cursor-pointer"
        style="background: rgba(139,92,246,0.3); color: #a78bfa; border: 1px solid rgba(139,92,246,0.3);"
      >
        I understand &mdash; let me explore
      </button>

      <p class="text-[10px] text-zinc-600 mt-6 font-mono tracking-[0.08em]">
        PROPOSED &middot; NOT VALIDATED &middot; OPEN TO CRITIQUE
      </p>
    </div>
  </div>

  <script is:inline>
    (function() {
      var consent = document.getElementById('vision-consent');
      var btn = document.getElementById('consent-btn');

      // Skip if already consented this session
      if (sessionStorage.getItem('vision-consent') === 'yes') {
        if (consent) consent.style.display = 'none';
        return;
      }

      btn.onmouseenter = function() { btn.style.background = 'rgba(139,92,246,0.5)'; };
      btn.onmouseleave = function() { btn.style.background = 'rgba(139,92,246,0.3)'; };

      btn.addEventListener('click', function() {
        sessionStorage.setItem('vision-consent', 'yes');
        consent.style.transition = 'opacity 0.4s ease';
        consent.style.opacity = '0';
        setTimeout(function() { consent.style.display = 'none'; }, 400);
      });
    })();
  </script>

  <div class="sticky top-16 z-40 text-center py-2 text-[10px] tracking-[0.15em] uppercase font-mono" style="background: rgba(139,92,246,0.1); border-bottom: 1px solid rgba(139,92,246,0.2); color: var(--color-accent-tertiary);">Theoretical Vision — Research directions and possibilities, not validated results</div>

  <!-- VISION HERO: Kinect on right, text on left -->
  <section class="relative min-h-screen flex items-center overflow-hidden" style="background: #050a08;" id="vision-hero">
    <HeroParticles client:visible variant="dark" />
    <div class="absolute inset-0 z-0">
      <KinectVision client:only="react" fullBleed={true} />
    </div>
    <!-- Ambient gradient orbs -->
    <div class="absolute inset-0 z-[1] pointer-events-none overflow-hidden">
    </div>
    <div class="relative z-10 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 pt-24">
      <div class="max-w-xl">
        <p class="text-xs font-mono tracking-[0.2em] uppercase mb-8 text-[var(--color-accent-tertiary)] reveal-elastic" style="transition-delay: 0ms;">BCI Vision</p>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight mb-8 leading-[1.05] word-reveal" id="hero-headline">
          <span class="text-white word">The </span><span class="text-white word">Future </span><span class="text-white word">of</span><br /><span class="gradient-text word">Neural </span><span class="gradient-text word">Interface </span><span class="gradient-text word">Security.</span>
        </h1>
        <p class="text-lg sm:text-xl text-zinc-400 mb-12 leading-relaxed reveal-elastic" style="transition-delay: 400ms;">A theoretical vision of where BCI security research leads — from threat modeling to content delivery for cortical prosthetics.</p>
        <div class="flex flex-wrap gap-4 reveal-elastic" style="transition-delay: 600ms;">
          <a href="/research/whitepaper/" class="magnetic px-8 py-3.5 rounded-xl bg-[var(--color-accent-primary)] text-white font-medium hover:opacity-90 transition-opacity text-base">Read the Whitepaper</a>
          <a href="/atlas/" class="magnetic px-8 py-3.5 rounded-xl glass font-medium transition-colors text-base">Explore the Atlas</a>
        </div>
      </div>
    </div>
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10" style="animation: float 3s ease-in-out infinite;"><svg class="w-5 h-5 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg></div>
  </section>

  <!-- TRANSPARENCY -->
  <section class="py-20" style="background: var(--color-bg-surface);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-6 reveal-stagger reveal">
        <div class="glass rounded-xl p-6 glow-border"><h3 class="text-lg font-bold mb-4">What This Work Is</h3><ul class="space-y-2 text-sm text-[var(--color-text-muted)]"><li>&#8250; Open-source research portfolio</li><li>&#8250; Proposed threat modeling methods</li><li>&#8250; Bridge between security and neurorights</li></ul></div>
        <div class="glass rounded-xl p-6 glow-border"><h3 class="text-lg font-bold mb-4">What This Work Is Not</h3><ul class="space-y-2 text-sm text-[var(--color-text-muted)]"><li>&times; Not a clinical or diagnostic tool</li><li>&times; Not an adopted standard</li><li>&times; Not independently validated</li></ul></div>
      </div>
      <p class="text-center mt-6 font-mono text-xs text-[var(--color-text-faint)] tracking-[0.1em] reveal">PROPOSED &middot; NOT VALIDATED &middot; OPEN TO CRITIQUE</p>
    </div>
  </section>

  <!-- QIF HOURGLASS -->
  <section class="py-20 vision-section-cool">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-xs font-mono tracking-[0.15em] uppercase text-[var(--color-accent-primary)] mb-4">The Framework</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">11 bands. Every surface mapped.</h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">The Quantified Interconnection Framework maps every surface between neuron and silicon.</p>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="flex flex-col gap-1 reveal-stagger reveal">
          <div class="flex items-center gap-2 py-1 mb-2"><div class="flex-1 h-px" style="background: rgba(34,197,94,0.3);"></div><span class="text-[10px] uppercase tracking-[0.12em] text-emerald-500/70 font-mono">Neural Domain</span><div class="flex-1 h-px" style="background: rgba(34,197,94,0.3);"></div></div>
          {HOURGLASS_BANDS.map((band, i) => (<>
            {band.id === 'I0' && (<div class="flex items-center gap-2 py-2 my-1"><div class="flex-1 h-px" style="background: rgba(245,158,11,0.4);"></div><span class="text-[10px] uppercase tracking-[0.12em] text-amber-500/80 font-mono">I0 — The Bottleneck</span><div class="flex-1 h-px" style="background: rgba(245,158,11,0.4);"></div></div>)}
            {band.id === 'S1' && (<div class="flex items-center gap-2 py-2 my-1"><div class="flex-1 h-px" style="background: rgba(59,130,246,0.3);"></div><span class="text-[10px] uppercase tracking-[0.12em] text-blue-500/70 font-mono">Synthetic Domain</span><div class="flex-1 h-px" style="background: rgba(59,130,246,0.3);"></div></div>)}
            <a href={`/atlas/#${band.id}`} class="flex items-center gap-4 py-1 group rounded-lg px-2 transition-all hover:bg-white/[0.02]" title={band.description}>
              <span class="text-xs font-mono w-8 text-right shrink-0" style={`color: ${band.color}99;`}>{band.id}</span>
              <div class="flex-1 flex justify-center"><div class="h-9 rounded transition-all group-hover:scale-[1.02]" style={`width: ${HOURGLASS_WIDTHS[i]}%; background: ${band.color}15; border: 1px solid ${band.color}30;`}></div></div>
              <span class="text-xs w-32 shrink-0 truncate text-[var(--color-text-muted)] group-hover:text-[var(--color-text-primary)] transition-colors">{band.name}</span>
            </a>
          </>))}
        </div>
        <div class="text-center mt-6"><a href="/research/whitepaper/" class="text-sm text-[var(--color-accent-primary)]">Read the full specification &rarr;</a></div>
      </div>
    </div>
  </section>

  <!-- TARA ATLAS -->
  <section class="py-20" style="background: var(--color-bg-surface);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-mono tracking-[0.15em] uppercase text-[var(--color-accent-secondary)] mb-4">Threat Intelligence</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">The TARA Atlas</h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">Every technique scored, every device mapped, every neuroright traced.</p>
      </div>
      <div class="grid grid-cols-3 gap-6 max-w-2xl mx-auto mb-16 reveal">
        <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-[var(--color-accent-primary)]"><ScrollCounter client:idle end={totalThreats} suffix="+" /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">techniques</p></div>
        <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-[var(--color-accent-secondary)]"><ScrollCounter client:idle end={24} /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">devices</p></div>
        <div class="text-center"><p class="text-4xl sm:text-5xl font-bold text-emerald-500"><ScrollCounter client:idle end={neurorightsCount} /></p><p class="text-xs text-[var(--color-text-muted)] mt-2">neurorights</p></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 max-w-4xl mx-auto reveal-stagger reveal">
        {sampleTechniques.map((t: any) => (
          <a href={`/TARA/${t.id}/`} class="glass rounded-xl p-4 card-tilt glow-border card-hover group relative overflow-hidden">
            <div class="absolute left-0 top-0 bottom-0 w-1 rounded-l-xl" style={`background: ${bandZoneColor(t.band)};`}></div>
            <div class="flex items-center justify-between mb-2"><span class="font-mono text-[10px] text-[var(--color-text-faint)]">{t.id}</span><span class="font-mono text-[10px] px-1.5 py-0.5 rounded" style={`background: ${bandZoneColor(t.band)}15; color: ${bandZoneColor(t.band)};`}>{t.band}</span></div>
            <p class="text-sm font-semibold mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">{t.name}</p>
            <div class="flex items-center gap-2"><div class="flex-1 h-1.5 rounded-full" style="background: var(--color-bg-elevated);"><div class="h-full rounded-full" style={`width: ${Math.min(t.niss * 10, 100)}%; background: ${t.niss >= 7 ? '#ef4444' : t.niss >= 4 ? '#f59e0b' : '#10b981'};`}></div></div><span class="text-[10px] font-mono text-[var(--color-text-faint)]">{t.niss?.toFixed?.(1) || '—'}</span></div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8"><a href="/atlas/tara/" class="text-sm text-[var(--color-accent-primary)]">Explore the full atlas &rarr;</a></div>
    </div>
  </section>

  <!-- NISS SCORING -->
  <section class="py-20 vision-section-warm">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-mono tracking-[0.15em] uppercase text-amber-500 mb-4">Severity Scoring</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">NISS: Neural Impact Severity Score</h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">Every technique is scored by base severity, reversibility, and detectability.</p>
      </div>
      <div class="glass rounded-2xl p-8 max-w-lg mx-auto reveal-scale">
        <p class="font-mono text-xs text-[var(--color-text-faint)] mb-4">Example: Signal Injection</p>
        <div class="space-y-4">
          <div><div class="flex justify-between text-xs mb-1"><span class="text-[var(--color-text-muted)]">Base Severity</span><span class="font-mono">6.0</span></div><div class="h-2 rounded-full" style="background: var(--color-bg-elevated);"><div class="h-full rounded-full bg-blue-500" style="width: 60%;"></div></div></div>
          <div><div class="flex justify-between text-xs mb-1"><span class="text-[var(--color-text-muted)]">+ Reversibility</span><span class="font-mono text-amber-500">+1.5</span></div><div class="h-2 rounded-full" style="background: var(--color-bg-elevated);"><div class="h-full rounded-full bg-amber-500" style="width: 15%;"></div></div></div>
          <div><div class="flex justify-between text-xs mb-1"><span class="text-[var(--color-text-muted)]">+ Detectability</span><span class="font-mono text-amber-500">+0.7</span></div><div class="h-2 rounded-full" style="background: var(--color-bg-elevated);"><div class="h-full rounded-full bg-amber-500" style="width: 7%;"></div></div></div>
          <div class="pt-2 border-t" style="border-color: var(--color-border);"><div class="flex justify-between text-sm mb-1"><span class="font-semibold">Final NISS</span><span class="font-mono font-bold text-red-500">8.2 HIGH</span></div><div class="h-3 rounded-full" style="background: var(--color-bg-elevated);"><div class="h-full rounded-full bg-gradient-to-r from-red-500 to-red-400" style="width: 82%;"></div></div></div>
        </div>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2 mt-12 text-[10px] font-mono text-[var(--color-text-faint)] reveal">
        <span class="glass rounded px-2 py-1">Technique</span><span>&rarr;</span><span class="glass rounded px-2 py-1">Band</span><span>&rarr;</span><span class="glass rounded px-2 py-1">Anatomy</span><span>&rarr;</span><span class="glass rounded px-2 py-1">Function</span><span>&rarr;</span><span class="glass rounded px-2 py-1">NISS</span><span>&rarr;</span><span class="glass rounded px-2 py-1">DSM-5-TR*</span>
      </div>
      <p class="text-center text-[10px] text-[var(--color-text-faint)] mt-2">*Diagnostic category references for threat modeling, not diagnostic claims</p>
    </div>
  </section>

  <!-- NEUROETHICS: ORIGIN + TIMELINE (with ONI Spheres behind) -->
  <section class="relative py-20 overflow-hidden" style="background: #050a14;">
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 reveal">
        <p class="text-xs font-mono tracking-[0.15em] uppercase text-emerald-500 mb-4">Where It Started</p>
        <h2 class="text-3xl sm:text-4xl font-bold mb-6">Neuroethics Is Younger Than You Think</h2>
        <p class="text-[var(--color-text-muted)] max-w-2xl mx-auto">The field that governs how we think about brains, privacy, and technology was formally named in 2002 — just over two decades ago. Here's the lineage all of us inherit.</p>
      </div>

      <!-- Visual Timeline -->
      <div class="relative mb-16">
        <div class="absolute left-6 sm:left-1/2 top-0 bottom-0 w-px" style="background: linear-gradient(to bottom, transparent, rgba(16,185,129,0.4), rgba(16,185,129,0.4), transparent);"></div>

        {[
          {
            year: '2002',
            title: 'The Field Is Named',
            body: 'William Safire opens the Dana Foundation conference "Neuroethics: Mapping the Field" in San Francisco. In his keynote, he defines neuroethics as "the examination of what is right and wrong, good and bad about the treatment of, perfection of, or unwelcome invasion of and worrisome manipulation of the human brain." The modern field begins here.',
            side: 'right',
            color: '#10b981',
            accent: 'Dana Foundation, San Francisco',
          },
          {
            year: '2002',
            title: 'Two Branches, One Name',
            body: 'At the same conference, philosopher Adina Roskies draws a distinction that still defines the field. Ethics of neuroscience asks: "What ethical rules should govern neuroscience research and its clinical applications?" Neuroscience of ethics asks: "What can brain science teach us about morality itself?" Both branches share a name, but they ask fundamentally different questions.',
            side: 'left',
            color: '#06b6d4',
            accent: 'Roskies (2002)',
          },
          {
            year: '2005',
            title: 'The Discipline Formalizes',
            body: 'The International Neuroethics Society (INS) is founded, establishing neuroethics as a professional academic discipline with its own conferences, journals, and research programs.',
            side: 'right',
            color: '#10b981',
            accent: 'International Neuroethics Society',
          },
          {
            year: '2006',
            title: 'Neuromodesty',
            body: 'Legal scholar Stephen Morse publishes "Brain Overclaim Syndrome," warning against using neuroscience findings to make claims the science doesn\'t support. His principle — neuromodesty — becomes a cornerstone: don\'t confuse brain scans with mind reading.',
            side: 'left',
            color: '#f59e0b',
            accent: 'Morse, Ohio State J Criminal Law',
          },
          {
            year: '2017',
            title: 'Neurorights Proposed',
            body: 'Ienca and Andorno publish "Towards New Human Rights in the Age of Neuroscience and Neurotechnology," proposing four new rights: cognitive liberty, mental privacy, mental integrity, and psychological continuity. They argue existing human rights are insufficient for the neurotechnology era.',
            side: 'right',
            color: '#8b5cf6',
            accent: 'Life Sciences, Society and Policy',
          },
          {
            year: '2021',
            title: 'Chile Leads',
            body: 'Chile becomes the first country to enshrine neuroprotection in its constitution. The theoretical becomes legislative. The question shifts from "should we protect mental privacy?" to "how do we enforce it technically?"',
            side: 'left',
            color: '#ec4899',
            accent: 'Chilean Constitutional Amendment',
          },
          {
            year: '2024',
            title: 'Colorado — First U.S. State',
            body: 'Colorado passes HB 24-1058, classifying neural data as "sensitive data" under its existing privacy framework. Effective August 7, 2024, the law requires explicit opt-in consent for collection and use of neural data. The first U.S. state to legislate neural data protection.',
            side: 'right',
            color: '#3b82f6',
            accent: 'HB 24-1058, Colorado Privacy Act',
          },
          {
            year: '2024',
            title: 'California Follows',
            body: 'California amends the California Consumer Privacy Act (CCPA) to include "neural data" in the definition of "sensitive personal information." Consumers gain the right to limit the use and disclosure of their neural data — the largest population covered by neural data law in the U.S.',
            side: 'left',
            color: '#3b82f6',
            accent: 'CCPA Amendment, SB 1223',
          },
          {
            year: '2025',
            title: 'Montana Expands the Scope',
            body: 'Montana passes SB 163, amending the Genetic Information Privacy Act (GIPA) to cover neural data. It becomes the third U.S. state with neural data legislation — and the first to include "mental augmentation" within its scope, acknowledging enhancement alongside protection.',
            side: 'right',
            color: '#3b82f6',
            accent: 'SB 163, Montana GIPA Amendment',
          },
          {
            year: 'Future',
            title: 'All of US',
            body: 'Two decades of neuroethics scholarship built the principles. Now the engineering has to catch up. If neurotechnology can read, write, and modulate neural signals — who builds the security? Who writes the policies? The answer is everyone working at this intersection.',
            side: 'right',
            color: '#10b981',
            accent: 'The bridge is being built',
          },
        ].map((item, idx) => (
          <div class={`relative flex items-start mb-10 reveal ${item.side === 'left' ? 'sm:flex-row-reverse' : ''}`}>
            <div class="absolute left-6 sm:left-1/2 w-3 h-3 rounded-full -translate-x-1/2 z-10 ring-4 timeline-dot" style={`background: ${item.color}; ring-color: ${item.color}20; color: ${item.color};`}></div>
            <div class={`ml-14 sm:ml-0 sm:w-[calc(50%-2rem)] ${item.side === 'left' ? 'sm:mr-auto sm:pr-8' : 'sm:ml-auto sm:pl-8'}`}>
              <div class="glass rounded-xl p-5">
                <div class="flex items-center gap-3 mb-2">
