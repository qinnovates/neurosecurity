    <!-- DSM-5 Clusters -->
    <div class="glass rounded-xl p-5 mb-6">
      <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">DSM-5-TR Diagnostic Category Mappings</h3>
      <p class="text-[10px] text-[var(--color-text-faint)] mb-3 italic">Diagnostic category references for threat modeling purposes &mdash; not diagnostic claims.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-3">
        {Object.entries(dsmClusters).map(([id, cluster]: [string, any]) => (
          <div class="glass rounded-lg p-3">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-2 h-2 rounded-full" style={`background: ${cluster.color}`} />
              <span class="text-xs font-semibold text-[var(--color-text-primary)]">{cluster.label}</span>
            </div>
            <div class="space-y-1">
              {(cluster.conditions || []).map((c: any) => (
                <div class="flex justify-between text-[10px]">
                  <span class="text-[var(--color-text-muted)] truncate mr-1">{c.name}</span>
                  <span class="font-mono text-[var(--color-text-faint)] shrink-0">{c.code}</span>
                </div>
              ))}
