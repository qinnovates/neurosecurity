  <section class="mb-10 reveal">
    <h2 class="text-lg font-bold font-[family-name:var(--font-heading)] mb-1">Clinical Mapping</h2>
    <p class="text-xs text-[var(--color-text-faint)] mb-6">Brain regions, neural pathways, and DSM-5-TR diagnostic category references mapped to QIF hourglass bands. For threat modeling purposes &mdash; not diagnostic claims.</p>

    <div class="grid lg:grid-cols-2 gap-6 mb-6">
      <!-- Hourglass band distribution -->
      <div class="glass rounded-xl p-5">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">Brain Regions by QIF Band</h3>
        <div class="space-y-2">
          {qifBands.map((b: any) => {
            const count = regionsByBand[b.id] || 0;
            const maxRegions = Math.max(...Object.values(regionsByBand) as number[]);
            const pct = maxRegions > 0 ? (count / maxRegions) * 100 : 0;
            return (
              <div class="flex items-center gap-2">
                <span class="text-xs font-mono w-6 shrink-0" style={`color: ${bandColors[b.id] || '#666'}`}>{b.id}</span>
                <span class="text-xs text-[var(--color-text-muted)] w-24 shrink-0 truncate">{b.name}</span>
                <div class="flex-1 h-4 bg-[var(--color-bg-surface)] rounded-full overflow-hidden">
                  <div class="h-full rounded-full" style={`width: ${pct}%; background: ${bandColors[b.id] || '#666'}`} />
                </div>
                <span class="text-xs font-mono text-[var(--color-text-faint)] w-6 text-right">{count}</span>
              </div>
            );
          })}
        </div>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-3">{totalRegions} brain structures across {totalBands} QIF hourglass bands</p>
      </div>

      <!-- Neural pathways breakdown -->
      <div class="glass rounded-xl p-5">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">Neural Pathways</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-[var(--color-text-faint)] uppercase tracking-wider mb-2">By Type</p>
            <div class="space-y-1.5">
              {Object.entries(pathwaysByType).sort((a, b) => b[1] - a[1]).map(([type, count]) => (
                <div class="flex justify-between text-xs">
                  <span class="text-[var(--color-text-muted)] truncate mr-2">{type.replace(/_/g, ' ')}</span>
                  <span class="font-mono text-purple-400">{count}</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <p class="text-xs text-[var(--color-text-faint)] uppercase tracking-wider mb-2">By Neurotransmitter</p>
            <div class="space-y-1.5">
              {Object.entries(pathwaysByNT).sort((a, b) => b[1] - a[1]).map(([nt, count]) => (
                <div class="flex justify-between text-xs">
                  <span class="text-[var(--color-text-muted)] capitalize">{nt}</span>
                  <span class="font-mono text-cyan-400">{count}</span>
                </div>
              ))}
