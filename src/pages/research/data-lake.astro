---
import PageLayout from '@/layouts/PageLayout.astro';

// Load all data sources
import landscapeRaw from '@shared/bci-landscape.json';
import atlasRaw from '@shared/qif-brain-bci-atlas.json';
import registrarRaw from '@shared/qtara-registrar.json';
import dsmRaw from '@shared/qif-dsm-mappings.json';
import ethicsRaw from '@shared/qif-ethics-controls.json';
import cveRaw from '@shared/cve-technique-mapping.json';
import controlsRaw from '@shared/qif-security-controls.json';
import pathwaysRaw from '@shared/qif-neural-pathways.json';
import neurotransmitterRaw from '@shared/qif-neurotransmitters.json';

const landscape = landscapeRaw as any;
const atlas = atlasRaw as any;
const registrar = registrarRaw as any;
const dsm = dsmRaw as any;
const ethics = ethicsRaw as any;
const cve = cveRaw as any;
const controls = controlsRaw as any;
const pathways = pathwaysRaw as any;

// --- Compute all metrics ---

// Companies
const companies = landscape.companies || [];
const totalCompanies = companies.length;
const invasiveCount = companies.filter((c: any) => c.type === 'invasive').length;
const nonInvasiveCount = companies.filter((c: any) => c.type === 'non_invasive').length;
const semiInvasiveCount = companies.filter((c: any) => c.type === 'semi_invasive').length;
const noSecCount = companies.filter((c: any) => c.security_posture === 'none_published').length;
const totalDevices = companies.reduce((s: number, c: any) => s + (c.devices || []).length, 0);
const totalFundingB = companies.reduce((s: number, c: any) => s + (c.funding_total_usd || 0), 0) / 1_000_000_000;
const activeCompanies = companies.filter((c: any) => c.status === 'active').length;

// Top funded companies
const topFunded = [...companies]
  .filter((c: any) => c.funding_total_usd > 0)
  .sort((a: any, b: any) => (b.funding_total_usd || 0) - (a.funding_total_usd || 0))
  .slice(0, 8)
  .map((c: any) => ({
    name: c.name,
    funding_M: Math.round((c.funding_total_usd || 0) / 1_000_000),
    type: c.type,
    security: c.security_posture,
  }));

// Devices by type
const allDevices = companies.flatMap((c: any) => (c.devices || []).map((d: any) => ({ ...d, company: c.name })));
const devicesByType: Record<string, number> = {};
for (const d of allDevices) {
  const t = d.type || 'unknown';
  devicesByType[t] = (devicesByType[t] || 0) + 1;
}

// Brain regions & bands
const brainRegions = atlas.brain_regions || [];
const qifBands = atlas.qif_bands || [];
const totalRegions = brainRegions.length;
const totalBands = qifBands.length;

// Regions by band
const regionsByBand: Record<string, number> = {};
for (const r of brainRegions) {
  const b = r.qif_band || 'unknown';
  regionsByBand[b] = (regionsByBand[b] || 0) + 1;
}

// TARA
const techniques = registrar.techniques || [];
const tactics = registrar.tactics || [];
const totalTechniques = techniques.length;
const totalTactics = tactics.length;

// Techniques by severity
const bySeverity: Record<string, number> = {};
for (const t of techniques) {
  const s = t.severity || 'unknown';
  bySeverity[s] = (bySeverity[s] || 0) + 1;
}

// Techniques by status
const byStatus: Record<string, number> = {};
for (const t of techniques) {
  const s = t.status || 'unknown';
  byStatus[s] = (byStatus[s] || 0) + 1;
}

// DSM-5
const dsmClusters = dsm.diagnostic_clusters || {};
const totalConditions = Object.values(dsmClusters).reduce((s: number, c: any) => s + (c.conditions || []).length, 0);
const totalClusters = Object.keys(dsmClusters).length;

// Neural pathways
const allPathways = pathways.pathways || [];
const totalPathways = allPathways.length;
const pathwayTypes = pathways.pathway_types || {};

// Pathways by type
const pathwaysByType: Record<string, number> = {};
for (const p of allPathways) {
  const t = p.type || 'unknown';
  pathwaysByType[t] = (pathwaysByType[t] || 0) + 1;
}

// Pathways by neurotransmitter
const pathwaysByNT: Record<string, number> = {};
for (const p of allPathways) {
  if (p.neurotransmitter) {
    pathwaysByNT[p.neurotransmitter] = (pathwaysByNT[p.neurotransmitter] || 0) + 1;
  }
}

// Neurorights
const neurorights = ethics.neurorights || {};
const totalNeurorights = Object.keys(neurorights).length;

// CVEs
const cveCount = (cve.mappings || []).length;

// Security controls
const controlsByBand: Record<string, number> = {};
for (const [band, types] of Object.entries(controls.controls_by_band || {})) {
  const t = types as any;
  controlsByBand[band] = (t.detection || []).length + (t.prevention || []).length + (t.response || []).length;
}
const totalControls = Object.values(controlsByBand).reduce((s: number, c: number) => s + c, 0);

// Market data
const marketForecasts = landscape.market_data?.market_size_estimates || [];
const fundingRounds = landscape.market_data?.major_funding_rounds || [];
const vcDeals = landscape.market_data?.vc_aggregate_by_year || [];

// Governance frameworks
const frameworks = ethics.governance_frameworks || [];

// Neurotransmitters
const ntData = neurotransmitterRaw as any;
const allNeurotransmitters = ntData.neurotransmitters || [];
const totalNeurotransmitters = allNeurotransmitters.length;
const totalReceptors = allNeurotransmitters.reduce((s: number, nt: any) => s + (Array.isArray(nt.receptors) ? nt.receptors.length : 0), 0);
const totalCofactors = allNeurotransmitters.reduce((s: number, nt: any) => s + (nt.cofactor_dependencies || []).length, 0);
const totalSynthSteps = allNeurotransmitters.reduce((s: number, nt: any) => s + (nt.synthesis_pathway || []).length, 0);

// Financial / Investor intelligence
const investorIntel = landscape.market_data?.investor_intelligence || {};
const crossPortfolioVCs = investorIntel.cross_portfolio_vcs || [];
const sovereignFunds = investorIntel.sovereign_wealth_funds || [];
const bigTechBCI = investorIntel.big_tech_corporate_venture || [];
const peFirms = investorIntel.pe_firms || [];
const intelDefense = investorIntel.intelligence_agencies_defense || [];
const govGrants = landscape.market_data?.government_grants || [];
const acquisitions = landscape.market_data?.acquisition_history || [];
const totalTrackedFunding = landscape.market_data?.total_funding_tracked_usd || 0;

// Top funding rounds
const topRounds = [...fundingRounds]
  .sort((a: any, b: any) => (b.amount_usd || 0) - (a.amount_usd || 0))
  .slice(0, 10);

// NT color map
const ntColors: Record<string, string> = {
  dopamine: '#22c55e', serotonin: '#3b82f6', norepinephrine: '#ef4444',
  acetylcholine: '#f59e0b', glutamate: '#ec4899', gaba: '#8b5cf6',
  glycine: '#06b6d4', histamine: '#f97316', endorphins: '#a78bfa',
  nitric_oxide: '#14b8a6', endocannabinoids: '#84cc16', adenosine: '#6366f1',
};

// --- Dopamine Reward Center Dependency Chain ---
// This is a scientifically verified molecular dependency chain showing
// how a QIF attack on the reward center cascades through biochemistry.
const mesolimbicPathway = allPathways.find((p: any) => p.id === 'mesolimbic');

// Color config
const severityColors: Record<string, string> = {
  critical: '#ef4444',
  high: '#f59e0b',
  medium: '#eab308',
  low: '#22c55e',
  info: '#3b82f6',
};

const bandColors: Record<string, string> = {
  N7: '#ef4444', N6: '#f97316', N5: '#f59e0b', N4: '#eab308',
  N3: '#84cc16', N2: '#22c55e', N1: '#14b8a6',
  I0: '#06b6d4',
  S1: '#3b82f6', S2: '#6366f1', S3: '#8b5cf6',
};
---

<PageLayout
  title="QIF Data Lake Dashboard"
  description="Live metrics dashboard across the QIF data lake: BCI companies, devices, TARA threats, brain regions, neural pathways, DSM-5 mappings, molecular dependencies, and business intelligence."
  breadcrumbs={[{ label: 'Research', href: '/research/' }, { label: 'Data Lake' }]}
  wide={true}
>
  <div class="mb-8 reveal">
    <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-heading)] mb-3">QIF Data Lake</h1>
    <p class="text-base text-[var(--color-text-muted)] max-w-3xl">
      Live metrics derived from {Object.keys(landscape).length + Object.keys(atlas).length + Object.keys(registrar).length} data sources. Spanning business intelligence (companies, funding, market trends) and clinical mapping (brain regions, neural pathways, molecular dependencies). All queryable via <a href="/research/landscape/" class="text-[var(--color-accent-primary)] hover:underline">KQL</a>.
    </p>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 1: OVERVIEW STATS                                  -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <section class="glass rounded-xl p-6 sm:p-8 mb-10 reveal">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-faint)] mb-5">Data Lake Overview</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-4 text-center">
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-primary)]">{totalCompanies}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Companies</p>
      </div>
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-secondary)]">{totalDevices}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Devices</p>
      </div>
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-tertiary)]">{totalTechniques}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">TARA Techniques</p>
      </div>
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-cyan-400">{totalRegions}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Brain Regions</p>
      </div>
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-purple-400">{totalPathways}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Neural Pathways</p>
      </div>
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-amber-400">{totalConditions}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">DSM-5 Conditions</p>
      </div>
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-red-400">{totalControls}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Security Controls</p>
      </div>
      <div class="glass rounded-lg p-3">
        <p class="text-2xl font-bold font-[family-name:var(--font-mono)] text-green-400">{cveCount}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">CVE Mappings</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!-- SECTION 2: BUSINESS INTELLIGENCE                           -->
  <!-- ═══════════════════════════════════════════════════════════ -->

  <section class="mb-10 reveal">
    <h2 class="text-lg font-bold font-[family-name:var(--font-heading)] mb-1">Business Intelligence</h2>
    <p class="text-xs text-[var(--color-text-faint)] mb-6">BCI industry tracking: companies, investments, market trends, security posture</p>

    <div class="grid lg:grid-cols-2 gap-6 mb-6">
      <!-- Funding bar chart -->
      <div class="glass rounded-xl p-5">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">Top Funded Companies</h3>
        <div class="space-y-2">
          {topFunded.map((c) => {
            const maxFunding = topFunded[0]?.funding_M || 1;
            const pct = Math.round((c.funding_M / maxFunding) * 100);
            const isInsecure = c.security === 'none_published';
            return (
              <div class="flex items-center gap-3">
                <span class="text-xs text-[var(--color-text-muted)] w-28 shrink-0 truncate">{c.name}</span>
                <div class="flex-1 h-5 bg-[var(--color-bg-surface)] rounded-full overflow-hidden relative">
                  <div
                    class="h-full rounded-full transition-all"
                    style={`width: ${pct}%; background: ${isInsecure ? 'linear-gradient(90deg, #ef4444, #f97316)' : 'linear-gradient(90deg, #22c55e, #10b981)'}`}
                  />
                </div>
                <span class="text-xs font-mono text-[var(--color-text-faint)] w-16 text-right">${c.funding_M}M</span>
                {isInsecure && <span class="text-[8px] text-red-400 uppercase">No Sec</span>}
              </div>
            );
          })}
        </div>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-3">
          Total tracked funding: <span class="font-mono text-[var(--color-accent-primary)]">${totalFundingB.toFixed(1)}B</span>
          &middot; <span class="text-red-400">{noSecCount}/{totalCompanies}</span> have no published security docs
        </p>
      </div>

      <!-- Company breakdown -->
      <div class="glass rounded-xl p-5">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">Industry Breakdown</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-[var(--color-text-faint)] uppercase tracking-wider mb-2">By Modality</p>
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs">
                <span class="text-[var(--color-text-muted)]">Invasive</span>
                <span class="font-mono text-red-400">{invasiveCount}</span>
              </div>
              <div class="flex justify-between text-xs">
                <span class="text-[var(--color-text-muted)]">Non-invasive</span>
                <span class="font-mono text-cyan-400">{nonInvasiveCount}</span>
              </div>
              <div class="flex justify-between text-xs">
                <span class="text-[var(--color-text-muted)]">Semi-invasive</span>
                <span class="font-mono text-amber-400">{semiInvasiveCount}</span>
              </div>
            </div>
          </div>
          <div>
            <p class="text-xs text-[var(--color-text-faint)] uppercase tracking-wider mb-2">By Status</p>
            <div class="space-y-1.5">
              <div class="flex justify-between text-xs">
                <span class="text-[var(--color-text-muted)]">Active</span>
                <span class="font-mono text-green-400">{activeCompanies}</span>
              </div>
              <div class="flex justify-between text-xs">
                <span class="text-[var(--color-text-muted)]">Acquired</span>
                <span class="font-mono text-purple-400">{companies.filter((c: any) => c.status === 'acquired').length}</span>
              </div>
              <div class="flex justify-between text-xs">
                <span class="text-[var(--color-text-muted)]">Defunct</span>
                <span class="font-mono text-[var(--color-text-faint)]">{companies.filter((c: any) => c.status === 'defunct' || c.status === 'dissolved').length}</span>
              </div>
            </div>
          </div>
        </div>

        <hr class="border-[var(--color-border)]/30 my-4" />

        <p class="text-xs text-[var(--color-text-faint)] uppercase tracking-wider mb-2">Devices by Type</p>
        <div class="flex flex-wrap gap-2">
          {Object.entries(devicesByType).sort((a, b) => b[1] - a[1]).map(([type, count]) => (
            <span class="inline-flex items-center gap-1 text-xs px-2 py-1 rounded-full glass">
              <span class="w-1.5 h-1.5 rounded-full" style={`background: ${type === 'invasive' ? '#ef4444' : type === 'non_invasive' ? '#06b6d4' : '#f59e0b'}`} />
              {type.replace(/_/g, '-')}: <span class="font-mono">{count}</span>
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- Market data -->
    {marketForecasts.length > 0 && (
      <div class="glass rounded-xl p-5 mb-6">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">Market Projections</h3>
        <div class="overflow-x-auto">
          <div class="flex gap-3 min-w-max">
            {marketForecasts.slice(0, 8).map((m: any) => (
              <div class="text-center glass rounded-lg p-3 min-w-[90px]">
                <p class="text-lg font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-primary)]">${m.value_billion_usd}B</p>
                <p class="text-[10px] text-[var(--color-text-faint)] mt-0.5">{m.year}</p>
                {m.cagr_percent && <p class="text-[9px] text-green-400">{m.cagr_percent}% CAGR</p>}
                {m.source && <p class="text-[8px] text-[var(--color-text-faint)] mt-1 truncate max-w-[80px]">{m.source}</p>}
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Top Funding Rounds -->
    {topRounds.length > 0 && (
      <div class="glass rounded-xl p-5 mb-6">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">Top Funding Rounds</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-xs">
            <thead>
              <tr class="border-b border-[var(--color-border)]/30">
                <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Company</th>
                <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Round</th>
                <th class="text-right py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Amount</th>
                <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Date</th>
                <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Lead Investor</th>
              </tr>
            </thead>
            <tbody class="text-[var(--color-text-muted)]">
              {topRounds.map((r: any, i: number) => (
                <tr class={`border-b border-[var(--color-border)]/10 ${i === 0 ? 'bg-green-500/5' : ''}`}>
                  <td class="py-2 px-2 font-semibold text-[var(--color-text-primary)]">{r.company}</td>
                  <td class="py-2 px-2">{r.round}</td>
                  <td class="py-2 px-2 text-right font-mono text-green-400">${Math.round((r.amount_usd || 0) / 1_000_000)}M</td>
                  <td class="py-2 px-2 text-[var(--color-text-faint)]">{r.date || '—'}</td>
                  <td class="py-2 px-2 text-[var(--color-text-faint)] truncate max-w-[150px]">{r.lead_investor || '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-[10px] text-[var(--color-text-faint)] mt-3">Total tracked funding: ${Math.round(totalTrackedFunding / 1_000_000_000 * 100) / 100}B across {fundingRounds.length} rounds</p>
      </div>
    )}

    <!-- VC Deal Flow by Year -->
    {vcDeals.length > 0 && (
      <div class="glass rounded-xl p-5 mb-6">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-4">VC Deal Flow by Year</h3>
        <div class="flex items-end gap-3 h-32">
          {vcDeals.map((y: any) => {
            const maxDeals = Math.max(...vcDeals.map((v: any) => v.total_deals || 0));
            const pct = maxDeals > 0 ? ((y.total_deals || 0) / maxDeals) * 100 : 0;
            return (
              <div class="flex flex-col items-center flex-1">
                <span class="text-[10px] font-mono text-green-400 mb-1">{y.total_deals}</span>
                <div class="w-full rounded-t" style={`height: ${pct}%; background: linear-gradient(to top, var(--color-accent-primary), #22c55e)`} />
                <span class="text-[9px] text-[var(--color-text-faint)] mt-1">{y.year}</span>
                <span class="text-[8px] font-mono text-[var(--color-text-faint)]">${Math.round((y.total_invested_usd || 0) / 1_000_000)}M</span>
              </div>
            );
          })}
        </div>
      </div>
    )}

    <!-- Investor Intelligence -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
      <!-- Cross-Portfolio VCs -->
      {crossPortfolioVCs.length > 0 && (
        <div class="glass rounded-xl p-5">
          <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-3">Cross-Portfolio VCs</h3>
          <p class="text-[10px] text-[var(--color-text-faint)] mb-3">VCs with 2+ BCI investments</p>
          <div class="space-y-2">
            {crossPortfolioVCs.slice(0, 8).map((vc: any) => (
              <div class="flex items-center justify-between text-xs">
                <span class="text-[var(--color-text-muted)] truncate mr-2">{vc.name}</span>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="font-mono text-cyan-400">{(vc.portfolio || []).length} cos</span>
                </div>
              </div>
            ))}
          </div>
          <p class="text-[10px] text-[var(--color-text-faint)] mt-2">{crossPortfolioVCs.length} tracked cross-portfolio VCs</p>
        </div>
      )}

      <!-- Sovereign Wealth & Big Tech -->
      <div class="glass rounded-xl p-5">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-3">Sovereign & Big Tech</h3>
        {sovereignFunds.length > 0 && (
          <div class="mb-3">
            <p class="text-[10px] text-amber-400 font-semibold uppercase tracking-wider mb-2">Sovereign Wealth</p>
            <div class="space-y-1.5">
              {sovereignFunds.map((f: any) => (
                <div class="flex justify-between text-xs">
                  <span class="text-[var(--color-text-muted)] truncate mr-2">{f.name}</span>
                  <span class="font-mono text-amber-400 shrink-0">{(f.bci_investments || []).length}</span>
                </div>
              ))}
            </div>
          </div>
        )}
        {bigTechBCI.length > 0 && (
          <div>
            <p class="text-[10px] text-purple-400 font-semibold uppercase tracking-wider mb-2">Big Tech / Corporate</p>
            <div class="space-y-1.5">
              {bigTechBCI.map((b: any) => (
                <div class="flex justify-between text-xs">
                  <span class="text-[var(--color-text-muted)] truncate mr-2">{b.parent || b.name}</span>
                  <span class="text-[var(--color-text-faint)] text-[10px] truncate max-w-[100px]">{b.focus || '—'}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- PE, Intel/Defense, Gov Grants -->
      <div class="glass rounded-xl p-5">
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-3">Other Investors</h3>
        {peFirms.length > 0 && (
          <div class="mb-3">
