  <section class="mb-10 reveal">
    <h2 class="text-lg font-bold font-[family-name:var(--font-heading)] mb-1">Security Controls by Band</h2>
    <p class="text-xs text-[var(--color-text-faint)] mb-6">Detection, prevention, and response controls mapped across the 11-band QIF hourglass</p>

    <div class="glass rounded-xl p-5">
      <div class="space-y-2">
        {qifBands.map((b: any) => {
          const count = controlsByBand[b.id] || 0;
          const maxControls = Math.max(...Object.values(controlsByBand) as number[]);
          const pct = maxControls > 0 ? (count / maxControls) * 100 : 0;
          return (
            <div class="flex items-center gap-2">
              <span class="text-xs font-mono w-6 shrink-0" style={`color: ${bandColors[b.id] || '#666'}`}>{b.id}</span>
              <span class="text-xs text-[var(--color-text-muted)] w-28 shrink-0 truncate">{b.name}</span>
              <div class="flex-1 h-4 bg-[var(--color-bg-surface)] rounded-full overflow-hidden">
                <div class="h-full rounded-full" style={`width: ${pct}%; background: ${bandColors[b.id] || '#666'}`} />
              </div>
              <span class="text-xs font-mono text-[var(--color-text-faint)] w-8 text-right">{count}</span>
            </div>
          );
        })}
      </div>
    </div>
  </section>

