---
import PageLayout from '@/layouts/PageLayout.astro';
import registry from '@shared/research-registry.json';

const breadcrumbs = [
  { label: 'Research', href: '/research/' },
  { label: 'Neuroethics Landscape' },
];

const explorer = registry.explorer;
const ethicsTimeline = registry.timelines.neuroethics;
const securityTimeline = registry.timelines.neurosecurity;

const pillars = [
  {
    name: 'Cognitive Liberty',
    description: 'The right to mental self-determination. Freedom to alter, protect, or refuse to disclose your own mental states.',
    sources: ['Ienca & Andorno 2017', 'Farahany 2023', 'Bublitz 2013'],
    icon: 'M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
  },
  {
    name: 'Mental Privacy',
    description: 'Protection of neural data from unauthorized access, collection, or inference. Extends data privacy to brain signals.',
    sources: ['Ienca & Andorno 2017', 'Yuste et al. 2017', 'Jwa & Poldrack 2024', 'Shen & Wolf 2020'],
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
  },
  {
    name: 'Mental Integrity',
    description: 'The right to be free from unauthorized manipulation or alteration of neural processes. Protection against cognitive harm.',
    sources: ['Ienca & Andorno 2017', 'Lavazza 2023', 'Ligthart & Meynen 2023'],
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    name: 'Psychological Continuity',
    description: 'The right to maintain personal identity and sense of self. Protection against unauthorized alteration of personality, memory, or cognition.',
    sources: ['Ienca & Andorno 2017', 'Goering et al. 2021'],
    icon: 'M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3',
  },
];

const frameworks = [
  { name: 'Beauchamp & Childress (1979)', type: 'Ethics', cl: true, mp: true, mi: true, pc: false, ea: true },
  { name: 'Ienca & Andorno (2017)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Yuste et al. / Nature (2017)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'Farahany (2023)', type: 'Rights', cl: true, mp: true, mi: false, pc: false, ea: false },
  { name: 'OECD (2019)', type: 'Policy', cl: false, mp: true, mi: true, pc: false, ea: true },
  { name: 'UNESCO (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'WHO (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: false, ea: true },
  { name: 'Council of Europe (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Chile Constitution (2021)', type: 'Law', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Colorado HB 1058 (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'California SB 1223 (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'EU AI Act (2024)', type: 'Law', cl: false, mp: true, mi: true, pc: false, ea: false },
  { name: 'Goering et al. (2021)', type: 'Ethics', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'Farah (2015)', type: 'Ethics', cl: false, mp: true, mi: true, pc: false, ea: false },
  { name: 'Morse (2006)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Wexler (2024)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Ienca (2021/2022)', type: 'Rigor', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Hendriks et al. (2019)', type: 'Ethics', cl: false, mp: false, mi: true, pc: false, ea: false },
  { name: 'Ligthart & Meynen (2023)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Lavazza (2023)', type: 'Rights', cl: false, mp: false, mi: true, pc: true, ea: false },
  { name: 'Andorno & Gkotsi (2022)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Savulescu & Bostrom (2009)', type: 'Ethics', cl: false, mp: false, mi: false, pc: false, ea: true },
  { name: 'Kreitmair (2019)', type: 'Ethics', cl: false, mp: true, mi: false, pc: false, ea: true },
  { name: 'Kellmeyer (2022)', type: 'Rights', cl: false, mp: true, mi: true, pc: false, ea: false },
  { name: 'Bublitz (2022)', type: 'Rigor', cl: true, mp: true, mi: true, pc: false, ea: false },
  { name: 'Racine, Illes (2005)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Poldrack (2006)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Tennison & Moreno (2012)', type: 'Rigor', cl: true, mp: true, mi: true, pc: false, ea: false },
  { name: 'Montana SB 214 (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'Minnesota HF 1370 (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'Latin American Model Law (2023)', type: 'Law', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'China MoST Guidelines (2024)', type: 'Policy', cl: false, mp: true, mi: true, pc: false, ea: true },
  { name: 'UN HRC Advisory (2024)', type: 'Policy', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'QIF (in development)', type: 'HOW', cl: true, mp: true, mi: true, pc: true, ea: true },
];

// Category counts for display
const explorerCounts = {
  ethics: explorer.filter(e => e.domain === 'ethics' || e.domain === 'both').length,
  security: explorer.filter(e => e.domain === 'security' || e.domain === 'both').length,
  academia: explorer.filter(e => e.category === 'academia').length,
  researcher: explorer.filter(e => e.category === 'researcher').length,
  standards: explorer.filter(e => e.category === 'standards').length,
};

---

<PageLayout
  title="The Neuroethics Landscape — 33 Frameworks, 1 Gap"
  description="A comprehensive survey of neuroethics frameworks, institutions, and the Principles-to-Protocol Gap that QIF fills."
  breadcrumbs={breadcrumbs}
  wide
>

  <!-- ═══ HERO ═══ -->
  <section class="py-12 md:py-20">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <p class="text-xs font-medium tracking-[0.2em] uppercase mb-4 text-[var(--color-text-faint)]">
        Neuroethics Survey
      </p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-[family-name:var(--font-heading)] tracking-tight mb-6 leading-[1.15]">
        <span class="text-[var(--color-text-primary)]">33 Frameworks.</span>
        <br />
        <span class="bg-gradient-to-r from-[var(--color-accent-primary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">
          One Gap.
        </span>
      </h1>
      <p class="text-base sm:text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed">
        Nearly a century of bioethics and neuroethics scholarship have converged on five universal principles.
        Every framework answers <strong class="text-[var(--color-text-primary)]">why</strong> we should protect neural rights
        or <strong class="text-[var(--color-text-primary)]">what</strong> those rights are.
        None answer <strong class="text-[var(--color-text-primary)]">how</strong> to enforce them technically.
      </p>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="py-12 md:py-16" id="timeline">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Timeline
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <!-- Timeline domain toggle -->
    <div class="flex justify-center gap-1 mb-8 p-1 rounded-lg bg-[var(--color-bg-surface)] border border-[var(--color-border)] w-fit mx-auto">
      <button data-tl="ethics" class="tl-toggle px-4 py-1.5 rounded-md text-xs font-semibold transition-all bg-[var(--color-accent-tertiary)]/10 text-[var(--color-accent-tertiary)]">
        Neuroethics
      </button>
      <button data-tl="security" class="tl-toggle px-4 py-1.5 rounded-md text-xs font-semibold transition-all text-[var(--color-text-faint)] hover:text-[var(--color-text-muted)]">
        Neurosecurity
      </button>
    </div>

    <!-- Ethics timeline -->
    <div id="tl-ethics" class="tl-panel max-w-4xl mx-auto">
      <div class="relative">
        <div class="absolute left-4 sm:left-6 top-0 bottom-0 w-px bg-gradient-to-b from-[var(--color-accent-tertiary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)]"></div>
        <div class="flex flex-col gap-6">
          {ethicsTimeline.map((t, i) => (
            <div class="flex items-start gap-4 sm:gap-6 pl-2">
              <div class={`shrink-0 w-5 h-5 rounded-full border-2 mt-1 bg-[var(--color-bg-surface)] border-[var(--color-accent-tertiary)]`}></div>
              <div>
                <span class="text-xs font-bold tracking-[0.1em] uppercase text-[var(--color-accent-tertiary)]">{t.year}</span>
                <h3 class="text-sm font-bold text-[var(--color-text-primary)]">{t.label}</h3>
                <p class="text-xs text-[var(--color-text-muted)]">{t.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Security timeline -->
    <div id="tl-security" class="tl-panel hidden max-w-4xl mx-auto">
      <div class="relative">
        <div class="absolute left-4 sm:left-6 top-0 bottom-0 w-px bg-gradient-to-b from-[var(--color-accent-primary)]/30 via-[var(--color-accent-primary)] to-[var(--color-accent-primary)]"></div>
        <div class="flex flex-col gap-6">
          {securityTimeline.map((t, i) => (
            <div class="flex items-start gap-4 sm:gap-6 pl-2">
              <div class={`shrink-0 w-5 h-5 rounded-full border-2 mt-1 ${i === securityTimeline.length - 1 ? 'bg-[var(--color-accent-primary)] border-[var(--color-accent-primary)]' : 'bg-[var(--color-bg-surface)] border-[var(--color-accent-primary)]'}`}></div>
              <div>
                <span class="text-xs font-bold tracking-[0.1em] uppercase text-[var(--color-accent-primary)]">{t.year}</span>
                <h3 class="text-sm font-bold text-[var(--color-text-primary)]">{t.label}</h3>
                <p class="text-xs text-[var(--color-text-muted)]">{t.desc}</p>
                {t.detail && <p class="text-[10px] text-[var(--color-text-faint)] italic mt-0.5">{t.detail}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FIVE PILLARS ═══ -->
  <section class="py-12 md:py-16" id="pillars">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Five Universal Pillars
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <p class="text-sm text-[var(--color-text-muted)] max-w-2xl mx-auto text-center mb-8">
      Despite different terminology, legal traditions, and institutional mandates, every major neuroethics framework
      converges on these five themes.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
      {pillars.map((p) => (
        <div class="glass rounded-xl p-5 border border-[var(--color-border)]">
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-5 h-5 text-[var(--color-accent-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={p.icon} />
            </svg>
            <h3 class="text-sm font-bold text-[var(--color-text-primary)]">{p.name}</h3>
          </div>
          <p class="text-xs text-[var(--color-text-muted)] leading-relaxed mb-3">{p.description}</p>
          <div class="flex flex-wrap gap-1">
            {p.sources.map((s) => (
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-accent-secondary)]/10 text-[var(--color-accent-secondary)]">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ FIELD EXPLORER ═══ -->
  <section class="py-12 md:py-16" id="explorer">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Who Built the Field
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <p class="text-sm text-[var(--color-text-muted)] max-w-2xl mx-auto text-center mb-6">
      Neuroethics defines the rights. Neurosecurity builds the defenses. Governance bridges them.
      <span class="text-[var(--color-text-faint)] text-xs block mt-1">{explorer.length} entries across both domains.</span>
    </p>

    <!-- Controls: domain toggle + category filters -->
    <div class="max-w-6xl mx-auto mb-6">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <!-- Domain toggle (left) -->
        <div class="flex gap-1 p-1 rounded-lg bg-[var(--color-bg-surface)] border border-[var(--color-border)]" role="tablist" aria-label="Domain filter">
          <button role="tab" aria-selected="true" data-domain="all" class="exp-domain px-3 py-1.5 rounded-md text-xs font-semibold transition-all bg-[var(--color-accent-secondary)]/10 text-[var(--color-accent-secondary)]">
            All
          </button>
          <button role="tab" aria-selected="false" data-domain="ethics" class="exp-domain px-3 py-1.5 rounded-md text-xs font-semibold transition-all text-[var(--color-text-faint)] hover:text-[var(--color-text-muted)]">
            Neuroethics <span class="text-[10px] opacity-60">({explorerCounts.ethics})</span>
          </button>
          <button role="tab" aria-selected="false" data-domain="security" class="exp-domain px-3 py-1.5 rounded-md text-xs font-semibold transition-all text-[var(--color-text-faint)] hover:text-[var(--color-text-muted)]">
            Neurosecurity <span class="text-[10px] opacity-60">({explorerCounts.security})</span>
          </button>
        </div>

        <!-- Category filters (right) -->
        <div class="flex gap-1.5 flex-wrap" role="group" aria-label="Category filter">
          <button data-category="all" class="exp-cat px-3 py-1.5 rounded-full text-[10px] font-semibold tracking-wide uppercase transition-all border border-[var(--color-accent-secondary)]/30 bg-[var(--color-accent-secondary)]/10 text-[var(--color-accent-secondary)]">
            All
          </button>
          <button data-category="academia" class="exp-cat px-3 py-1.5 rounded-full text-[10px] font-semibold tracking-wide uppercase transition-all border border-transparent text-[var(--color-text-faint)] hover:text-[var(--color-text-muted)] hover:border-[var(--color-border)]">
            Academia ({explorerCounts.academia})
          </button>
          <button data-category="researcher" class="exp-cat px-3 py-1.5 rounded-full text-[10px] font-semibold tracking-wide uppercase transition-all border border-transparent text-[var(--color-text-faint)] hover:text-[var(--color-text-muted)] hover:border-[var(--color-border)]">
            Researchers ({explorerCounts.researcher})
          </button>
          <button data-category="standards" class="exp-cat px-3 py-1.5 rounded-full text-[10px] font-semibold tracking-wide uppercase transition-all border border-transparent text-[var(--color-text-faint)] hover:text-[var(--color-text-muted)] hover:border-[var(--color-border)]">
            Standards &amp; Policy ({explorerCounts.standards})
          </button>
        </div>
      </div>
    </div>

    <!-- Result count -->
    <p id="exp-count" class="text-[10px] text-[var(--color-text-faint)] max-w-6xl mx-auto mb-3">
      Showing {explorer.length} of {explorer.length}
    </p>

    <!-- Card grid -->
    <div id="exp-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 max-w-6xl mx-auto">
      {explorer.map((e) => {
        const domainColor = e.domain === 'ethics' ? 'var(--color-accent-tertiary)' : e.domain === 'security' ? 'var(--color-accent-primary)' : 'var(--color-accent-secondary)';
        const domainLabel = e.domain === 'ethics' ? 'Ethics' : e.domain === 'security' ? 'Security' : 'Both';
        const catLabel = e.category === 'academia' ? 'Academia' : e.category === 'researcher' ? 'Researcher' : 'Standards';
        const statusColor = e.status === 'Active' ? 'var(--color-status-safe)' : e.status === 'Partial' ? 'var(--color-status-warn)' : e.status === 'Gap' ? 'var(--color-status-danger)' : '';
        return (
          <div class="exp-card glass rounded-xl p-4 border border-[var(--color-border)] transition-opacity duration-200" data-domain={e.domain} data-category={e.category}>
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <h3 class="text-xs font-bold text-[var(--color-text-primary)]">{e.name}</h3>
              <span class="text-[9px] font-bold tracking-wider uppercase px-1.5 py-0.5 rounded" style={`color: ${domainColor}; background: ${domainColor}12;`}>{domainLabel}</span>
              <span class="text-[9px] px-1.5 py-0.5 rounded-full bg-[var(--color-bg-surface)] text-[var(--color-text-faint)] border border-[var(--color-border)]">{catLabel}</span>
              {e.status && (
                <span class="text-[9px] font-bold px-1.5 py-0.5 rounded-full" style={`color: ${statusColor}; background: ${statusColor}12;`}>{e.status}</span>
              )}
            </div>
            <p class="text-[10px] text-[var(--color-text-faint)] mb-1">{e.subtitle} &middot; {e.detail}</p>
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">{e.contribution}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ═══ FRAMEWORK COMPARISON ═══ -->
  <section class="py-12 md:py-16" id="comparison">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Framework Comparison
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="glass rounded-2xl p-4 sm:p-6 max-w-6xl mx-auto overflow-x-auto">
      <table class="w-full text-xs min-w-[600px]">
        <thead>
          <tr class="border-b border-[var(--color-border)]">
            <th class="text-left py-2 pr-3 text-[var(--color-text-primary)] font-semibold">Framework</th>
            <th class="text-center py-2 px-2 text-[var(--color-text-faint)] font-semibold">Type</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">CL</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">MP</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">MI</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">PC</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">EA</th>
          </tr>
        </thead>
        <tbody class="text-[var(--color-text-muted)]">
          {frameworks.map((f) => (
            <tr class={`border-b border-[var(--color-border)]/30 ${f.type === 'HOW' ? 'bg-[var(--color-accent-primary)]/5 font-medium' : ''}`}>
              <td class="py-2 pr-3 text-[var(--color-text-primary)]">{f.name}</td>
              <td class="text-center py-2 px-2">
                <span class={`text-[10px] px-1.5 py-0.5 rounded-full ${
                  f.type === 'HOW' ? 'bg-[var(--color-accent-primary)]/15 text-[var(--color-accent-primary)]' :
                  f.type === 'Law' ? 'bg-[var(--color-status-warn)]/15 text-[var(--color-status-warn)]' :
                  f.type === 'Policy' ? 'bg-[var(--color-accent-secondary)]/15 text-[var(--color-accent-secondary)]' :
                  f.type === 'Rigor' ? 'bg-[var(--color-text-faint)]/15 text-[var(--color-text-faint)]' :
                  'bg-[var(--color-accent-tertiary)]/15 text-[var(--color-accent-tertiary)]'
                }`}>{f.type}</span>
              </td>
              <td class="text-center py-2 px-2">{f.cl ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.mp ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.mi ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.pc ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.ea ? '\u2713' : ''}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="mt-4 pt-3 border-t border-[var(--color-border)]/50 text-[10px] text-[var(--color-text-faint)]">
        CL = Cognitive Liberty &middot; MP = Mental Privacy &middot; MI = Mental Integrity &middot; PC = Psychological Continuity
