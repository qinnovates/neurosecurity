---
import PageLayout from '@/layouts/PageLayout.astro';
import { getBciStats } from '@/lib/bci-data';
import { BCI_CONSTRAINTS, BCI_VALIDATION } from '@/lib/bci-limits-constants';
import { TARA_TECHNIQUES } from '@/lib/qif-constants';
import { getValidationStats } from '@/lib/validation-data';

const stats = getBciStats();
const valStats = getValidationStats();
---

<PageLayout
  title="BCI Research"
  description="Brain-computer interface research hub: device dashboard, market landscape, hardware explorer, physics constraints, security guardrails, validation, and open API."
  breadcrumbs={[{ label: 'BCI Research' }]}
  wide={true}
>
  <div class="max-w-5xl mx-auto">

    <!-- Hero -->
    <section class="mb-12">
      <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-heading)] mb-4">
        BCI Research
      </h1>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl">
        Everything QIF has produced on brain-computer interface hardware, physics, and security. Device profiles, market analysis, physics constraints, and an open API — all from FDA filings, peer-reviewed papers, and original derivation.
      </p>
    </section>

    <!-- Stats bar -->
    <section class="glass rounded-xl p-6 sm:p-8 mb-12">
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-6 text-center">
        <div>
          <p class="text-3xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-primary)]">{stats.totalDevices}</p>
          <p class="text-xs text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Devices</p>
        </div>
        <div>
          <p class="text-3xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-tertiary)]">{stats.manufacturers}</p>
          <p class="text-xs text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Companies</p>
        </div>
        <div>
          <p class="text-3xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-secondary)]">{BCI_CONSTRAINTS.length}</p>
          <p class="text-xs text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Physics Constraints</p>
        </div>
        <div>
          <p class="text-3xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-status-safe)]">{BCI_VALIDATION.constraintsVerified}/{BCI_VALIDATION.constraintsTotal}</p>
          <p class="text-xs text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Cross-Validated</p>
        </div>
        <div>
          <p class="text-3xl font-bold font-[family-name:var(--font-mono)] text-[var(--color-accent-primary)]">{valStats.totalTested}</p>
          <p class="text-xs text-[var(--color-text-faint)] mt-1 uppercase tracking-wider">Tests Passed</p>
        </div>
      </div>
    </section>

    <!-- Primary Tools -->
    <section class="mb-12">
      <h2 class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-text-faint)] mb-6">Research Tools</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <!-- Dashboard -->
        <a href="/interface-risks/dashboard/" class="glass rounded-xl p-6 sm:p-8 hover:border-[var(--color-accent-primary)] border border-transparent transition-all group">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xs font-bold font-[family-name:var(--font-mono)] px-2 py-1 rounded bg-[var(--color-accent-primary)]/10 text-[var(--color-accent-primary)]">DASHBOARD</span>
          </div>
          <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-primary)] transition-colors">Device Dashboard</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Single-pane view of any BCI device. Select a device to see specs, brain regions, hourglass position, threats, and physics constraints all at once.
          </p>
        </a>

        <!-- Landscape -->
        <a href="/neuroethics/landscape/" class="glass rounded-xl p-6 sm:p-8 hover:border-[var(--color-accent-secondary)] border border-transparent transition-all group">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xs font-bold font-[family-name:var(--font-mono)] px-2 py-1 rounded bg-[var(--color-accent-secondary)]/10 text-[var(--color-accent-secondary)]">MARKET</span>
          </div>
          <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">BCI Landscape</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            The full BCI market mapped — {stats.totalDevices} devices across {stats.manufacturers} companies, filterable by type, invasiveness, brain regions, and regulatory status. Funding data, publication trends, and KQL queries.
          </p>
        </a>

        <!-- Hardware Explorer -->
        <a href="/interface-risks/explorer/" class="glass rounded-xl p-6 sm:p-8 hover:border-[var(--color-accent-tertiary)] border border-transparent transition-all group">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xs font-bold font-[family-name:var(--font-mono)] px-2 py-1 rounded bg-[var(--color-accent-tertiary)]/10 text-[var(--color-accent-tertiary)]">INVENTORY</span>
          </div>
          <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-tertiary)] transition-colors">Hardware Explorer</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            {stats.totalDevices} BCI devices from FDA filings, manufacturer datasheets, and peer-reviewed papers. Filter by type, QIF band, or interface direction. Full specs, brain targeting, and threat mapping per device.
          </p>
        </a>

        <!-- Validation -->
        <a href="/research/validation/" class="glass rounded-xl p-6 sm:p-8 hover:border-[var(--color-status-safe)] border border-transparent transition-all group">
          <div class="flex items-center gap-3 mb-4">
            <span class="text-xs font-bold font-[family-name:var(--font-mono)] px-2 py-1 rounded bg-[var(--color-status-safe)]/10 text-[var(--color-status-safe)]">VALIDATION</span>
          </div>
          <h3 class="text-xl font-bold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-status-safe)] transition-colors">Validation Status</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            What has been tested, how it was tested, and what remains untested. {valStats.totalTested} components validated, {valStats.totalNotTested} not yet tested. Honest reporting of validation boundaries.
          </p>
        </a>
      </div>
    </section>

    <!-- Secondary Tools -->
    <section class="mb-12">
      <h2 class="text-xs font-semibold tracking-[0.15em] uppercase text-[var(--color-text-faint)] mb-6">Deep Dives</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <!-- Limits -->
        <a href="/interface-risks/limits/" class="glass rounded-xl p-5 hover:border-[var(--color-accent-secondary)] border border-transparent transition-all group">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-bold font-[family-name:var(--font-mono)] px-2 py-0.5 rounded bg-[var(--color-accent-secondary)]/10 text-[var(--color-accent-secondary)]">PHYSICS</span>
          </div>
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-1 group-hover:text-[var(--color-accent-secondary)] transition-colors">BCI Limits Equation</h3>
          <p class="text-xs text-[var(--color-text-muted)]">
            {BCI_CONSTRAINTS.length} physics constraints defining the fundamental design envelope. {BCI_VALIDATION.constraintsVerified}/{BCI_VALIDATION.constraintsTotal} cross-validated.
          </p>
        </a>

        <!-- Guardrails -->
        <a href="/interface-risks/guardrails/" class="glass rounded-xl p-5 hover:border-[var(--color-accent-tertiary)] border border-transparent transition-all group">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-bold font-[family-name:var(--font-mono)] px-2 py-0.5 rounded bg-[var(--color-accent-tertiary)]/10 text-[var(--color-accent-tertiary)]">SECURITY</span>
          </div>
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-1 group-hover:text-[var(--color-accent-tertiary)] transition-colors">Security Guardrails</h3>
          <p class="text-xs text-[var(--color-text-muted)]">
            Physics-derived defense architecture. Four guardrail layers from signal integrity to post-quantum crypto.
          </p>
        </a>

        <!-- API -->
        <a href="/interface-risks/api/" class="glass rounded-xl p-5 hover:border-[var(--color-status-safe)] border border-transparent transition-all group">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs font-bold font-[family-name:var(--font-mono)] px-2 py-0.5 rounded bg-[var(--color-status-safe)]/10 text-[var(--color-status-safe)]">API</span>
          </div>
          <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-1 group-hover:text-[var(--color-status-safe)] transition-colors">BCI Data API</h3>
          <p class="text-xs text-[var(--color-text-muted)]">
            Open JSON API — {TARA_TECHNIQUES} threat techniques, {stats.totalDevices} devices, brain atlas, physics constraints. CORS-enabled, free to use.
          </p>
        </a>
      </div>
    </section>

  </div>
</PageLayout>

<style>
  a.glass:hover {
    transform: translateY(-2px);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
</style>
