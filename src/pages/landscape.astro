      </p>
    </div>
  </section>

  <script>
    const tabs = document.querySelectorAll('.sec-tab');
    const panels = document.querySelectorAll('.sec-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');

        tabs.forEach((t) => {
          const isActive = t.getAttribute('data-tab') === target;
          t.setAttribute('aria-selected', String(isActive));
          t.classList.toggle('bg-[var(--color-accent-primary)]/10', isActive);
          t.classList.toggle('text-[var(--color-accent-primary)]', isActive);
          t.classList.toggle('border-[var(--color-accent-primary)]/30', isActive);
          t.classList.toggle('text-[var(--color-text-faint)]', !isActive);
          t.classList.toggle('border-transparent', !isActive);
        });

        panels.forEach((p) => {
          p.classList.toggle('hidden', p.getAttribute('data-panel') !== target);
        });
      });
    });
  </script>

