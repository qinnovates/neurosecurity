---
import PageLayout from '../layouts/PageLayout.astro';

const breadcrumbs = [
  { label: 'Framework', href: '/security/' },
  { label: 'Neuroethics Landscape' },
];

const pillars = [
  {
    name: 'Cognitive Liberty',
    description: 'The right to mental self-determination. Freedom to alter, protect, or refuse to disclose your own mental states.',
    sources: ['Ienca & Andorno 2017', 'Farahany 2023', 'Bublitz 2013'],
    icon: 'M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
  },
  {
    name: 'Mental Privacy',
    description: 'Protection of neural data from unauthorized access, collection, or inference. Extends data privacy to brain signals.',
    sources: ['Ienca & Andorno 2017', 'Yuste et al. 2017', 'Jwa & Poldrack 2024', 'Shen & Wolf 2020'],
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
  },
  {
    name: 'Mental Integrity',
    description: 'The right to be free from unauthorized manipulation or alteration of neural processes. Protection against cognitive harm.',
    sources: ['Ienca & Andorno 2017', 'Lavazza 2023', 'Ligthart & Meynen 2023'],
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    name: 'Psychological Continuity',
    description: 'The right to maintain personal identity and sense of self. Protection against unauthorized alteration of personality, memory, or cognition.',
    sources: ['Ienca & Andorno 2017', 'Goering et al. 2021'],
    icon: 'M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3',
  },
  {
    name: 'Equal Access',
    description: 'The right to benefit equitably from neurotechnology advances. Protection against cognitive enhancement creating new forms of inequality.',
    sources: ['Yuste et al. 2017', 'Savulescu & Bostrom 2009', 'UNESCO 2025'],
    icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
  },
];

const institutions = [
  { name: 'Columbia University', lab: 'NeuroRights Foundation', leader: 'Rafael Yuste', layer: 'WHAT', contribution: 'Five neurorights, Chile legislation, Nature call-to-action', color: 'secondary' },
  { name: 'Stanford University', lab: 'Center for Law & Biosciences', leader: 'Hank Greely', layer: 'WHY', contribution: 'Neurolaw, brain data spectrum, legal scholarship', color: 'tertiary' },
  { name: 'UPenn', lab: 'Center for Neuroscience & Society', leader: 'Martha Farah', layer: 'WHY', contribution: 'Neuroethics toolbox, cosmetic neurology, neuromodesty', color: 'tertiary' },
  { name: 'Duke University', lab: 'Science & Society', leader: 'Nita Farahany', layer: 'WHAT', contribution: 'Cognitive liberty, Battle for Your Brain, incriminating thoughts', color: 'secondary' },
  { name: 'Johns Hopkins', lab: 'Berman Institute / CELLS', leader: 'Debra Mathews', layer: 'WHY', contribution: 'Three-tiered governance, device abandonment, NAM framework', color: 'tertiary' },
  { name: 'ETH Zurich', lab: 'Health Ethics & Policy Lab', leader: 'Marcello Ienca', layer: 'WHAT', contribution: 'Neurorights taxonomy, brain data governance, anti-inflationism', color: 'secondary' },
  { name: 'Oxford University', lab: 'Uehiro Centre', leader: 'Julian Savulescu', layer: 'WHY', contribution: 'Enhancement ethics, cognitive justice, philosophical foundations', color: 'tertiary' },
  { name: 'UNESCO', lab: 'International Bioethics Committee', leader: '194 Member States', layer: 'WHAT', contribution: 'First global neurotech ethics recommendation (2025)', color: 'secondary' },
  { name: 'OECD', lab: 'Neurotechnology Policy', leader: '38 Member States', layer: 'WHAT', contribution: 'Nine-principle innovation governance (2019)', color: 'secondary' },
  { name: 'WHO', lab: 'Ethics & Governance', leader: 'Global Health Body', layer: 'WHAT', contribution: 'First neurotechnology guidance document (2025)', color: 'secondary' },
  { name: 'Council of Europe', lab: 'Bioethics Committee', leader: '46 Member States', layer: 'WHAT', contribution: 'Strategic Action Plan on Neurotechnology (2025)', color: 'secondary' },
  { name: 'QIF / Qinnovate', lab: 'Open Neural Atlas', leader: 'Kevin Qi', layer: 'HOW', contribution: 'First technical security specification. NISS, TARA, Coherence Metric, NSP.', color: 'primary' },
];

const frameworks = [
  { name: 'Beauchamp & Childress (1979)', type: 'Ethics', cl: true, mp: true, mi: true, pc: false, ea: true },
  { name: 'Ienca & Andorno (2017)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Yuste et al. / Nature (2017)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'Farahany (2023)', type: 'Rights', cl: true, mp: true, mi: false, pc: false, ea: false },
  { name: 'OECD (2019)', type: 'Policy', cl: false, mp: true, mi: true, pc: false, ea: true },
  { name: 'UNESCO (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'WHO (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: false, ea: true },
  { name: 'Council of Europe (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Chile Constitution (2021)', type: 'Law', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'California SB 1223 (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'US MIND Act (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'Goering et al. (2021)', type: 'Ethics', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'Farah (2015)', type: 'Ethics', cl: false, mp: true, mi: true, pc: false, ea: false },
  { name: 'Morse (2006)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Wexler (2024)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Ienca (2021/2022)', type: 'Rigor', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Hendriks et al. (2019)', type: 'Ethics', cl: false, mp: false, mi: true, pc: false, ea: false },
  { name: 'Ligthart & Meynen (2023)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Lavazza (2023)', type: 'Rights', cl: false, mp: false, mi: true, pc: true, ea: false },
  { name: 'Andorno & Gkotsi (2022)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Savulescu & Bostrom (2009)', type: 'Ethics', cl: false, mp: false, mi: false, pc: false, ea: true },
  { name: 'Kreitmair (2019)', type: 'Ethics', cl: false, mp: true, mi: false, pc: false, ea: true },
  { name: 'QIF (2025)', type: 'HOW', cl: true, mp: true, mi: true, pc: true, ea: true },
];

const timeline = [
  { year: '1979', label: 'Beauchamp & Childress', desc: 'Four Principles of Biomedical Ethics' },
  { year: '2002', label: 'Neuroethics coined', desc: 'San Francisco conference establishes the field' },
  { year: '2006', label: 'Neuromodesty', desc: 'Morse warns against overclaiming' },
  { year: '2017', label: 'Neurorights', desc: 'Ienca & Andorno + Yuste et al. independently propose rights' },
  { year: '2019', label: 'OECD', desc: 'Nine-principle governance for neurotechnology' },
  { year: '2021', label: 'Chile', desc: 'First country to constitutionally protect neurorights' },
  { year: '2024', label: 'California', desc: 'Neural data added to CCPA' },
  { year: '2025', label: 'UNESCO + WHO', desc: 'First global normative frameworks' },
  { year: '2025', label: 'QIF', desc: 'First technical security specification' },
];
---

<PageLayout
  title="The Neuroethics Landscape — 23 Frameworks, 1 Gap"
  description="A comprehensive survey of neuroethics frameworks, institutions, and the Principles-to-Protocol Gap that QIF fills."
  breadcrumbs={breadcrumbs}
  wide
>

  <!-- ═══ HERO ═══ -->
  <section class="py-12 md:py-20">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <p class="text-xs font-medium tracking-[0.2em] uppercase mb-4 text-[var(--color-text-faint)]">
        Neuroethics Survey
      </p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-[family-name:var(--font-heading)] tracking-tight mb-6 leading-[1.15]">
        <span class="text-[var(--color-text-primary)]">23 Frameworks.</span>
        <br />
        <span class="bg-gradient-to-r from-[var(--color-accent-primary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">
          One Gap.
        </span>
      </h1>
      <p class="text-base sm:text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed">
        46 years of neuroethics scholarship have converged on five universal principles.
        Every framework answers <strong class="text-[var(--color-text-primary)]">why</strong> we should protect neural rights
        or <strong class="text-[var(--color-text-primary)]">what</strong> those rights are.
        None answer <strong class="text-[var(--color-text-primary)]">how</strong> to enforce them technically.
      </p>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="py-12 md:py-16" id="timeline">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Timeline
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-4 sm:left-6 top-0 bottom-0 w-px bg-gradient-to-b from-[var(--color-accent-tertiary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-primary)]"></div>

        <div class="flex flex-col gap-6">
          {timeline.map((t, i) => (
            <div class="flex items-start gap-4 sm:gap-6 pl-2">
              <div class={`shrink-0 w-5 h-5 rounded-full border-2 mt-1 ${i === timeline.length - 1 ? 'bg-[var(--color-accent-primary)] border-[var(--color-accent-primary)]' : 'bg-[var(--color-bg-surface)] border-[var(--color-accent-secondary)]'}`}></div>
              <div>
                <span class="text-xs font-bold tracking-[0.1em] uppercase text-[var(--color-accent-secondary)]">{t.year}</span>
                <h3 class="text-sm font-bold text-[var(--color-text-primary)]">{t.label}</h3>
                <p class="text-xs text-[var(--color-text-muted)]">{t.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FIVE PILLARS ═══ -->
  <section class="py-12 md:py-16" id="pillars">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Five Universal Pillars
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <p class="text-sm text-[var(--color-text-muted)] max-w-2xl mx-auto text-center mb-8">
      Despite different terminology, legal traditions, and institutional mandates, every major neuroethics framework
      converges on these five themes.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
      {pillars.map((p) => (
        <div class="glass rounded-xl p-5 border border-[var(--color-border)]">
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-5 h-5 text-[var(--color-accent-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={p.icon} />
            </svg>
            <h3 class="text-sm font-bold text-[var(--color-text-primary)]">{p.name}</h3>
          </div>
          <p class="text-xs text-[var(--color-text-muted)] leading-relaxed mb-3">{p.description}</p>
          <div class="flex flex-wrap gap-1">
            {p.sources.map((s) => (
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-accent-secondary)]/10 text-[var(--color-accent-secondary)]">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ INSTITUTION MAP ═══ -->
  <section class="py-12 md:py-16" id="institutions">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Who Built the Field
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <p class="text-sm text-[var(--color-text-muted)] max-w-2xl mx-auto text-center mb-4">
      Each institution contributes at a specific layer.
    </p>

    <div class="flex items-center justify-center gap-4 mb-8 text-[10px]">
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent-tertiary)]"></span>
        <span class="text-[var(--color-text-muted)]">WHY (Principles)</span>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent-secondary)]"></span>
        <span class="text-[var(--color-text-muted)]">WHAT (Rights)</span>
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent-primary)]"></span>
        <span class="text-[var(--color-text-muted)]">HOW (Protocol)</span>
      </span>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 max-w-6xl mx-auto">
      {institutions.map((inst) => {
        const borderColor = inst.color === 'primary' ? 'var(--color-accent-primary)' : inst.color === 'secondary' ? 'var(--color-accent-secondary)' : 'var(--color-accent-tertiary)';
        const bgColor = inst.color === 'primary' ? 'rgba(37,99,235,0.04)' : inst.color === 'secondary' ? 'rgba(8,145,178,0.04)' : 'rgba(124,58,237,0.04)';
        return (
          <div class="rounded-xl p-4 border" style={`border-color: ${borderColor}30; background: ${bgColor};`}>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-[10px] font-bold tracking-[0.1em] uppercase px-1.5 py-0.5 rounded" style={`color: ${borderColor}; background: ${borderColor}15;`}>{inst.layer}</span>
              <h3 class="text-xs font-bold text-[var(--color-text-primary)]">{inst.name}</h3>
            </div>
            <p class="text-[10px] text-[var(--color-text-faint)] mb-1">{inst.lab} &middot; {inst.leader}</p>
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">{inst.contribution}</p>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ═══ FRAMEWORK COMPARISON ═══ -->
  <section class="py-12 md:py-16" id="comparison">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Framework Comparison
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="glass rounded-2xl p-4 sm:p-6 max-w-6xl mx-auto overflow-x-auto">
      <table class="w-full text-xs min-w-[600px]">
        <thead>
          <tr class="border-b border-[var(--color-border)]">
            <th class="text-left py-2 pr-3 text-[var(--color-text-primary)] font-semibold">Framework</th>
            <th class="text-center py-2 px-2 text-[var(--color-text-faint)] font-semibold">Type</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">CL</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">MP</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">MI</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">PC</th>
            <th class="text-center py-2 px-2 text-[var(--color-accent-secondary)] font-semibold">EA</th>
          </tr>
        </thead>
        <tbody class="text-[var(--color-text-muted)]">
          {frameworks.map((f) => (
            <tr class={`border-b border-[var(--color-border)]/30 ${f.type === 'HOW' ? 'bg-[var(--color-accent-primary)]/5 font-medium' : ''}`}>
              <td class="py-2 pr-3 text-[var(--color-text-primary)]">{f.name}</td>
              <td class="text-center py-2 px-2">
                <span class={`text-[10px] px-1.5 py-0.5 rounded-full ${
                  f.type === 'HOW' ? 'bg-[var(--color-accent-primary)]/15 text-[var(--color-accent-primary)]' :
                  f.type === 'Law' ? 'bg-[var(--color-status-warn)]/15 text-[var(--color-status-warn)]' :
                  f.type === 'Policy' ? 'bg-[var(--color-accent-secondary)]/15 text-[var(--color-accent-secondary)]' :
                  f.type === 'Rigor' ? 'bg-[var(--color-text-faint)]/15 text-[var(--color-text-faint)]' :
                  'bg-[var(--color-accent-tertiary)]/15 text-[var(--color-accent-tertiary)]'
                }`}>{f.type}</span>
              </td>
              <td class="text-center py-2 px-2">{f.cl ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.mp ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.mi ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.pc ? '\u2713' : ''}</td>
              <td class="text-center py-2 px-2">{f.ea ? '\u2713' : ''}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="mt-4 pt-3 border-t border-[var(--color-border)]/50 text-[10px] text-[var(--color-text-faint)]">
        CL = Cognitive Liberty &middot; MP = Mental Privacy &middot; MI = Mental Integrity &middot; PC = Psychological Continuity &middot; EA = Equal Access
      </div>
    </div>
  </section>

  <!-- ═══ THE GAP ═══ -->
  <section class="py-12 md:py-16" id="gap">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        The Principles-to-Protocol Gap
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="rounded-2xl p-6 sm:p-8 border border-[var(--color-status-warn)]/30" style="background: rgba(245,158,11,0.04);">
        <h3 class="text-base font-bold text-[var(--color-text-primary)] mb-3">
          The fire code problem
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
          Imagine if fire safety consisted only of the principle "buildings should not burn down" and the right
          "people deserve safe buildings" &mdash; but no one had written fire codes, designed sprinkler systems,
          or specified fire-resistant materials. That is the current state of neuroethics.
        </p>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
          23 frameworks define <strong class="text-[var(--color-text-primary)]">why</strong> neural rights matter and
          <strong class="text-[var(--color-text-primary)]">what</strong> those rights are.
          Zero provide <strong class="text-[var(--color-text-primary)]">how</strong> to enforce them technically:
          no threat models, no scoring systems, no detection mechanisms, no protocol specifications.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-4">
          <div class="text-center p-3 rounded-lg bg-[var(--color-accent-tertiary)]/5 border border-[var(--color-accent-tertiary)]/20">
            <p class="text-2xl font-bold text-[var(--color-accent-tertiary)]">22</p>
            <p class="text-[10px] text-[var(--color-text-faint)] uppercase tracking-wider">WHY / WHAT</p>
          </div>
          <div class="text-center p-3 rounded-lg bg-[var(--color-text-faint)]/5 border border-[var(--color-text-faint)]/20">
            <p class="text-2xl font-bold text-[var(--color-text-faint)]">0</p>
            <p class="text-[10px] text-[var(--color-text-faint)] uppercase tracking-wider">HOW (before QIF)</p>
          </div>
          <div class="text-center p-3 rounded-lg bg-[var(--color-accent-primary)]/5 border border-[var(--color-accent-primary)]/20">
            <p class="text-2xl font-bold text-[var(--color-accent-primary)]">1</p>
            <p class="text-[10px] text-[var(--color-text-faint)] uppercase tracking-wider">HOW (QIF)</p>
          </div>
        </div>

        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
          QIF fills this gap with: <strong class="text-[var(--color-text-primary)]">NISS</strong> (neural impact scoring),
          the <strong class="text-[var(--color-text-primary)]">TARA Atlas</strong> (109 threat techniques),
          the <strong class="text-[var(--color-text-primary)]">Coherence Metric</strong> (signal provenance verification),
          and <strong class="text-[var(--color-text-primary)]">NSP</strong> (post-quantum secure neural communication).
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ NEUROSECURITY ═══ -->
  <section class="py-12 md:py-16" id="neurosecurity">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        From Neuroethics to Neurosecurity
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="max-w-3xl mx-auto mb-8">
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
        Neuroethics asks: <em>what rights should people have over their own neural data and cognitive processes?</em>
        Neurosecurity asks: <em>how do we technically enforce those rights against real attack vectors?</em>
        One is philosophy. The other is engineering. Both are incomplete without the other.
      </p>
      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
        Every neurorights violation maps to a concrete technical attack pattern. Mental Privacy is violated by eavesdropping.
        Mental Integrity is violated by signal injection. Cognitive Liberty is violated by subliminal manipulation.
        Neurosecurity is the discipline that builds the defenses — threat models, scoring systems, detection engines,
        and cryptographic protocols — that turn rights on paper into protections in hardware.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-4xl mx-auto mb-8">
      <div class="glass rounded-xl p-5 border border-[var(--color-border)]">
        <h3 class="text-xs font-bold tracking-[0.1em] uppercase text-[var(--color-accent-tertiary)] mb-3">Neuroethics</h3>
        <ul class="space-y-2 text-xs text-[var(--color-text-muted)]">
          <li>Defines the <strong class="text-[var(--color-text-primary)]">rights</strong> (Ienca & Andorno, Yuste, Farahany)</li>
          <li>Establishes <strong class="text-[var(--color-text-primary)]">consent models</strong> (Beauchamp & Childress)</li>
          <li>Writes <strong class="text-[var(--color-text-primary)]">policy</strong> (UNESCO, OECD, WHO, Chile)</li>
          <li>Asks who should be protected and why</li>
        </ul>
      </div>
      <div class="glass rounded-xl p-5 border border-[var(--color-accent-primary)]/30" style="background: rgba(37,99,235,0.04);">
        <h3 class="text-xs font-bold tracking-[0.1em] uppercase text-[var(--color-accent-primary)] mb-3">Neurosecurity</h3>
        <ul class="space-y-2 text-xs text-[var(--color-text-muted)]">
          <li>Catalogs the <strong class="text-[var(--color-text-primary)]">attacks</strong> (<a href="/TARA/" class="text-[var(--color-accent-primary)] hover:underline">109 TARA techniques</a>)</li>
          <li>Scores the <strong class="text-[var(--color-text-primary)]">impact</strong> (<a href="/scoring/" class="text-[var(--color-accent-primary)] hover:underline">NISS vulnerability scoring</a>)</li>
          <li>Builds the <strong class="text-[var(--color-text-primary)]">defenses</strong> (<a href="/tools/" class="text-[var(--color-accent-primary)] hover:underline">Neurowall, NSP, Runemate</a>)</li>
          <li>Answers how to detect, prevent, and respond technically</li>
        </ul>
      </div>
    </div>

    <!-- How each right maps to security -->
    <div class="max-w-4xl mx-auto">
      <h3 class="text-xs font-bold tracking-[0.1em] uppercase text-[var(--color-text-faint)] mb-4 text-center">
        Rights &rarr; Threats &rarr; Defenses
      </h3>
      <div class="glass rounded-xl overflow-hidden">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-[var(--color-border)]">
              <th class="text-left py-3 px-4 text-[var(--color-accent-secondary)] font-semibold">Neuroright</th>
