---
import PageLayout from '../layouts/PageLayout.astro';

const breadcrumbs = [
  { label: 'Framework', href: '/security/' },
  { label: 'Neuroethics Landscape' },
];

const pillars = [
  {
    name: 'Cognitive Liberty',
    description: 'The right to mental self-determination. Freedom to alter, protect, or refuse to disclose your own mental states.',
    sources: ['Ienca & Andorno 2017', 'Farahany 2023', 'Bublitz 2013'],
    icon: 'M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18',
  },
  {
    name: 'Mental Privacy',
    description: 'Protection of neural data from unauthorized access, collection, or inference. Extends data privacy to brain signals.',
    sources: ['Ienca & Andorno 2017', 'Yuste et al. 2017', 'Jwa & Poldrack 2024', 'Shen & Wolf 2020'],
    icon: 'M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z',
  },
  {
    name: 'Mental Integrity',
    description: 'The right to be free from unauthorized manipulation or alteration of neural processes. Protection against cognitive harm.',
    sources: ['Ienca & Andorno 2017', 'Lavazza 2023', 'Ligthart & Meynen 2023'],
    icon: 'M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z',
  },
  {
    name: 'Psychological Continuity',
    description: 'The right to maintain personal identity and sense of self. Protection against unauthorized alteration of personality, memory, or cognition.',
    sources: ['Ienca & Andorno 2017', 'Goering et al. 2021'],
    icon: 'M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3',
  },
  {
    name: 'Equal Access',
    description: 'The right to benefit equitably from neurotechnology advances. Protection against cognitive enhancement creating new forms of inequality.',
    sources: ['Yuste et al. 2017', 'Savulescu & Bostrom 2009', 'UNESCO 2025'],
    icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z',
  },
];

const institutions = [
  { name: 'Columbia University', lab: 'NeuroRights Foundation', leader: 'Rafael Yuste', layer: 'WHAT', contribution: 'Five neurorights, Chile legislation, Nature call-to-action', color: 'secondary' },
  { name: 'Stanford University', lab: 'Center for Law & Biosciences', leader: 'Hank Greely', layer: 'WHY', contribution: 'Neurolaw, brain data spectrum, legal scholarship', color: 'tertiary' },
  { name: 'UPenn', lab: 'Center for Neuroscience & Society', leader: 'Martha Farah', layer: 'WHY', contribution: 'Neuroethics toolbox, cosmetic neurology, neuromodesty', color: 'tertiary' },
  { name: 'Duke University', lab: 'Science & Society', leader: 'Nita Farahany', layer: 'WHAT', contribution: 'Cognitive liberty, Battle for Your Brain, incriminating thoughts', color: 'secondary' },
  { name: 'Johns Hopkins', lab: 'Berman Institute / CELLS', leader: 'Debra Mathews', layer: 'WHY', contribution: 'Three-tiered governance, device abandonment, NAM framework', color: 'tertiary' },
  { name: 'ETH Zurich', lab: 'Health Ethics & Policy Lab', leader: 'Marcello Ienca', layer: 'WHAT', contribution: 'Neurorights taxonomy, brain data governance, anti-inflationism', color: 'secondary' },
  { name: 'Oxford University', lab: 'Uehiro Centre', leader: 'Julian Savulescu', layer: 'WHY', contribution: 'Enhancement ethics, cognitive justice, philosophical foundations', color: 'tertiary' },
  { name: 'UNESCO', lab: 'International Bioethics Committee', leader: '194 Member States', layer: 'WHAT', contribution: 'First global neurotech ethics recommendation (2025)', color: 'secondary' },
  { name: 'OECD', lab: 'Neurotechnology Policy', leader: '38 Member States', layer: 'WHAT', contribution: 'Nine-principle innovation governance (2019)', color: 'secondary' },
  { name: 'WHO', lab: 'Ethics & Governance', leader: 'Global Health Body', layer: 'WHAT', contribution: 'First neurotechnology guidance document (2025)', color: 'secondary' },
  { name: 'Council of Europe', lab: 'Bioethics Committee', leader: '46 Member States', layer: 'WHAT', contribution: 'Strategic Action Plan on Neurotechnology (2025)', color: 'secondary' },
  { name: 'Int\'l Neuroethics Society', lab: 'Professional Society', leader: 'Founded 2006', layer: 'WHY', contribution: 'First professional society for neuroethics. Founded at Asilomar by Gazzaniga, Farah, Illes, Wolpe', color: 'tertiary' },
  { name: 'NeuroRights Foundation', lab: 'Columbia University', leader: 'Rafael Yuste', layer: 'WHAT', contribution: 'Policy vehicle driving Chile, California, Colorado legislation. 2025 consumer neurotech data audit', color: 'secondary' },
  { name: 'QIF / Qinnovate', lab: 'Open Neural Atlas', leader: 'Kevin Qi', layer: 'HOW', contribution: 'First technical security specification. NISS, TARA, Coherence Metric, NSP.', color: 'primary' },
];

const frameworks = [
  { name: 'Beauchamp & Childress (1979)', type: 'Ethics', cl: true, mp: true, mi: true, pc: false, ea: true },
  { name: 'Ienca & Andorno (2017)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Yuste et al. / Nature (2017)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'Farahany (2023)', type: 'Rights', cl: true, mp: true, mi: false, pc: false, ea: false },
  { name: 'OECD (2019)', type: 'Policy', cl: false, mp: true, mi: true, pc: false, ea: true },
  { name: 'UNESCO (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'WHO (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: false, ea: true },
  { name: 'Council of Europe (2025)', type: 'Policy', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Chile Constitution (2021)', type: 'Law', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Colorado HB 1058 (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'California SB 1223 (2024)', type: 'Law', cl: false, mp: true, mi: false, pc: false, ea: false },
  { name: 'EU AI Act (2024)', type: 'Law', cl: false, mp: true, mi: true, pc: false, ea: false },
  { name: 'Goering et al. (2021)', type: 'Ethics', cl: true, mp: true, mi: true, pc: true, ea: true },
  { name: 'Farah (2015)', type: 'Ethics', cl: false, mp: true, mi: true, pc: false, ea: false },
  { name: 'Morse (2006)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Wexler (2024)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Ienca (2021/2022)', type: 'Rigor', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Hendriks et al. (2019)', type: 'Ethics', cl: false, mp: false, mi: true, pc: false, ea: false },
  { name: 'Ligthart & Meynen (2023)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Lavazza (2023)', type: 'Rights', cl: false, mp: false, mi: true, pc: true, ea: false },
  { name: 'Andorno & Gkotsi (2022)', type: 'Rights', cl: true, mp: true, mi: true, pc: true, ea: false },
  { name: 'Savulescu & Bostrom (2009)', type: 'Ethics', cl: false, mp: false, mi: false, pc: false, ea: true },
  { name: 'Kreitmair (2019)', type: 'Ethics', cl: false, mp: true, mi: false, pc: false, ea: true },
  { name: 'Kellmeyer (2022)', type: 'Rights', cl: false, mp: true, mi: true, pc: false, ea: false },
  { name: 'Bublitz (2022)', type: 'Rigor', cl: true, mp: true, mi: true, pc: false, ea: false },
  { name: 'Racine, Illes (2005)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Poldrack (2006)', type: 'Rigor', cl: false, mp: false, mi: false, pc: false, ea: false },
  { name: 'Tennison & Moreno (2012)', type: 'Rigor', cl: true, mp: true, mi: true, pc: false, ea: false },
  { name: 'QIF (in development)', type: 'HOW', cl: true, mp: true, mi: true, pc: true, ea: true },
];

const securityResearchers = [
  { name: 'Tadayoshi Kohno', affiliation: 'University of Washington', contribution: 'Co-coined "neurosecurity" (2009). Foundational threat model for implantable neural devices.', paper: 'Denning, Matsuoka & Kohno, Neurosurgical Focus 27(1):E7' },
  { name: 'Tamara Denning', affiliation: 'University of Washington', contribution: 'Lead author on the first neurosecurity paper. Defined attack surfaces for implantable BMIs.', paper: 'Denning et al. 2009' },
  { name: 'Ivan Martinovic', affiliation: 'University of Oxford', contribution: 'First empirical BCI side-channel attack. Demonstrated P300-based extraction of PINs and locations from consumer EEG headsets.', paper: 'Martinovic et al., USENIX Security 2012' },
  { name: 'Dawn Song', affiliation: 'UC Berkeley', contribution: 'Co-authored the landmark BCI side-channel paper. MacArthur Fellow, one of the most-cited researchers in computer security.', paper: 'Martinovic, Frank, Song et al., USENIX Security 2012' },
  { name: 'Laurie Pycroft', affiliation: 'University of Oxford', contribution: 'Coined and systematized "brainjacking" — the first comprehensive threat model for implanted neurostimulators.', paper: 'Pycroft et al., World Neurosurgery 92:454-462, 2016' },
  { name: 'Tamara Bonaci', affiliation: 'Northeastern / UW', contribution: 'BCI game attack vectors. Showed subliminal stimuli can extract private information during BCI use.', paper: 'Bonaci et al. 2014' },
  { name: 'Howard Chizeck', affiliation: 'University of Washington', contribution: 'Neural engineering security. BCI privacy through signal obfuscation and access control.', paper: 'Chizeck & Bonaci 2014' },
  { name: 'Kevin Fu', affiliation: 'Northeastern University', contribution: 'Medical device cybersecurity pioneer. Former FDA Acting Director of Medical Device Cybersecurity. $3.5M NSF grant for neural implant security.', paper: 'Archimedes Center for Medical Device Security' },
  { name: 'Nitesh Saxena', affiliation: 'Texas A&M University', contribution: 'BCI authentication protocols. P300 brainwave attacks and neural biometric spoofing.', paper: 'Saxena et al. 2017' },
  { name: 'Marcello Ienca', affiliation: 'TU Munich / ETH Zurich', contribution: 'Brain data governance at the security-ethics intersection. Neurorights taxonomy and anti-inflationism.', paper: 'Ienca & Andorno 2017; Ienca & Haselager, ACM Computing Surveys 2021' },
  { name: 'Sergio Lopez Bernal', affiliation: 'University of Murcia', contribution: 'BCI cybersecurity survey and neural cyberattack taxonomy. "Eight Reasons" paper on why BCIs are not secure.', paper: 'Lopez Bernal et al., CACM 2023' },
  { name: 'Tyler Schroder', affiliation: 'Yale Digital Ethics Center', contribution: 'Most comprehensive 2025 BCI cyber risk assessment. Measures for safeguarding brain implants.', paper: 'Schroder et al., Neuroethics (Springer) 2025' },
  { name: 'Qiben Yan', affiliation: 'Michigan State University', contribution: 'Neural signal injection attacks. Electromagnetic interference on implantable stimulators.', paper: 'Yan et al. 2020' },
];

const securityInstitutions = [
  { name: 'University of Washington', lab: 'Security & Privacy Research Lab', focus: 'Founded the neurosecurity field (2009). Implantable device threat modeling, BCI game attacks, neural signal privacy.', leaders: 'Kohno, Chizeck, Bonaci, Denning, Goering' },
  { name: 'University of Oxford', lab: 'Functional Neurosurgery + InfoSec', focus: 'Brainjacking threat models for implanted DBS devices (Pycroft 2016). EEG side-channel attacks on consumer BCIs (Martinovic 2012).', leaders: 'Pycroft, Martinovic, Aziz' },
  { name: 'Northeastern University', lab: 'Archimedes Center for Medical Device Security', focus: 'Medical device cybersecurity pioneer. $22M total research. Neural implant security under $3.5M NSF grant. Kevin Fu served as FDA Acting Director of Medical Device Cybersecurity.', leaders: 'Fu, Bonaci' },
  { name: 'Yale University', lab: 'Digital Ethics Center', focus: 'Most comprehensive BCI cyber risk assessment (2025). Interdisciplinary approach bridging cybersecurity and neuroethics.', leaders: 'Floridi, Schroder' },
  { name: 'UC Berkeley', lab: 'Computer Security Research', focus: 'Co-produced the first empirical BCI side-channel attack paper (USENIX 2012). Dawn Song is a MacArthur Fellow.', leaders: 'Song' },
  { name: 'TU Munich / ETH Zurich', lab: 'Ethics of AI and Neuroscience', focus: 'Brain data governance, neurorights and security intersection, state-of-the-art BCI security survey (ACM 2021).', leaders: 'Ienca, Haselager' },
  { name: 'University of Murcia', lab: 'BCI Cybersecurity Group', focus: 'Neural cyberattack taxonomy, "Eight Reasons" BCI insecurity paper (CACM 2023). Highest-volume BCI security publication group.', leaders: 'Lopez Bernal, Celdran, Perez' },
  { name: 'Graz University of Technology', lab: 'Institute of Neural Engineering', focus: 'BCI conference venue and neural engineering research. EEG-based authentication and biosignal processing.', leaders: 'Muller-Putz' },
  { name: 'Michigan State University', lab: 'SEIT Lab', focus: 'Electromagnetic injection attacks on neural implants, sensor security.', leaders: 'Yan' },
  { name: 'Texas A&M University', lab: 'SPIES Lab / Global Cyber Research Institute', focus: 'BCI authentication, neural biometric security, brainwave spoofing, EEG disease inference.', leaders: 'Saxena' },
  { name: 'Brown University', lab: 'BrainGate Consortium', focus: 'Intracortical BCI clinical trials. Security-relevant: first long-term human implant data on failure modes.', leaders: 'Hochberg, Donoghue' },
];

const standardsBodies = [
  { name: 'IEEE', scope: 'BMI Standards Roadmap', contribution: 'Identified BCI-specific security standards as an open standardization gap. IEEE 2794 (brain data).', status: 'Active' },
  { name: 'NIST', scope: 'Cybersecurity Framework', contribution: 'CSF 2.0 provides the security control baseline. No neurotech-specific profile exists yet.', status: 'Gap' },
  { name: 'FDA', scope: 'Premarket Cybersecurity Guidance', contribution: 'Requires threat modeling for connected medical devices. No neural-specific requirements.', status: 'Partial' },
  { name: 'ISO/IEC', scope: 'Medical Device Security', contribution: 'ISO 14708 (implants), IEC 62443 (industrial security). No BCI-specific standard exists.', status: 'Gap' },
  { name: 'MITRE', scope: 'ATT&CK / CWE / CVE', contribution: 'Attack taxonomy and vulnerability classification. No neural device attack techniques catalogued.', status: 'Gap' },
  { name: 'CISA', scope: 'Medical Device Advisories', contribution: 'Issues advisories for connected device vulnerabilities. Has not addressed neural implants.', status: 'Gap' },
  { name: 'UNESCO', scope: 'Neurotech Ethics Recommendation', contribution: 'First global normative framework (2025). Ethics-focused, no technical security requirements.', status: 'Active' },
  { name: 'OECD', scope: 'Responsible Innovation', contribution: 'Nine-principle governance framework (2019). Policy layer, no technical specification.', status: 'Active' },
  { name: 'WHO', scope: 'Neurotechnology Guidance', contribution: 'First global health guidance on neurotech (2025). Safety-focused, no security specification.', status: 'Active' },
  { name: 'Council of Europe', scope: 'Strategic Action Plan', contribution: 'Neurotechnology action plan (2025). Human rights approach, 46 member states.', status: 'Active' },
  { name: 'Chile CNPT', scope: 'Neurotechnology Commission', contribution: 'First national neurotech regulatory body. Implements constitutional neurorights (2021).', status: 'Active' },
  { name: 'EU AI Act', scope: 'High-Risk AI Classification', contribution: 'Classifies certain neurotech as high-risk AI systems (Regulation 2024/1689). Full application August 2026.', status: 'Active' },
  { name: 'Global Privacy Assembly', scope: 'Neural Data Resolution', contribution: '46th Conference (2024) adopted resolution on principles for neural data processing and cognitive freedom.', status: 'Active' },
  { name: 'FIRST / CVSS SIG', scope: 'Vulnerability Scoring', contribution: 'CVSS 4.0 scores IT vulnerabilities. No neural impact metrics exist in the standard.', status: 'Gap' },
];

const timeline = [
  { year: '1927', label: 'Fritz Jahr coins "Bio-Ethik"', desc: 'First use of the term in Kosmos journal, proposing a bioethical imperative extending moral consideration to all living things' },
  { year: '1947', label: 'Nuremberg Code', desc: 'First international ethics code for human experimentation, born from the Doctors\' Trial' },
  { year: '1964', label: 'Declaration of Helsinki', desc: 'World Medical Association establishes ethical principles for medical research on humans' },
  { year: '1970', label: 'Potter revives "Bioethics"', desc: 'Van Rensselaer Potter publishes "Bioethics: The Science of Survival" in Perspectives in Biology and Medicine' },
  { year: '1974', label: 'National Research Act', desc: 'U.S. Congress creates the National Commission for the Protection of Human Subjects in response to the Tuskegee study' },
  { year: '1979', label: 'Belmont Report', desc: 'Three core principles for human subjects research: respect for persons, beneficence, justice' },
  { year: '1979', label: 'Beauchamp & Childress', desc: 'Principles of Biomedical Ethics: autonomy, beneficence, non-maleficence, justice' },
  { year: '2002', label: '"Neuroethics" defined', desc: 'William Safire\'s keynote at the Dana Foundation conference establishes the modern field (Pontius used "neuro-ethics" in 1973 in a narrower clinical context)' },
  { year: '2006', label: 'Brain Overclaim Syndrome', desc: 'Stephen Morse warns neuroscience claims are routinely overclaimed when applied to law (Ohio State J. Criminal Law). "Neuromodesty" follows in 2011' },
  { year: '2006', label: 'Int\'l Neuroethics Society', desc: 'Founded at Asilomar by Gazzaniga, Farah, Illes, and Wolpe — first professional society for the discipline' },
  { year: '2009', label: '"Neurosecurity" coined', desc: 'Denning, Matsuoka & Kohno define security for neural devices (Neurosurgical Focus 27(1):E7)' },
  { year: '2012', label: 'First BCI side-channel attack', desc: 'Martinovic et al. (USENIX Security) demonstrate consumer EEG headsets can extract PINs and locations via P300 response' },
  { year: '2016', label: '"Brainjacking" defined', desc: 'Pycroft et al. (Oxford) systematize threats to implanted neurostimulators (World Neurosurgery 92:454-462)' },
  { year: '2017', label: 'Neurorights', desc: 'Ienca & Andorno (Life Sciences Society and Policy) and Yuste et al. (Nature) independently propose neurorights' },
  { year: '2019', label: 'OECD', desc: 'Nine-principle governance for responsible innovation in neurotechnology (Recommendation #457)' },
  { year: '2021', label: 'Chile', desc: 'First country to constitutionally protect neurorights (mental integrity)' },
  { year: '2024', label: 'Colorado + California', desc: 'Colorado HB 1058 (first U.S. neural data law, April) and California SB 1223 (neural data added to CCPA, September)' },
  { year: '2025', label: 'UNESCO', desc: 'First global normative framework on neurotechnology ethics, adopted by 194 member states' },
  { year: 'Next', label: 'QIF', desc: 'First open technical security specification (in development)' },
];
---

<PageLayout
  title="The Neuroethics Landscape — 28 Frameworks, 1 Gap"
  description="A comprehensive survey of neuroethics frameworks, institutions, and the Principles-to-Protocol Gap that QIF fills."
  breadcrumbs={breadcrumbs}
  wide
>

  <!-- ═══ HERO ═══ -->
  <section class="py-12 md:py-20">
    <div class="text-center max-w-3xl mx-auto mb-12">
      <p class="text-xs font-medium tracking-[0.2em] uppercase mb-4 text-[var(--color-text-faint)]">
        Neuroethics Survey
      </p>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold font-[family-name:var(--font-heading)] tracking-tight mb-6 leading-[1.15]">
        <span class="text-[var(--color-text-primary)]">28 Frameworks.</span>
        <br />
        <span class="bg-gradient-to-r from-[var(--color-accent-primary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">
          One Gap.
        </span>
      </h1>
      <p class="text-base sm:text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed">
        Nearly a century of bioethics and neuroethics scholarship have converged on five universal principles.
        Every framework answers <strong class="text-[var(--color-text-primary)]">why</strong> we should protect neural rights
        or <strong class="text-[var(--color-text-primary)]">what</strong> those rights are.
        None answer <strong class="text-[var(--color-text-primary)]">how</strong> to enforce them technically.
      </p>
    </div>
  </section>

  <!-- ═══ TIMELINE ═══ -->
  <section class="py-12 md:py-16" id="timeline">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Timeline
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-4 sm:left-6 top-0 bottom-0 w-px bg-gradient-to-b from-[var(--color-accent-tertiary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-primary)]"></div>

        <div class="flex flex-col gap-6">
          {timeline.map((t, i) => (
            <div class="flex items-start gap-4 sm:gap-6 pl-2">
              <div class={`shrink-0 w-5 h-5 rounded-full border-2 mt-1 ${i === timeline.length - 1 ? 'bg-[var(--color-accent-primary)] border-[var(--color-accent-primary)]' : 'bg-[var(--color-bg-surface)] border-[var(--color-accent-secondary)]'}`}></div>
              <div>
                <span class="text-xs font-bold tracking-[0.1em] uppercase text-[var(--color-accent-secondary)]">{t.year}</span>
                <h3 class="text-sm font-bold text-[var(--color-text-primary)]">{t.label}</h3>
                <p class="text-xs text-[var(--color-text-muted)]">{t.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FIVE PILLARS ═══ -->
  <section class="py-12 md:py-16" id="pillars">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
      <h2 class="text-lg sm:text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] whitespace-nowrap">
        Five Universal Pillars
      </h2>
      <div class="h-px flex-1 bg-[var(--color-border)]"></div>
    </div>

    <p class="text-sm text-[var(--color-text-muted)] max-w-2xl mx-auto text-center mb-8">
      Despite different terminology, legal traditions, and institutional mandates, every major neuroethics framework
      converges on these five themes.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto">
      {pillars.map((p) => (
        <div class="glass rounded-xl p-5 border border-[var(--color-border)]">
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-5 h-5 text-[var(--color-accent-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={p.icon} />
            </svg>
            <h3 class="text-sm font-bold text-[var(--color-text-primary)]">{p.name}</h3>
          </div>
          <p class="text-xs text-[var(--color-text-muted)] leading-relaxed mb-3">{p.description}</p>
          <div class="flex flex-wrap gap-1">
            {p.sources.map((s) => (
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-accent-secondary)]/10 text-[var(--color-accent-secondary)]">{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ INSTITUTION MAP ═══ -->
