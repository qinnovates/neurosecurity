---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
  title="Open Neural Atlas — Live Neural Monitoring Platform"
  description="Connect BCI devices, stream live EEG, analyze frequency spectra, and test TARA attack techniques — all in the browser."
  breadcrumbs={[{ label: 'Atlas', href: '/atlas/' }, { label: 'Open Neural Atlas' }]}
>
  <main class="mx-auto max-w-4xl px-4 py-8">
    <!-- Hero -->
    <div class="mb-10">
      <p class="text-xs font-mono tracking-[0.15em] uppercase mb-3" style="color: #22d3ee;">Live Platform</p>
      <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-heading)] mb-3" style="color: var(--color-text-primary);">
        Open Neural Atlas
      </h1>
      <p class="text-base max-w-2xl" style="color: var(--color-text-muted);">
        A next-gen neural monitoring platform by Qinnovate. Connect a brain-computer interface (or use synthetic data),
        stream live EEG, analyze frequency bands, test security defenses with the TARA Scanner, and explore
        the full BrainFlow API — all in the browser.
      </p>
    </div>

    <!-- Module Grid -->
    <div class="grid sm:grid-cols-2 gap-4 mb-10">
      {[
        {
          title: 'Signal Monitor',
          description: 'Watch live brain signals from all channels in real time — like a heart monitor for the brain.',
          color: '#10b981',
        },
        {
          title: 'Spectrum Analyzer',
          description: 'Break down signals into Delta, Theta, Alpha, Beta, and Gamma bands. Includes experimental DSM pattern analysis.',
          color: '#a855f7',
        },
        {
          title: 'TARA Scanner',
          description: 'Penetration testing for BCI — scan, replay, and compare 13 attack techniques across 6 categories.',
          color: '#f59e0b',
        },
        {
          title: 'Alert Center',
          description: 'Every anomaly detection event with timestamps, severity levels, and channel identification.',
          color: '#ef4444',
        },
        {
          title: 'NeuroSIM',
          description: 'BrainFlow integration hub — connect 40+ devices, explore the API, load sample datasets.',
          color: '#22d3ee',
        },
        {
          title: 'Integrations',
          description: 'Connect to APIs, data feeds, and the QIF knowledge base with KQL.',
          color: '#6366f1',
        },
      ].map((mod) => (
        <div class="glass rounded-xl p-5" style={`border-left: 3px solid ${mod.color};`}>
          <h3 class="text-sm font-bold mb-1" style={`color: ${mod.color};`}>{mod.title}</h3>
          <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">{mod.description}</p>
        </div>
      ))}
    </div>

    <!-- Sample Data -->
    <div class="glass rounded-xl p-6 mb-10">
      <h2 class="text-lg font-bold mb-2" style="color: var(--color-text-primary);">10 Sample EEG Datasets Included</h2>
      <p class="text-sm mb-4" style="color: var(--color-text-muted);">
        Synthetic datasets generated from known EEG patterns — no hardware needed. 16 channels (10-20 system), 250 Hz.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-2">
        {['Eyes Closed', 'Eyes Open', 'Motor Imagery', 'P300 Oddball', 'SSVEP 12Hz', 'Sleep N2', 'Eye Blink', 'Seizure', 'Meditation', 'Motor Right'].map((name) => (
          <div class="px-3 py-2 rounded-lg text-center text-xs font-medium" style="background: var(--color-bg-elevated); color: var(--color-text-muted);">
            {name}
          </div>
        ))}
      </div>
    </div>

    <!-- Launch CTA -->
    <div class="text-center mb-10">
      <a
        href="https://github.com/qinnovates/neurosim"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3 rounded-xl text-base font-semibold transition-colors"
        style="background: #22d3ee; color: #0a0e17;"
      >
        <svg class="w-5 h-5" viewBox="0 0 32 32" fill="none">
          <path d="M8 16 Q12 8 16 16 Q20 24 24 16" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
        </svg>
        View on GitHub
      </a>
      <p class="text-xs mt-3" style="color: var(--color-text-faint);">
        Open source. Run locally with <code class="font-mono px-1 py-0.5 rounded" style="background: var(--color-bg-elevated);">npm run dev</code> + <code class="font-mono px-1 py-0.5 rounded" style="background: var(--color-bg-elevated);">uvicorn</code>.
      </p>
    </div>

    <!-- Tech Stack -->
    <div class="glass rounded-xl p-6 mb-8">
      <h2 class="text-sm font-mono font-semibold mb-3" style="color: var(--color-text-muted);">Built With</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {[
          { name: 'BrainFlow', detail: '40+ BCI devices' },
          { name: 'React + Vite', detail: 'Frontend' },
          { name: 'FastAPI', detail: 'WebSocket backend' },
          { name: 'SciPy', detail: 'Welch PSD analysis' },
        ].map((tech) => (
          <div class="text-center">
            <p class="text-sm font-semibold" style="color: var(--color-text-primary);">{tech.name}</p>
            <p class="text-[10px]" style="color: var(--color-text-faint);">{tech.detail}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="text-center">
      <p class="text-[10px] font-mono tracking-[0.08em]" style="color: var(--color-text-faint);">
        PROPOSED FRAMEWORK &middot; NOT VALIDATED &middot; RESEARCH USE ONLY
      </p>
    </div>
  </main>
</PageLayout>
