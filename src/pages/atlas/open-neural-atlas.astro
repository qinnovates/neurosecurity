---
import PageLayout from '@/layouts/PageLayout.astro';
---

<PageLayout
  title="Demo Atlas — Open Neural Monitoring Platform"
  description="Explore EEG signal analysis, frequency spectra, and TARA attack techniques with sample data — all in the browser. No hardware required."
  breadcrumbs={[{ label: 'Atlas', href: '/atlas/' }, { label: 'Demo Atlas' }]}
>
  <main class="mx-auto max-w-4xl px-4 py-8">
    <!-- Hero -->
    <div class="mb-10">
      <p class="text-xs font-mono tracking-[0.15em] uppercase mb-3" style="color: #22d3ee;">Demo Platform</p>
      <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-heading)] mb-3" style="color: var(--color-text-primary);">
        Demo Atlas
      </h1>
      <p class="text-base max-w-2xl" style="color: var(--color-text-muted);">
        Explore the Open Neural Atlas with pre-loaded sample data. Stream EEG signals,
        analyze frequency bands, run the TARA Scanner, and navigate the full QIF knowledge base — no hardware, no setup, no risk.
      </p>
    </div>

    <!-- Module Grid -->
    <div class="grid sm:grid-cols-2 gap-4 mb-10">
      {[
        {
          title: 'Signal Monitor',
          description: 'Watch live brain signals from all channels in real time — like a heart monitor for the brain.',
          color: '#10b981',
        },
        {
          title: 'Spectrum Analyzer',
          description: 'Break down signals into Delta, Theta, Alpha, Beta, and Gamma bands. Includes experimental DSM pattern analysis.',
          color: '#a855f7',
        },
        {
          title: 'TARA Scanner',
          description: 'Penetration testing for BCI — scan, replay, and compare 13 attack techniques across 6 categories.',
          color: '#f59e0b',
        },
        {
          title: 'Alert Center',
          description: 'Every anomaly detection event with timestamps, severity levels, and channel identification.',
          color: '#ef4444',
        },
        {
          title: 'NeuroSIM',
          description: 'Simulation hub — load sample datasets, explore neuron models, and browse the full EEG electrode map.',
          color: '#22d3ee',
        },
        {
          title: 'Integrations',
          description: 'Connect to APIs, data feeds, and the QIF knowledge base with KQL.',
          color: '#6366f1',
        },
      ].map((mod) => (
        <div class="glass rounded-xl p-5" style={`border-left: 3px solid ${mod.color};`}>
          <h3 class="text-sm font-bold mb-1" style={`color: ${mod.color};`}>{mod.title}</h3>
          <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">{mod.description}</p>
        </div>
      ))}
    </div>

    <!-- Sample Data -->
    <div class="glass rounded-xl p-6 mb-10">
      <h2 class="text-lg font-bold mb-2" style="color: var(--color-text-primary);">10 Sample EEG Datasets Included</h2>
      <p class="text-sm mb-4" style="color: var(--color-text-muted);">
        Synthetic datasets generated from known EEG patterns — no hardware needed. 16 channels (10-20 system), 250 Hz.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-2">
        {['Eyes Closed', 'Eyes Open', 'Motor Imagery', 'P300 Oddball', 'SSVEP 12Hz', 'Sleep N2', 'Eye Blink', 'Seizure', 'Meditation', 'Motor Right'].map((name) => (
          <div class="px-3 py-2 rounded-lg text-center text-xs font-medium" style="background: var(--color-bg-elevated); color: var(--color-text-muted);">
            {name}
          </div>
        ))}
      </div>
    </div>

    <!-- Launch CTA -->
    <div class="text-center mb-10">
      <a
        href="/demo-atlas/"
        class="inline-flex items-center gap-2 px-10 py-4 rounded-xl text-lg font-bold transition-all hover:scale-[1.02]"
        style="background: linear-gradient(135deg, #22d3ee, #06b6d4); color: #0a0e17; box-shadow: 0 4px 24px rgba(34, 211, 238, 0.25);"
      >
        <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none">
          <path d="M8 16 Q12 8 16 16 Q20 24 24 16" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
        </svg>
        Launch Demo Atlas
      </a>
      <p class="text-xs mt-3" style="color: var(--color-text-faint);">
        Runs entirely in your browser. No install, no backend, no data leaves your device.
      </p>
      <a
        href="https://github.com/qinnovates/neurosim"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 mt-3 text-xs font-medium transition-colors"
        style="color: var(--color-text-muted);"
      >
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        View source on GitHub
      </a>
    </div>

    <!-- Why Sample Data -->
    <div class="glass rounded-xl p-6 mb-10" style="border: 1px solid #f59e0b20;">
      <h2 class="text-lg font-bold mb-3" style="color: var(--color-text-primary);">Why Sample Data?</h2>
      <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-muted);">
        Building secure neurotechnology infrastructure takes time. The QIF framework itself is fully open — every threat model,
        every scoring methodology, every line of code. But a tool that connects directly to brain-computer interfaces
        carries a responsibility most software doesn't: protecting biometric data that can never be changed.
      </p>
      <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-muted);">
        This demo ships with sample EEG data so you can explore the full platform without risking your own neural signals.
        No accidental data leaks. No unencrypted streams leaving your device. Just the science, the security models, and the tools — ready to learn from.
      </p>
      <p class="text-sm leading-relaxed mb-5" style="color: var(--color-text-muted);">
        A full version with live BCI device connectivity, advanced signal processing, and enterprise-grade data protection is in development.
      </p>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3 pt-3" style="border-top: 1px solid var(--color-border);">
        <a
          href="mailto:kevin@qinnovate.com?subject=Atlas%20—%20Full%20Version%20Inquiry"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors"
          style="background: #f59e0b; color: #0a0e17;"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          Inquire About the Full Version
        </a>
        <span class="text-xs" style="color: var(--color-text-faint);">
          kevin@qinnovate.com — serious inquiries only
        </span>
      </div>
    </div>

    <!-- Tech Stack -->
    <div class="glass rounded-xl p-6 mb-8">
      <h2 class="text-sm font-mono font-semibold mb-3" style="color: var(--color-text-muted);">Built With</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {[
          { name: 'BrainFlow', detail: '40+ BCI devices' },
          { name: 'React + Vite', detail: 'Frontend' },
          { name: 'FastAPI', detail: 'WebSocket backend' },
          { name: 'SciPy', detail: 'Welch PSD analysis' },
        ].map((tech) => (
          <div class="text-center">
            <p class="text-sm font-semibold" style="color: var(--color-text-primary);">{tech.name}</p>
            <p class="text-[10px]" style="color: var(--color-text-faint);">{tech.detail}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="text-center">
      <p class="text-[10px] font-mono tracking-[0.08em]" style="color: var(--color-text-faint);">
        PROPOSED FRAMEWORK &middot; NOT VALIDATED &middot; RESEARCH USE ONLY
      </p>
    </div>
  </main>
</PageLayout>
