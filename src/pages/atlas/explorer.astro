---
import PageLayout from '@/layouts/PageLayout.astro';
import AtlasViewSwitcher from '@/components/atlas/AtlasViewSwitcher.astro';
import TaraExplorer from '../../components/atlas/TaraExplorer';
import { THREAT_VECTORS } from '../../lib/threat-data';
---
<PageLayout title="TARA Explorer | Qinnovate" description="Interactive explorer for the TARA threat catalog — search, filter, and visualize BCI attack techniques by domain, severity, and neurorights impact." breadcrumbs={[{label:'Atlas',href:'/atlas/'},{label:'Explorer'}]}>
  <AtlasViewSwitcher current="/atlas/explorer/" />
  <TaraExplorer client:load techniques={THREAT_VECTORS} />
</PageLayout>
