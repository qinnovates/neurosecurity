---
import PageLayout from '@/layouts/PageLayout.astro';
import ThreatMatrix from '@/components/ThreatMatrix';
import { HOURGLASS_BANDS } from '@/lib/qif-constants';
import { THREAT_CATEGORIES, THREAT_VECTORS, getTacticsWithCounts, THREAT_DOMAINS } from '@/lib/threat-data';

const tactics = getTacticsWithCounts();
const totalTechniques = THREAT_VECTORS.length;

// Group tactics by domain
const tacticsByDomain: Record<string, typeof tactics> = {};
for (const tactic of tactics) {
  const domain = tactic.domain || 'Unknown';
  if (!tacticsByDomain[domain]) tacticsByDomain[domain] = [];
  tacticsByDomain[domain].push(tactic);
}

// Severity distribution
const severityCounts = { critical: 0, high: 0, medium: 0, low: 0 };
for (const t of THREAT_VECTORS) {
  if (t.severity in severityCounts) severityCounts[t.severity as keyof typeof severityCounts]++;
}

// NISS stats
const nissScores = THREAT_VECTORS.map(t => t.niss.score).filter(s => s > 0);
const avgNiss = nissScores.length > 0 ? (nissScores.reduce((a, b) => a + b, 0) / nissScores.length).toFixed(1) : '0';
const maxNiss = nissScores.length > 0 ? Math.max(...nissScores).toFixed(1) : '0';

// Example technique for decoder
const exampleTechnique = THREAT_VECTORS[0];

// Band zone groupings for reference
const neuralBands = HOURGLASS_BANDS.filter(b => b.id.startsWith('N'));
const interfaceBands = HOURGLASS_BANDS.filter(b => b.id === 'I0');
const syntheticBands = HOURGLASS_BANDS.filter(b => b.id.startsWith('S'));

// Serialize data for the React component
const matrixTechniques = THREAT_VECTORS.map(t => ({
  id: t.id,
  name: t.name,
  category: t.category,
  tactic: t.tactic,
  bands: [...t.bands],
  severity: t.severity,
  status: t.status,
  description: t.description,
  bandsStr: t.bandsStr,
  niss: t.niss,
  tara: t.tara ? { dual_use: t.tara.dual_use, clinical: t.tara.clinical } : null,
}));

const matrixCategories = THREAT_CATEGORIES.map(c => ({
  id: c.id,
  name: c.name,
  description: c.description,
}));

const matrixBands = HOURGLASS_BANDS.map(b => ({
  id: b.id,
  name: b.name,
  zone: b.zone,
  color: b.color,
  description: b.description,
}));

const SEVERITY_COLORS: Record<string, string> = {
  critical: '#ef4444', high: '#f59e0b', medium: '#eab308', low: '#94a3b8',
};
---

<PageLayout
  title="Threat Matrix — TARA Tactics, Techniques & Procedures"
  description="Interactive threat matrix mapping 135 BCI attack techniques across 11 hourglass bands and 9 attack categories. Explore the full TARA taxonomy."
  breadcrumbs={[
    { label: 'Neural Atlas', href: '/atlas/' },
    { label: 'TARA', href: '/atlas/tara/' },
    { label: 'Threat Matrix' },
  ]}
  wide={true}
>
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-10">
      <p class="text-xs font-mono tracking-[0.15em] uppercase text-[var(--color-accent-secondary)] mb-3">TARA Taxonomy</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="font-family: var(--font-heading);">
        Threat Matrix
      </h1>
      <p class="text-base sm:text-lg text-[var(--color-text-muted)] max-w-3xl leading-relaxed">
        {totalTechniques} attack techniques mapped across 11 hourglass bands and 9 attack categories. Click any cell to explore the techniques at that intersection.
      </p>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-3 mb-8">
      {Object.entries(severityCounts).map(([sev, count]) => (
        <div class="glass rounded-xl px-4 py-3 text-center">
          <p class="text-2xl font-bold font-[family-name:var(--font-heading)]" style={`color: ${SEVERITY_COLORS[sev]};`}>
            {count}
          </p>
          <p class="text-[10px] uppercase tracking-[0.1em] mt-1 capitalize" style="color: var(--color-text-faint);">
            {sev}
          </p>
        </div>
      ))}
      <div class="glass rounded-xl px-4 py-3 text-center">
        <p class="text-2xl font-bold font-[family-name:var(--font-heading)]" style="color: #06b6d4;">
          {avgNiss}
        </p>
        <p class="text-[10px] uppercase tracking-[0.1em] mt-1" style="color: var(--color-text-faint);">
          Avg NISS
        </p>
      </div>
      <div class="glass rounded-xl px-4 py-3 text-center">
        <p class="text-2xl font-bold font-[family-name:var(--font-heading)]" style="color: #ef4444;">
          {maxNiss}
        </p>
        <p class="text-[10px] uppercase tracking-[0.1em] mt-1" style="color: var(--color-text-faint);">
          Max NISS
        </p>
      </div>
    </div>

    <!-- Interactive Threat Matrix -->
    <ThreatMatrix
      client:load
      techniques={matrixTechniques}
      categories={matrixCategories}
      bands={matrixBands}
    />

    <!-- Section Divider: How to Read -->
    <div class="flex items-center gap-3 my-10">
      <div class="flex-1 h-px" style="background: var(--color-border);" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">How to Read This Matrix</span>
      <div class="flex-1 h-px" style="background: var(--color-border);" />
    </div>

    <!-- TTP Hierarchy + ID Decoder -->
    <div class="grid lg:grid-cols-2 gap-6 mb-10">
      <!-- TTP Hierarchy -->
      <div>
        <h2 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">TTP Hierarchy</h2>
        <div class="space-y-3">
          <div class="rounded-xl p-4 border" style="background: var(--color-bg-secondary); border-color: var(--color-border);">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold" style="background: rgba(6, 182, 212, 0.15); color: #06b6d4;">T</span>
              <h3 class="text-sm font-bold">Tactic</h3>
              <span class="text-xs text-[var(--color-text-faint)] ml-auto">Why</span>
            </div>
            <p class="text-xs text-[var(--color-text-muted)]">The attacker's strategic objective. Format: <span class="font-mono text-[var(--color-accent-secondary)]">QIF-N.IJ</span> (domain + action code).</p>
          </div>
          <div class="rounded-xl p-4 border" style="background: var(--color-bg-secondary); border-color: var(--color-border);">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold" style="background: rgba(16, 185, 129, 0.15); color: #10b981;">T</span>
              <h3 class="text-sm font-bold">Technique</h3>
              <span class="text-xs text-[var(--color-text-faint)] ml-auto">What</span>
            </div>
            <p class="text-xs text-[var(--color-text-muted)]">The specific method. Format: <span class="font-mono text-[var(--color-accent-secondary)]">QIF-T0001</span> (sequential, stable ID).</p>
          </div>
          <div class="rounded-xl p-4 border" style="background: var(--color-bg-secondary); border-color: var(--color-border);">
            <div class="flex items-center gap-2 mb-2">
              <span class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-bold" style="background: rgba(139, 92, 246, 0.15); color: #8b5cf6;">P</span>
              <h3 class="text-sm font-bold">Procedure</h3>
              <span class="text-xs text-[var(--color-text-faint)] ml-auto">How</span>
            </div>
            <p class="text-xs text-[var(--color-text-muted)]">Implementation on specific hardware. Example: 10 Hz tACS via compromised Emotiv EPOC+.</p>
          </div>
        </div>
      </div>

      <!-- ID Decoder -->
      <div>
        <h2 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Reading an Entry</h2>
        <div class="rounded-xl p-5 border" style="background: var(--color-bg-secondary); border-color: var(--color-border);">
          <div class="space-y-2.5 text-sm">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] shrink-0 w-16 text-right" style="color: var(--color-text-faint);">Technique</span>
              <span class="font-mono font-bold text-xs" style="color: var(--color-accent-secondary);">{exampleTechnique?.id}</span>
              <span class="text-xs text-[var(--color-text-muted)] truncate">{exampleTechnique?.name}</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] shrink-0 w-16 text-right" style="color: var(--color-text-faint);">Tactic</span>
              <span class="font-mono font-bold text-xs" style="color: var(--color-accent-secondary);">{exampleTechnique?.tactic}</span>
              <span class="text-xs text-[var(--color-text-muted)]">strategic objective</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] shrink-0 w-16 text-right" style="color: var(--color-text-faint);">Category</span>
              <span class="font-mono font-bold text-xs" style="color: var(--color-accent-primary);">{exampleTechnique?.category}</span>
              <span class="text-xs text-[var(--color-text-muted)]">type of harm</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] shrink-0 w-16 text-right" style="color: var(--color-text-faint);">Bands</span>
              <span class="font-mono font-bold text-xs" style="color: #22c55e;">{exampleTechnique?.bands.join(', ')}</span>
              <span class="text-xs text-[var(--color-text-muted)]">hourglass layers</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] shrink-0 w-16 text-right" style="color: var(--color-text-faint);">NISS</span>
              <span class="font-mono font-bold text-xs" style={`color: ${exampleTechnique?.niss.severity === 'critical' ? '#ef4444' : exampleTechnique?.niss.severity === 'high' ? '#f59e0b' : '#94a3b8'};`}>
                {exampleTechnique?.niss.score.toFixed(1)} {exampleTechnique?.niss.severity.toUpperCase()}
              </span>
              <span class="text-xs text-[var(--color-text-muted)]">neural impact score</span>
            </div>
          </div>
          <div class="mt-4 pt-3 border-t text-[10px] text-[var(--color-text-faint)]" style="border-color: var(--color-border);">
            NISS measures signal-level disruption, not cognitive harm. Scores correspond to severity categories for threat modeling purposes.
          </div>
        </div>
      </div>
    </div>

    <!-- Axis References: Bands + Categories -->
    <div class="grid lg:grid-cols-2 gap-6 mb-10">
      <!-- Row Axis: Hourglass Bands -->
      <div>
        <h2 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Rows: Hourglass Bands</h2>
        <div class="space-y-3">
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="w-3 h-3 rounded-full" style="background: #22c55e;"></span>
              <span class="text-xs font-bold uppercase tracking-wider" style="color: #22c55e;">Neural Zone (N7-N1)</span>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {neuralBands.map((band) => (
                <span class="font-mono text-[10px] px-2 py-1 rounded-md border" style={`color: ${band.color}; border-color: var(--color-border); background: var(--color-bg-secondary);`}>
                  {band.id} <span class="text-[var(--color-text-faint)]">{band.name}</span>
                </span>
              ))}
            </div>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="w-3 h-3 rounded-full" style="background: #f59e0b;"></span>
              <span class="text-xs font-bold uppercase tracking-wider" style="color: #f59e0b;">Interface Zone (I0)</span>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {interfaceBands.map((band) => (
                <span class="font-mono text-[10px] px-2 py-1 rounded-md border" style={`color: ${band.color}; border-color: var(--color-border); background: var(--color-bg-secondary);`}>
                  {band.id} <span class="text-[var(--color-text-faint)]">{band.name}</span>
                </span>
              ))}
            </div>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="w-3 h-3 rounded-full" style="background: #3b82f6;"></span>
              <span class="text-xs font-bold uppercase tracking-wider" style="color: #3b82f6;">Synthetic Zone (S1-S3)</span>
            </div>
            <div class="flex flex-wrap gap-1.5">
              {syntheticBands.map((band) => (
                <span class="font-mono text-[10px] px-2 py-1 rounded-md border" style={`color: ${band.color}; border-color: var(--color-border); background: var(--color-bg-secondary);`}>
                  {band.id} <span class="text-[var(--color-text-faint)]">{band.name}</span>
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Column Axis: Attack Categories -->
      <div>
        <h2 class="text-lg font-bold mb-4" style="font-family: var(--font-heading);">Columns: Attack Categories</h2>
        <div class="rounded-xl border overflow-hidden" style="border-color: var(--color-border);">
          <table class="w-full text-sm">
            <thead>
              <tr style="background: var(--color-bg-secondary);">
                <th class="text-left px-3 py-2 font-mono text-xs" style="color: var(--color-text-faint);">Code</th>
                <th class="text-left px-3 py-2 text-xs" style="color: var(--color-text-faint);">Category</th>
                <th class="text-right px-3 py-2 text-xs" style="color: var(--color-text-faint);">N</th>
              </tr>
            </thead>
            <tbody>
              {THREAT_CATEGORIES.map((cat) => {
                const count = THREAT_VECTORS.filter(t => t.category === cat.id).length;
                return (
                  <tr class="border-t" style="border-color: var(--color-border);">
                    <td class="px-3 py-1.5 font-mono text-xs font-bold" style="color: var(--color-accent-primary);">{cat.id}</td>
                    <td class="px-3 py-1.5 text-xs" style="color: var(--color-text-primary);">{cat.name}</td>
                    <td class="px-3 py-1.5 text-right font-mono text-xs" style="color: var(--color-text-faint);">{count}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Tactics Reference Table -->
    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-px" style="background: var(--color-border);" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">Tactics Reference</span>
      <div class="flex-1 h-px" style="background: var(--color-border);" />
    </div>

    <div class="mb-12">
      <p class="text-sm text-[var(--color-text-muted)] mb-6">{tactics.length} tactics across {Object.keys(tacticsByDomain).length} operational domains. Tactic IDs use domain + action code (e.g., N.IJ = Neural Injection).</p>

      <div class="space-y-6">
        {Object.entries(tacticsByDomain).map(([domain, domainTactics]) => (
          <div>
            <h3 class="text-xs font-bold uppercase tracking-wider mb-2" style="color: var(--color-text-faint);">
              {domain}
            </h3>
            <div class="rounded-xl border overflow-hidden" style="border-color: var(--color-border);">
              <table class="w-full text-sm">
                <thead>
                  <tr style="background: var(--color-bg-secondary);">
                    <th class="text-left px-4 py-2.5 font-mono text-xs" style="color: var(--color-text-faint);">ID</th>
                    <th class="text-left px-4 py-2.5 text-xs" style="color: var(--color-text-faint);">Tactic</th>
                    <th class="text-left px-4 py-2.5 text-xs hidden sm:table-cell" style="color: var(--color-text-faint);">Description</th>
                    <th class="text-right px-4 py-2.5 text-xs" style="color: var(--color-text-faint);">Count</th>
                  </tr>
                </thead>
                <tbody>
                  {(domainTactics as any[]).map((tactic: any) => (
                    <tr class="border-t" style="border-color: var(--color-border);">
                      <td class="px-4 py-2.5 font-mono text-xs" style="color: var(--color-accent-secondary);">{tactic.id}</td>
                      <td class="px-4 py-2.5 text-sm font-medium" style="color: var(--color-text-primary);">{tactic.name}</td>
                      <td class="px-4 py-2.5 text-xs hidden sm:table-cell" style="color: var(--color-text-muted);">{tactic.description}</td>
                      <td class="px-4 py-2.5 text-right font-mono text-xs" style="color: var(--color-text-faint);">{tactic.count}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Navigation -->
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/atlas/tara/" class="px-5 py-2.5 rounded-xl text-sm font-medium transition-colors glass">Browse All Techniques &rarr;</a>
      <a href="/atlas/scoring/" class="px-5 py-2.5 rounded-xl text-sm font-medium transition-colors glass">NISS Scoring &rarr;</a>
    </div>
  </div>
</PageLayout>
