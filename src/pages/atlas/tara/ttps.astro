---
import PageLayout from '@/layouts/PageLayout.astro';
import ThreatMatrix from '@/components/ThreatMatrix';
import { HOURGLASS_BANDS } from '@/lib/qif-constants';
import { THREAT_CATEGORIES, THREAT_VECTORS, getTacticsWithCounts, THREAT_DOMAINS } from '@/lib/threat-data';

const tactics = getTacticsWithCounts();
const totalTechniques = THREAT_VECTORS.length;

// Group tactics by domain
const tacticsByDomain: Record<string, typeof tactics> = {};
for (const tactic of tactics) {
  const domain = tactic.domain || 'Unknown';
  if (!tacticsByDomain[domain]) tacticsByDomain[domain] = [];
  tacticsByDomain[domain].push(tactic);
}

// Severity distribution
const severityCounts = { critical: 0, high: 0, medium: 0, low: 0 };
for (const t of THREAT_VECTORS) {
  if (t.severity in severityCounts) severityCounts[t.severity as keyof typeof severityCounts]++;
}

// Serialize data for the React component
const matrixTechniques = THREAT_VECTORS.map(t => ({
  id: t.id,
  name: t.name,
  category: t.category,
  tactic: t.tactic,
  bands: [...t.bands],
  severity: t.severity,
  status: t.status,
  description: t.description,
  bandsStr: t.bandsStr,
  niss: t.niss,
  tara: t.tara ? { dual_use: t.tara.dual_use, clinical: t.tara.clinical } : null,
}));

const matrixCategories = THREAT_CATEGORIES.map(c => ({
  id: c.id,
  name: c.name,
  description: c.description,
}));

const matrixBands = HOURGLASS_BANDS.map(b => ({
  id: b.id,
  name: b.name,
  zone: b.zone,
  color: b.color,
  description: b.description,
}));

const SEVERITY_COLORS: Record<string, string> = {
  critical: '#ef4444', high: '#f59e0b', medium: '#eab308', low: '#94a3b8',
};
---

<PageLayout
  title="Threat Matrix — TARA Tactics, Techniques & Procedures"
  description="Interactive threat matrix mapping 109 BCI attack techniques across 11 hourglass bands and 9 attack categories. Explore the full TARA taxonomy."
  breadcrumbs={[
    { label: 'Neural Atlas', href: '/atlas/' },
    { label: 'TARA', href: '/atlas/tara/' },
    { label: 'Threat Matrix' },
  ]}
  wide={true}
>
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-10">
      <p class="text-xs font-mono tracking-[0.15em] uppercase text-[var(--color-accent-secondary)] mb-3">TARA Taxonomy</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight mb-4" style="font-family: var(--font-heading);">
        Threat Matrix
      </h1>
      <p class="text-base sm:text-lg text-[var(--color-text-muted)] max-w-3xl leading-relaxed">
        {totalTechniques} attack techniques mapped across 11 hourglass bands and 9 attack categories. Click any cell to explore the techniques at that intersection.
      </p>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
      {Object.entries(severityCounts).map(([sev, count]) => (
        <div class="glass rounded-xl px-4 py-3 text-center">
          <p class="text-2xl font-bold font-[family-name:var(--font-heading)]" style={`color: ${SEVERITY_COLORS[sev]};`}>
            {count}
          </p>
          <p class="text-[10px] uppercase tracking-[0.1em] mt-1 capitalize" style="color: var(--color-text-faint);">
            {sev}
          </p>
        </div>
      ))}
    </div>

    <!-- Interactive Threat Matrix -->
    <ThreatMatrix
      client:load
      techniques={matrixTechniques}
      categories={matrixCategories}
      bands={matrixBands}
    />

    <!-- Section Divider -->
    <div class="flex items-center gap-3 my-10">
      <div class="flex-1 h-px" style="background: var(--color-border);" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">TTP Hierarchy</span>
      <div class="flex-1 h-px" style="background: var(--color-border);" />
    </div>

    <!-- TTP Hierarchy Cards -->
    <div class="grid md:grid-cols-3 gap-4 mb-12">
      <div class="rounded-xl p-5 border" style="background: var(--color-bg-secondary); border-color: var(--color-border);">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: rgba(6, 182, 212, 0.15); color: #06b6d4;">T</span>
          <h3 class="text-base font-bold">Tactic</h3>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] mb-2">The attacker's strategic objective — <em>why</em> they act.</p>
        <p class="text-xs text-[var(--color-text-faint)]">Example: <span class="font-mono text-[var(--color-accent-secondary)]">QIF-N.IJ</span> — Neural Injection</p>
      </div>
      <div class="rounded-xl p-5 border" style="background: var(--color-bg-secondary); border-color: var(--color-border);">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: rgba(16, 185, 129, 0.15); color: #10b981;">T</span>
          <h3 class="text-base font-bold">Technique</h3>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] mb-2">The specific method used — <em>what</em> the attacker does.</p>
        <p class="text-xs text-[var(--color-text-faint)]">Example: <span class="font-mono text-[var(--color-accent-secondary)]">QIF-T0001</span> — tACS Phase Injection</p>
      </div>
      <div class="rounded-xl p-5 border" style="background: var(--color-bg-secondary); border-color: var(--color-border);">
        <div class="flex items-center gap-2 mb-3">
          <span class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: rgba(139, 92, 246, 0.15); color: #8b5cf6;">P</span>
          <h3 class="text-base font-bold">Procedure</h3>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] mb-2">The implementation detail — <em>how</em> on specific hardware.</p>
        <p class="text-xs text-[var(--color-text-faint)]">Example: 10 Hz tACS via compromised Emotiv EPOC+</p>
      </div>
    </div>

    <!-- Tactics Reference Table -->
    <div class="mb-12">
      <h2 class="text-xl font-bold mb-2" style="font-family: var(--font-heading);">Tactics Reference</h2>
      <p class="text-sm text-[var(--color-text-muted)] mb-6">{tactics.length} tactics across {Object.keys(tacticsByDomain).length} operational domains.</p>

      <div class="space-y-6">
        {Object.entries(tacticsByDomain).map(([domain, domainTactics]) => (
          <div>
            <h3 class="text-xs font-bold uppercase tracking-wider mb-2" style="color: var(--color-text-faint);">
              {domain}
            </h3>
            <div class="rounded-xl border overflow-hidden" style="border-color: var(--color-border);">
              <table class="w-full text-sm">
                <thead>
                  <tr style="background: var(--color-bg-secondary);">
                    <th class="text-left px-4 py-2.5 font-mono text-xs" style="color: var(--color-text-faint);">ID</th>
                    <th class="text-left px-4 py-2.5 text-xs" style="color: var(--color-text-faint);">Tactic</th>
                    <th class="text-left px-4 py-2.5 text-xs hidden sm:table-cell" style="color: var(--color-text-faint);">Description</th>
                    <th class="text-right px-4 py-2.5 text-xs" style="color: var(--color-text-faint);">Count</th>
                  </tr>
                </thead>
                <tbody>
                  {(domainTactics as any[]).map((tactic: any) => (
                    <tr class="border-t" style="border-color: var(--color-border);">
                      <td class="px-4 py-2.5 font-mono text-xs" style="color: var(--color-accent-secondary);">{tactic.id}</td>
                      <td class="px-4 py-2.5 text-sm font-medium" style="color: var(--color-text-primary);">{tactic.name}</td>
                      <td class="px-4 py-2.5 text-xs hidden sm:table-cell" style="color: var(--color-text-muted);">{tactic.description}</td>
                      <td class="px-4 py-2.5 text-right font-mono text-xs" style="color: var(--color-text-faint);">{tactic.count}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Navigation -->
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/atlas/tara/" class="px-5 py-2.5 rounded-xl text-sm font-medium transition-colors glass">Browse All Techniques &rarr;</a>
      <a href="/atlas/tara/numbering/" class="px-5 py-2.5 rounded-xl text-sm font-medium transition-colors glass">QIF Numbering System &rarr;</a>
      <a href="/atlas/scoring/" class="px-5 py-2.5 rounded-xl text-sm font-medium transition-colors glass">NISS Scoring &rarr;</a>
    </div>
  </div>
</PageLayout>
