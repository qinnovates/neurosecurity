---
import PageLayout from '@/layouts/PageLayout.astro';
import AtlasDashboard from '@/components/atlas/AtlasDashboard';
import BciKql from '@/components/bci/BciKql';
import PublicationCard from '@/components/PublicationCard.astro';
import { getAtlasData, getThreatsForBandDetail } from '@/lib/atlas-data';
import { getBrainViewData } from '@/lib/brain-view-data';
import { getKqlTables } from '@/lib/kql-tables';
import { HOURGLASS_BANDS } from '@/lib/qif-constants';
import { getCollection } from 'astro:content';
import { getPostDate } from '@/lib/utils';

// Build-time data computation
const kqlTables = getKqlTables();
const atlasData = getAtlasData();
const brainViews = getBrainViewData();

// Pre-compute threat details per band
const threatDetails: Record<string, any> = {};
for (const band of HOURGLASS_BANDS) {
  threatDetails[band.id] = getThreatsForBandDetail(band.id);
}

// Aggregate stats for hero
const totalThreats = atlasData.bands.reduce((sum, b) => sum + b.threatCount, 0);
const totalDevices = atlasData.devices.length;
const totalNeurorights = atlasData.neurorights.length;
const totalDsmCodes = atlasData.dsmClusters.reduce((sum, c) => sum + c.conditions.length, 0);
const avgNiss = (Object.values(threatDetails).reduce((sum: number, d: any) => sum + d.avgNiss, 0) / Object.values(threatDetails).length).toFixed(1);

// Recent blog posts (security/BCI-related)
const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(getPostDate(b.data)).getTime() - new Date(getPostDate(a.data)).getTime())
  .slice(0, 4);

// Sub-page navigation cards
const subPages = [
  {
    title: 'TARA Threat Catalog',
    description: 'Browse all attack techniques with NISS scores, kill chains, and band mappings.',
    href: '/atlas/tara/',
    icon: 'shield',
    stat: `${totalThreats} techniques`,
    color: '#ef4444',
  },
  {
    title: 'NISS Scoring',
    description: 'Neural Impact Severity Score — a proposed CVSS v4.0 extension for BCI security.',
    href: '/atlas/scoring/',
    icon: 'chart',
    stat: `Avg ${avgNiss}`,
    color: '#f59e0b',
  },
  {
    title: 'Case Studies',
    description: 'Deep-dive threat models, attack chain analysis, and real-world case studies.',
    href: '/atlas/analysis/',
    icon: 'document',
    stat: 'Analysis',
    color: '#3b82f6',
  },
  {
    title: 'Clinical & Therapeutics',
    description: 'Neural Impact Chain, dual-use mappings, FDA status, clinical domains — the full clinical picture.',
    href: '/atlas/clinical/',
    icon: 'brain',
    stat: `${atlasData.bands.reduce((s, b) => s + b.brainRegions.length, 0)} regions`,
    color: '#10b981',
  },
];

const iconSvg: Record<string, string> = {
  shield: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />',
  chart: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />',
  document: '<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />',
  brain: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />',
  heart: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />',
};
---

<PageLayout
  title="QIF Atlas"
  description="Unified Atlas Dashboard — hourglass architecture, 3D brain visualization, threat intelligence, and BCI device mappings. Explore 11 bands, brain regions, devices, neurorights, and attack vectors."
  breadcrumbs={[{ label: 'Atlas' }]}
  wide={true}
>
  <!-- Hero Section -->
  <div class="mb-10">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-8">
      <div>
        <p class="text-xs font-mono tracking-[0.15em] uppercase mb-3" style="color: var(--color-accent-primary);">Neural Security Intelligence</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-heading)] mb-3" style="color: var(--color-text-primary);">QIF Atlas</h1>
        <p class="text-base sm:text-lg max-w-2xl" style="color: var(--color-text-muted);">
          The unified map of brain-computer interface security. Every attack surface, every defense, every neuroright — linked across 11 hourglass bands.
        </p>
      </div>
      <div class="flex items-center gap-2 shrink-0 flex-wrap">
        <a href="/demo-atlas/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-bold transition-all hover:scale-[1.02]" style="background: linear-gradient(135deg, #22d3ee, #06b6d4); color: #0a0e17; box-shadow: 0 2px 12px rgba(34, 211, 238, 0.2);">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h2l3-6 4 12 3-8 2 2h4" /></svg>
          Launch Demo Atlas
        </a>
        <a href="/research/whitepaper/" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors" style="background: var(--color-accent-primary); color: #fff;">
          Whitepaper
        </a>
        <a href="https://github.com/qinnovates/qinnovate" target="_blank" rel="noopener noreferrer" class="px-4 py-2 rounded-lg text-sm font-medium transition-colors glass">
          GitHub
        </a>
      </div>
    </div>

    <!-- Stats Bar -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
      {[
        { label: 'Attack Techniques', value: totalThreats, color: '#ef4444' },
        { label: 'BCI Devices', value: totalDevices, color: '#3b82f6' },
        { label: 'Neurorights', value: totalNeurorights, color: '#8b5cf6' },
        { label: 'DSM-5 Codes', value: totalDsmCodes, color: '#10b981' },
        { label: 'Hourglass Bands', value: 11, color: '#f59e0b' },
      ].map((stat) => (
        <div class="glass rounded-xl px-4 py-3 text-center" style={`border-color: ${stat.color}20;`}>
          <p class="text-2xl sm:text-3xl font-bold font-[family-name:var(--font-heading)]" style={`color: ${stat.color};`}>{stat.value}</p>
          <p class="text-[10px] uppercase tracking-[0.1em] mt-1" style="color: var(--color-text-faint);">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Sub-Page Navigation Cards -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3 mb-10">
    {subPages.map((page) => (
      <a
        href={page.href}
        class="glass rounded-xl p-5 group transition-all hover:shadow-lg relative overflow-hidden"
        style={`border-color: ${page.color}15;`}
      >
        <div class="absolute top-0 left-0 w-full h-0.5" style={`background: ${page.color}; opacity: 0;`} />
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style={`background: ${page.color}12;`}>
            <svg class="w-4.5 h-4.5" style={`color: ${page.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={iconSvg[page.icon]} />
          </div>
          <span class="text-[10px] font-mono px-2 py-0.5 rounded-full" style={`background: ${page.color}10; color: ${page.color};`}>
            {page.stat}
          </span>
        </div>
        <h3 class="text-sm font-bold mb-1.5 group-hover:text-[var(--color-accent-primary)] transition-colors" style="color: var(--color-text-primary);">
          {page.title}
        </h3>
        <p class="text-xs leading-relaxed" style="color: var(--color-text-muted);">
          {page.description}
        </p>
      </a>
    ))}
  </div>

  <!-- Section Divider -->
  <div class="flex items-center gap-3 mb-6">
    <div class="flex-1 h-px" style="background: var(--color-border);" />
    <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">Interactive Dashboard</span>
    <div class="flex-1 h-px" style="background: var(--color-border);" />
  </div>

  <!-- AtlasDashboard -->
  <AtlasDashboard
    client:only="react"
    atlasData={atlasData}
    brainViews={brainViews}
    threatDetails={threatDetails}
  />

  <!-- Recent Research -->
  {posts.length > 0 && (
    <div class="mt-16 mb-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="flex-1 h-px" style="background: var(--color-border);" />
        <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">Latest Research</span>
        <div class="flex-1 h-px" style="background: var(--color-border);" />
      </div>

      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="text-xl font-bold font-[family-name:var(--font-heading)]" style="color: var(--color-text-primary);">Recent Work</h2>
          <p class="text-sm mt-1" style="color: var(--color-text-muted);">Field journals, case studies, and research notes.</p>
        </div>
        <a href="/news/" class="text-sm font-medium" style="color: var(--color-accent-primary);">
          All posts &rarr;
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {posts.map((post) => (
          <PublicationCard
            title={post.data.title}
            date={post.data.date_posted || post.data.date || new Date()}
            tags={post.data.tags}
            slug={post.id}
            body={post.body || ''}
            compact
          />
        ))}
      </div>
    </div>
  )}

  <!-- KQL Query Engine -->
  <div class="mt-12">
    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-px" style="background: var(--color-border);" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">Query Engine</span>
      <div class="flex-1 h-px" style="background: var(--color-border);" />
    </div>
    <BciKql client:only="react" tables={kqlTables} />
  </div>

  <!-- Footer note -->
  <div class="mt-8 mb-4 text-center">
    <p class="text-xs" style="color: var(--color-text-faint);">
      Data driven from JSON &mdash; atlas, ethics, DSM-5-TR, security controls.
      <a href="/atlas/tara/" class="underline ml-1">TARA Atlas</a> &middot;
      <a href="/atlas/scoring/" class="underline">NISS Scoring</a> &middot;
      <a href="/atlas/analysis/" class="underline">Case Studies</a> &middot;
      <a href="/atlas/clinical/#therapeutics" class="underline">Therapeutics</a>
    </p>
    <p class="text-[10px] font-mono mt-2 tracking-[0.08em]" style="color: var(--color-text-faint);">
      PROPOSED FRAMEWORK &middot; NOT VALIDATED &middot; OPEN TO CRITIQUE
    </p>
  </div>
</PageLayout>
