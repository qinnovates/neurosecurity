---
import PageLayout from '@/layouts/PageLayout.astro';
import ClinicalDashboard from '@/components/atlas/ClinicalDashboard';
import BciKql from '@/components/bci/BciKql';
import { getClinicalData } from '@/lib/clinical-data';
import { getKqlTables } from '@/lib/kql-tables';
import neurotransmitterRaw from '@shared/qif-neurotransmitters.json';

// Build-time data compilation — all JSON sources merged dynamically
const clinicalData = getClinicalData();
const kqlTables = getKqlTables();

// Neurotransmitter table data
const allNeurotransmitters = (neurotransmitterRaw as any).neurotransmitters || [];
const totalNeurotransmitters = allNeurotransmitters.length;
const totalReceptors = allNeurotransmitters.reduce((s: number, nt: any) => s + (Array.isArray(nt.receptors) ? nt.receptors.length : 0), 0);
const totalCofactors = allNeurotransmitters.reduce((s: number, nt: any) => s + (nt.cofactor_dependencies || []).length, 0);
const totalSynthSteps = allNeurotransmitters.reduce((s: number, nt: any) => s + (nt.synthesis_pathway || []).length, 0);

const ntColors: Record<string, string> = {
  dopamine: '#f59e0b', serotonin: '#3b82f6', norepinephrine: '#ef4444', acetylcholine: '#10b981',
  gaba: '#8b5cf6', glutamate: '#ec4899', endorphin: '#06b6d4', oxytocin: '#f97316',
  histamine: '#a855f7', glycine: '#14b8a6', substance_p: '#e11d48', anandamide: '#84cc16',
  melatonin: '#6366f1', adenosine: '#64748b', nitric_oxide: '#0ea5e9', epinephrine: '#dc2626',
  dynorphin: '#7c3aed', enkephalin: '#2dd4bf',
};

const bandColors: Record<string, string> = {
  N7: '#166534', N6: '#3a7d44', N5: '#5c7a38', N4: '#72772f',
  N3: '#877226', N2: '#9b6c1e', N1: '#ae6616', I0: '#f59e0b',
  S1: '#93c5fd', S2: '#60a5fa', S3: '#3b82f6',
};
---

<PageLayout
  title="Clinical View — QIF Atlas"
  description="Neural Impact Chain visualization — trace attack techniques through QIF bands, neural pathways, brain regions, and DSM-5-TR diagnostic categories. For threat modeling purposes."
  breadcrumbs={[{ label: 'Atlas', href: '/atlas/' }, { label: 'Clinical View' }]}
  wide={true}
>
  <!-- Hero -->
  <div class="mb-8">
    <p class="text-xs font-mono tracking-[0.15em] uppercase mb-3" style="color: #10b981;">Neural Impact Chain</p>
    <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-heading)] mb-3" style="color: var(--color-text-primary);">
      Clinical View
    </h1>
    <p class="text-base max-w-3xl" style="color: var(--color-text-muted);">
      Trace the full chain from attack technique to clinical outcome. Every threat mapped through QIF hourglass bands,
      neural pathways, neurotransmitter systems, brain regions, and DSM-5-TR diagnostic categories.
    </p>
    <p class="text-xs mt-2 italic" style="color: var(--color-text-faint);">
      Diagnostic category references for threat modeling purposes. Not clinical diagnosis. Requires clinical validation.
    </p>
  </div>

  <!-- Clinical Dashboard -->
  <ClinicalDashboard
    client:only="react"
    data={clinicalData}
  />

  <!-- Neurotransmitter Systems -->
  <div class="mt-16">
    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-px" style="background: var(--color-border);" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">Neurotransmitter Systems</span>
      <div class="flex-1 h-px" style="background: var(--color-border);" />
    </div>

    <p class="text-xs mb-6" style="color: var(--color-text-faint);">
      {totalNeurotransmitters} neurotransmitters with {totalSynthSteps} synthesis steps, {totalCofactors} cofactor dependencies, and {totalReceptors} receptor subtypes mapped
    </p>

    <div class="glass rounded-xl p-5 mb-6">
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b border-[var(--color-border)]/30">
              <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Neurotransmitter</th>
              <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Class</th>
              <th class="text-center py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Synth Steps</th>
              <th class="text-center py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Receptors</th>
              <th class="text-center py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Cofactors</th>
              <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">Key Enzymes</th>
              <th class="text-left py-2 px-2 text-[var(--color-text-faint)] font-semibold uppercase tracking-wider text-[10px]">QIF Bands</th>
            </tr>
          </thead>
          <tbody class="text-[var(--color-text-muted)]">
            {allNeurotransmitters.map((nt: any) => {
              const synthSteps = (nt.synthesis_pathway || []).length;
              const receptorCount = Array.isArray(nt.receptors) ? nt.receptors.length : 0;
              const cofactorCount = (nt.cofactor_dependencies || []).length;
              const enzymes = (nt.synthesis_pathway || []).map((s: any) => s.enzyme_gene).filter(Boolean).slice(0, 3);
              const bands = nt.primary_qif_bands || [];
              const color = ntColors[nt.id] || '#94a3b8';
              return (
                <tr class="border-b border-[var(--color-border)]/10">
                  <td class="py-2 px-2">
                    <div class="flex items-center gap-2">
                      <span class="w-2 h-2 rounded-full shrink-0" style={`background: ${color}`} />
                      <span class="font-semibold" style={`color: ${color}`}>{nt.name}</span>
                      {nt.abbreviation && <span class="text-[9px] text-[var(--color-text-faint)]">({nt.abbreviation})</span>}
                    </div>
                  </td>
                  <td class="py-2 px-2 text-[var(--color-text-faint)]">{nt.chemical_class || '—'}</td>
                  <td class="py-2 px-2 text-center font-mono">{synthSteps}</td>
                  <td class="py-2 px-2 text-center font-mono text-cyan-400">{receptorCount}</td>
                  <td class="py-2 px-2 text-center font-mono text-amber-400">{cofactorCount}</td>
                  <td class="py-2 px-2 text-[10px] text-[var(--color-text-faint)]">{enzymes.join(', ') || '—'}</td>
                  <td class="py-2 px-2">
                    <div class="flex flex-wrap gap-1">
                      {bands.slice(0, 4).map((b: string) => (
                        <span class="text-[9px] font-mono px-1 py-0.5 rounded" style={`background: ${bandColors[b] || '#666'}20; color: ${bandColors[b] || '#666'}`}>{b}</span>
                      ))}
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="glass rounded-lg p-4 text-center">
        <p class="text-xl font-bold font-[family-name:var(--font-mono)] text-green-400">{totalNeurotransmitters}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] uppercase tracking-wider mt-1">Neurotransmitters</p>
      </div>
      <div class="glass rounded-lg p-4 text-center">
        <p class="text-xl font-bold font-[family-name:var(--font-mono)] text-cyan-400">{totalReceptors}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] uppercase tracking-wider mt-1">Receptor Subtypes</p>
      </div>
      <div class="glass rounded-lg p-4 text-center">
        <p class="text-xl font-bold font-[family-name:var(--font-mono)] text-amber-400">{totalCofactors}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] uppercase tracking-wider mt-1">Cofactor Dependencies</p>
      </div>
      <div class="glass rounded-lg p-4 text-center">
        <p class="text-xl font-bold font-[family-name:var(--font-mono)] text-purple-400">{totalSynthSteps}</p>
        <p class="text-[10px] text-[var(--color-text-faint)] uppercase tracking-wider mt-1">Synthesis Steps</p>
      </div>
    </div>
  </div>

  <!-- KQL Query Engine -->
  <div class="mt-16">
    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-px" style="background: var(--color-border);" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono" style="color: var(--color-text-faint);">Query Engine</span>
      <div class="flex-1 h-px" style="background: var(--color-border);" />
    </div>
    <BciKql client:only="react" tables={kqlTables} />
  </div>

  <!-- Footer -->
  <div class="mt-12 mb-4 text-center">
    <p class="text-xs" style="color: var(--color-text-faint);">
      Data compiled from {clinicalData.stats.totalPathways} neural pathways, {clinicalData.stats.totalNeurotransmitters} neurotransmitters, {clinicalData.stats.totalRegions} brain regions.
      <a href="/atlas/" class="underline ml-1">Back to Atlas</a> &middot;
      <a href="/atlas/tara/" class="underline">TARA</a> &middot;
      <a href="/atlas/therapeutics/" class="underline">Therapeutics</a>
    </p>
    <p class="text-[10px] font-mono mt-2 tracking-[0.08em]" style="color: var(--color-text-faint);">
      PROPOSED FRAMEWORK &middot; NOT VALIDATED &middot; OPEN TO CRITIQUE
    </p>
  </div>
</PageLayout>
