  .matrix-corner, .matrix-rowlabel { background: #ffffff; }
  .matrix-cell-summary:hover { background: rgba(255, 255, 255, 0.04); }
  .matrix-cell details[open] > .matrix-cell-summary { background: rgba(255, 255, 255, 0.04); border-bottom: none; border-radius: 0.375rem 0.375rem 0 0; }
  .matrix-cell details[open] { background: rgba(255, 255, 255, 0.02); border-radius: 0.375rem; border: 1px solid var(--color-border); }
