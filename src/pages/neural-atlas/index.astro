---
import PageLayout from '@/layouts/PageLayout.astro';
import { HOURGLASS_BANDS } from '@/lib/qif-constants';
import { THREAT_VECTORS, NEURORIGHT_LABELS } from '@/lib/threat-data';

// Pick QIF-T0001: Signal Injection — CONFIRMED, dual-use confirmed, therapeutic analog, DSM-5, neurorights
const technique = THREAT_VECTORS.find(t => t.id === 'QIF-T0001')!;
const tara = technique.tara!;
const dsm5 = tara.dsm5!;
const clinical = tara.clinical!;
const neurorights = (technique as any).neurorights;

// NISS metric labels
const nissMetrics = [
  { key: 'BI', label: 'Biological Impact', value: 'H' },
  { key: 'CR', label: 'Cognitive Reach', value: 'H' },
  { key: 'CD', label: 'Clinical Disruption', value: 'H' },
  { key: 'CV', label: 'Consent Violation', value: 'E' },
  { key: 'RV', label: 'Reversibility', value: 'P' },
  { key: 'NP', label: 'Neural Persistence', value: 'T' },
];

// Parse NISS vector to get actual values
const vectorParts = technique.niss.vector.split('/').slice(1);
const nissValues = {} as any;
for (const part of vectorParts) {
  const [k, v] = part.split(':');
  nissValues[k] = v;
}
for (const m of nissMetrics) {
  m.value = nissValues[m.key] || m.value;
}

// Value scale for bar widths
const valueScale = { N: 0, L: 25, M: 50, H: 75, E: 90, P: 60, T: 40, C: 100 } as any;

// Affected neurorights (filter to 4 core)
const coreRights = ['MP', 'CL', 'MI', 'PC'] as const;
const affectedRights = neurorights?.affected?.filter((r: string) => coreRights.includes(r as any)) ?? [];

// Band info for the technique
const techBands = technique.bands.map(id => HOURGLASS_BANDS.find(b => b.id === id)!).filter(Boolean);

// Total technique count for CTA
const totalTechniques = THREAT_VECTORS.length;
---

<PageLayout
  title="Neural Atlas — Your First 60 Seconds"
  description="A guided walkthrough of one real BCI attack technique. Understand the hourglass model, NISS scoring, and TARA dual-use mapping, then launch the full Neural Atlas dashboard."
  breadcrumbs={[{ label: 'Atlas', href: '/atlas/' }, { label: 'Neural Atlas' }]}
>
  <!-- Hero -->
  <section class="mb-16 reveal">
    <div class="text-center max-w-3xl mx-auto">
      <p class="text-xs font-mono tracking-[0.15em] uppercase mb-4" style="color: var(--color-accent-secondary);">Guided Walkthrough</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold font-[family-name:var(--font-heading)] mb-5" style="color: var(--color-text-primary);">
        Your First 60 Seconds with the Neural Security Atlas
      </h1>
      <p class="text-base sm:text-lg leading-relaxed" style="color: var(--color-text-muted);">
        Before you explore {totalTechniques} techniques across 8 views, let's walk through one.
        By the end of this page, you'll understand the hourglass model, how a technique is scored,
        and where to go next.
      </p>
    </div>
  </section>

  <!-- Section: The Hourglass in 30 Seconds -->
  <section class="mb-20 reveal">
    <div class="flex items-center gap-3 mb-8">
      <div class="flex-1 h-px" style="background: linear-gradient(to right, transparent, var(--color-border), var(--color-accent-primary), var(--color-border));" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono px-3 py-1 rounded-full" style="color: var(--color-accent-primary); background: rgba(59, 130, 246, 0.06); border: 1px solid rgba(59, 130, 246, 0.12);">[ The Model ]</span>
      <div class="flex-1 h-px" style="background: linear-gradient(to left, transparent, var(--color-border), var(--color-accent-primary), var(--color-border));" />
    </div>

    <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-3 text-center" style="color: var(--color-text-primary);">The Hourglass in 30 Seconds</h2>
    <p class="text-sm text-center mb-10 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      QIF maps every BCI attack surface across 11 bands, organized into three zones.
      Signals flow from biology through the interface into silicon, and threats can target any layer.
    </p>

    <!-- Simplified Hourglass -->
    <div class="max-w-md mx-auto space-y-1">
      <!-- Neural Zone -->
      <div class="text-center mb-2">
        <span class="text-[10px] font-mono uppercase tracking-[0.12em] px-2 py-0.5 rounded-full" style="background: rgba(34, 197, 94, 0.08); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.15);">Neural Zone</span>
      </div>
      {HOURGLASS_BANDS.filter(b => b.zone === 'neural').map((band, i) => {
        const widths = [92, 84, 74, 64, 56, 46, 38];
        const isHighlighted = technique.bands.includes(band.id as any);
        return (
          <div class="flex items-center justify-center">
            <div
              class:list={["rounded-md py-1.5 px-3 text-center transition-all duration-300", isHighlighted ? "ring-2" : ""]}
              style={`width: ${widths[i]}%; background: ${isHighlighted ? 'rgba(34, 197, 94, 0.15)' : 'rgba(34, 197, 94, 0.05)'}; border: 1px solid ${isHighlighted ? 'rgba(34, 197, 94, 0.4)' : 'rgba(34, 197, 94, 0.1)'}; ${isHighlighted ? 'ring-color: rgba(34, 197, 94, 0.3); box-shadow: 0 0 12px rgba(34, 197, 94, 0.1);' : ''}`}
            >
              <span class="text-[10px] font-mono" style={`color: ${isHighlighted ? '#22c55e' : 'var(--color-text-faint)'};`}>{band.id}</span>
              <span class="text-[11px] ml-1.5" style={`color: ${isHighlighted ? '#22c55e' : 'var(--color-text-faint)'};`}>{band.name}</span>
            </div>
          </div>
        );
      })}
      <p class="text-[11px] text-center pt-1" style="color: var(--color-text-faint);">Neocortex down to spinal cord. 7 biological layers.</p>

      <!-- Interface Zone -->
      <div class="text-center pt-3 pb-1">
        <span class="text-[10px] font-mono uppercase tracking-[0.12em] px-2 py-0.5 rounded-full" style="background: rgba(245, 158, 11, 0.08); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.15);">Interface Zone</span>
      </div>
      <div class="flex items-center justify-center">
        <div
          class="rounded-md py-2.5 px-3 text-center ring-2"
          style={`width: 30%; background: rgba(245, 158, 11, 0.15); border: 1px solid rgba(245, 158, 11, 0.4); ring-color: rgba(245, 158, 11, 0.3); box-shadow: 0 0 16px rgba(245, 158, 11, 0.12);`}
        >
          <span class="text-[10px] font-mono font-bold" style="color: #f59e0b;">I0</span>
          <span class="text-[11px] ml-1.5 font-medium" style="color: #f59e0b;">Neural Interface</span>
        </div>
      </div>
      <p class="text-[11px] text-center pt-1" style="color: var(--color-text-faint);">Where electrode meets brain. The narrowest point. The highest-risk boundary.</p>

      <!-- Silicon Zone -->
      <div class="text-center pt-3 pb-1">
        <span class="text-[10px] font-mono uppercase tracking-[0.12em] px-2 py-0.5 rounded-full" style="background: rgba(59, 130, 246, 0.08); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.15);">Silicon Zone</span>
      </div>
      {HOURGLASS_BANDS.filter(b => b.zone === 'synthetic').map((band, i) => {
        const widths = [46, 60, 76];
        const isHighlighted = technique.bands.includes(band.id as any);
        return (
          <div class="flex items-center justify-center">
            <div
              class:list={["rounded-md py-1.5 px-3 text-center transition-all duration-300", isHighlighted ? "ring-2" : ""]}
              style={`width: ${widths[i]}%; background: ${isHighlighted ? 'rgba(59, 130, 246, 0.15)' : 'rgba(59, 130, 246, 0.05)'}; border: 1px solid ${isHighlighted ? 'rgba(59, 130, 246, 0.4)' : 'rgba(59, 130, 246, 0.1)'}; ${isHighlighted ? 'ring-color: rgba(59, 130, 246, 0.3); box-shadow: 0 0 12px rgba(59, 130, 246, 0.1);' : ''}`}
            >
              <span class="text-[10px] font-mono" style={`color: ${isHighlighted ? '#3b82f6' : 'var(--color-text-faint)'};`}>{band.id}</span>
              <span class="text-[11px] ml-1.5" style={`color: ${isHighlighted ? '#3b82f6' : 'var(--color-text-faint)'};`}>{band.name}</span>
            </div>
          </div>
        );
      })}
      <p class="text-[11px] text-center pt-1" style="color: var(--color-text-faint);">Hardware, firmware, and wireless. 3 synthetic layers.</p>
    </div>
  </section>

  <!-- Section: One Real Attack -->
  <section class="mb-20 reveal">
    <div class="flex items-center gap-3 mb-8">
      <div class="flex-1 h-px" style="background: linear-gradient(to right, transparent, var(--color-border), #ef4444, var(--color-border));" />
      <span class="text-[10px] uppercase tracking-[0.12em] font-mono px-3 py-1 rounded-full" style="color: #ef4444; background: rgba(239, 68, 68, 0.06); border: 1px solid rgba(239, 68, 68, 0.12);">[ Worked Example ]</span>
      <div class="flex-1 h-px" style="background: linear-gradient(to left, transparent, var(--color-border), #ef4444, var(--color-border));" />
    </div>

    <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-3 text-center" style="color: var(--color-text-primary);">One Real Technique: {technique.name}</h2>
    <p class="text-sm text-center mb-10 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      Every technique in the atlas is scored, mapped, and traced the same way.
      Here's how it works, end-to-end.
    </p>

    <div class="max-w-3xl mx-auto space-y-8">

      <!-- What happens -->
      <div class="glass rounded-xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(239, 68, 68, 0.1);">
            <svg class="w-4 h-4" style="color: #ef4444;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
          </div>
          <h3 class="text-base font-bold" style="color: var(--color-text-primary);">What happens</h3>
          <span class="text-[9px] font-mono px-2 py-0.5 rounded-full ml-auto" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">{technique.id}</span>
          <span class="text-[9px] font-mono px-2 py-0.5 rounded-full" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">{technique.status}</span>
        </div>
        <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">
          {technique.description}
        </p>
        <p class="text-xs mt-3" style="color: var(--color-text-faint);">
          Mechanism: {tara.mechanism}
        </p>
      </div>

      <!-- Which bands -->
      <div class="glass rounded-xl p-6">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(245, 158, 11, 0.1);">
            <svg class="w-4 h-4" style="color: #f59e0b;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
            </svg>
          </div>
          <h3 class="text-base font-bold" style="color: var(--color-text-primary);">Which bands</h3>
        </div>
        <div class="flex flex-wrap gap-2">
          {techBands.map(band => (
            <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg" style={`background: ${band.zone === 'neural' ? 'rgba(34, 197, 94, 0.08)' : band.zone === 'interface' ? 'rgba(245, 158, 11, 0.08)' : 'rgba(59, 130, 246, 0.08)'}; border: 1px solid ${band.zone === 'neural' ? 'rgba(34, 197, 94, 0.2)' : band.zone === 'interface' ? 'rgba(245, 158, 11, 0.2)' : 'rgba(59, 130, 246, 0.2)'};`}>
              <span class="text-[10px] font-mono font-bold" style={`color: ${band.color};`}>{band.id}</span>
              <span class="text-xs" style="color: var(--color-text-muted);">{band.name}</span>
            </div>
          ))}
        </div>
        <p class="text-xs mt-3" style="color: var(--color-text-faint);">
          This technique targets the electrode-tissue boundary (I0) and spinal cord relay (N1). It sits right at the hourglass neck, the highest-risk zone.
        </p>
      </div>

      <!-- NISS Score -->
      <div class="glass rounded-xl p-6">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(139, 92, 246, 0.1);">
            <svg class="w-4 h-4" style="color: #8b5cf6;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
            </svg>
          </div>
          <h3 class="text-base font-bold" style="color: var(--color-text-primary);">NISS Score: {technique.niss.score}</h3>
          <span class="text-[9px] font-mono px-2 py-0.5 rounded-full ml-auto" style={`background: ${technique.niss.severity === 'high' ? 'rgba(245, 158, 11, 0.12)' : technique.niss.severity === 'critical' ? 'rgba(239, 68, 68, 0.12)' : 'rgba(234, 179, 8, 0.12)'}; color: ${technique.niss.severity === 'high' ? '#f59e0b' : technique.niss.severity === 'critical' ? '#ef4444' : '#eab308'};`}>
            {technique.niss.severity.toUpperCase()}
          </span>
        </div>
        <p class="text-xs mb-4" style="color: var(--color-text-faint);">
          NISS extends CVSS with 6 neural-specific metrics. Each captures a dimension that traditional vulnerability scoring cannot express.
        </p>
        <div class="space-y-2.5">
          {nissMetrics.map(m => {
            const width = valueScale[m.value] || 50;
            const barColor = width >= 75 ? '#ef4444' : width >= 50 ? '#f59e0b' : '#94a3b8';
            return (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs" style="color: var(--color-text-muted);">{m.label}</span>
                  <span class="text-[10px] font-mono" style={`color: ${barColor};`}>{m.key}:{m.value}</span>
                </div>
                <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--color-glass-bg);">
                  <div class="h-full rounded-full transition-all duration-700" style={`width: ${width}%; background: ${barColor};`} />
                </div>
              </div>
            );
          })}
        </div>
        <p class="text-[10px] font-mono mt-4 px-3 py-1.5 rounded-lg" style="color: var(--color-text-faint); background: var(--color-glass-bg);">
          Vector: {technique.niss.vector}
        </p>
      </div>

      <!-- Neurorights Affected -->
      <div class="glass rounded-xl p-6">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(168, 85, 247, 0.1);">
            <svg class="w-4 h-4" style="color: #a855f7;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
            </svg>
          </div>
          <h3 class="text-base font-bold" style="color: var(--color-text-primary);">Proposed Neurorights Affected</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {coreRights.map(code => {
            const isAffected = affectedRights.includes(code);
            const labels = {
              MP: 'The right to keep neural data private.',
              CL: 'The right to free and unmanipulated thought.',
              MI: 'The right to protection from harmful neural interference.',
              PC: 'The right to continuity of personal identity over time.',
            };
            return (
              <div class="rounded-lg px-3 py-2.5" style={`background: ${isAffected ? 'rgba(168, 85, 247, 0.06)' : 'var(--color-glass-bg)'}; border: 1px solid ${isAffected ? 'rgba(168, 85, 247, 0.2)' : 'var(--color-glass-border)'};`}>
                <div class="flex items-center gap-2 mb-1">
                  <span class="w-1.5 h-1.5 rounded-full" style={`background: ${isAffected ? '#a855f7' : 'var(--color-text-faint)'};`} />
                  <span class="text-xs font-bold" style={`color: ${isAffected ? '#a855f7' : 'var(--color-text-faint)'};`}>{(NEURORIGHT_LABELS as any)[code]}</span>
                </div>
                <p class="text-[11px] leading-relaxed" style={`color: ${isAffected ? 'var(--color-text-muted)' : 'var(--color-text-faint)'};`}>{labels[code]}</p>
              </div>
            );
          })}
        </div>
        <p class="text-[10px] mt-3" style="color: var(--color-text-faint);">
          Proposed neurorights per Ienca & Andorno (2017). These are contested concepts that lack agreed operational definitions.
        </p>
      </div>

      <!-- Therapeutic Mirror -->
      <div class="glass rounded-xl p-6" style="border-color: rgba(16, 185, 129, 0.15);">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(16, 185, 129, 0.1);">
            <svg class="w-4 h-4" style="color: #10b981;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          </div>
          <h3 class="text-base font-bold" style="color: var(--color-text-primary);">Therapeutic Mirror</h3>
          <span class="text-[9px] font-mono px-2 py-0.5 rounded-full ml-auto" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">DUAL-USE {tara.dual_use.toUpperCase()}</span>
        </div>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-muted);">
          The same mechanism used in this attack is also used therapeutically as <strong style="color: var(--color-text-primary);">{clinical.therapeutic_analog}</strong>
          to treat {clinical.conditions.join(', ')}.
        </p>
        <p class="text-sm leading-relaxed mb-3" style="color: var(--color-text-muted);">
          The difference is consent, dosage, and oversight. Safe parameters: {clinical.safe_parameters}.
        </p>
        <div class="flex flex-wrap gap-2 mt-3">
          <span class="text-[9px] font-mono px-2 py-0.5 rounded-full" style="background: rgba(16, 185, 129, 0.08); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.15);">FDA: {clinical.fda_status.toUpperCase()}</span>
          <span class="text-[9px] font-mono px-2 py-0.5 rounded-full" style="background: rgba(16, 185, 129, 0.08); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.15);">Evidence: {clinical.evidence_level}</span>
        </div>
      </div>

      <!-- DSM-5 Analog -->
      <div class="glass rounded-xl p-6" style="border-color: rgba(234, 179, 8, 0.15);">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center" style="background: rgba(234, 179, 8, 0.1);">
            <svg class="w-4 h-4" style="color: #eab308;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
            </svg>
          </div>
          <h3 class="text-base font-bold" style="color: var(--color-text-primary);">DSM-5-TR Symptom Analog</h3>
        </div>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-muted);">
          If this attack succeeded, the resulting symptoms would correspond to these diagnostic categories, for threat modeling purposes:
        </p>
        <div class="space-y-2">
          {dsm5.primary.map((d: any) => (
            <div class="flex items-center gap-2 px-3 py-2 rounded-lg" style="background: rgba(234, 179, 8, 0.05); border: 1px solid rgba(234, 179, 8, 0.12);">
              <span class="text-[10px] font-mono font-bold" style="color: #eab308;">{d.code}</span>
              <span class="text-xs" style="color: var(--color-text-muted);">{d.name}</span>
              <span class="text-[9px] font-mono px-1.5 py-0.5 rounded-full ml-auto" style="background: rgba(234, 179, 8, 0.08); color: #eab308;">{d.confidence}</span>
            </div>
          ))}
        </div>
        <p class="text-xs mt-3 px-3 py-2 rounded-lg" style="color: var(--color-text-faint); background: rgba(234, 179, 8, 0.03); border: 1px solid rgba(234, 179, 8, 0.08);">
          These are diagnostic category references for threat modeling, not diagnostic predictions.
          The Neural Impact Chain is a threat modeling tool, not a clinical instrument.
        </p>
      </div>

      <!-- Deep-dive link -->
      <div class="text-center">
        <a href={`/TARA/${technique.id}/`} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium transition-all hover:scale-[1.02]" style="background: var(--color-glass-bg); border: 1px solid var(--color-border); color: var(--color-text-primary);">
