---
import PageLayout from '@/layouts/PageLayout.astro';
import { HOURGLASS_BANDS, HOURGLASS_WIDTHS, QIF_VERSION, TARA_TECHNIQUES } from '@/lib/qif-constants';
import { THREAT_VECTORS, THREAT_TACTICS, THREAT_DOMAINS, getTacticsWithCounts } from '@/lib/threat-data';

const tacticsWithCounts = getTacticsWithCounts();
const totalTechniques = THREAT_VECTORS.length;
const totalTactics = THREAT_TACTICS.length;
const totalDomains = (THREAT_DOMAINS as any[]).length;

const tacticColors: Record<string, string> = {
  'N': '#06b6d4',   // Neural → cyan
  'C': '#f59e0b',   // Cognitive → amber
  'P': '#ef4444',   // Physiological → red
  'D': '#06b6d4',   // Data → cyan
  'B': '#8b5cf6',   // BCI System → violet
  'M': '#10b981',   // Model → emerald
  'E': '#f97316',   // Energy → orange
};
---

<PageLayout
  title="QIF Framework"
  description="The Quantified Interconnection Framework — a proposed 11-band hourglass security architecture for brain-computer interfaces."
  breadcrumbs={[{ label: 'Framework' }]}
  maxWidth="wide"
>
  <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-12">
    <!-- Sidebar (sticky TOC) -->
    <aside class="hidden lg:block">
      <nav class="sticky top-24 space-y-1" aria-label="Table of contents">
        <p class="text-xs font-semibold tracking-wider uppercase text-[var(--color-text-faint)] mb-3">On this page</p>
        {[
          { href: '#question', label: 'Research Question' },
          { href: '#derivation', label: 'Derivation' },
          { href: '#hourglass', label: 'Hourglass Model' },
          { href: '#bands', label: '11 Bands' },
          { href: '#threat-model', label: 'Threat Model' },
          { href: '#taxonomy', label: 'TARA Taxonomy' },
          { href: '#niss', label: 'NISS Scoring' },
          { href: '#signal-integrity', label: 'Signal Integrity' },
          { href: '#status', label: 'Status & Limitations' },
          { href: '#documents', label: 'Documents' },
        ].map((item) => (
          <a href={item.href} class="block text-sm py-1.5 text-[var(--color-text-muted)] hover:text-[var(--color-accent-primary)] transition-colors border-l-2 border-transparent hover:border-[var(--color-accent-primary)] pl-3">
            {item.label}
          </a>
        ))}
      </nav>
    </aside>

    <!-- Main content -->
    <div class="max-w-3xl">
      <!-- Research Question -->
      <section id="question" class="mb-20">
        <h1 class="text-3xl sm:text-4xl font-bold font-[family-name:var(--font-heading)] mb-6">
          QIF Framework <span class="text-[var(--color-accent-primary)]">v{QIF_VERSION}</span>
        </h1>
        <div class="prose">
          <p class="text-lg text-[var(--color-text-muted)]">
            I asked what the future of neurosecurity would look like.
          </p>
          <p>
            Neural interfaces connect digital systems to the human nervous system. Existing cybersecurity models (OSI, Zero Trust, STRIDE) handle synthetic systems. Existing neuroethics frameworks handle consent, privacy, and cognitive liberty. Neither addresses the engineering question at the boundary: <em>how do you secure a system where one endpoint is a brain?</em>
          </p>
          <p>
            The <strong>Quantified Interconnection Framework (QIF)</strong> is a proposed open security framework that attempts to bridge this gap. It defines a threat model and security architecture for the interface between silicon and neuron, built on three proposed systems:
          </p>
          <ul>
            <li><strong>TARA Atlas</strong> (Therapeutic Applications &amp; Risk Assessment) — a proposed dual-use atlas that classifies each BCI technique as both a security threat and a potential therapeutic application, with mappings to DSM-5-TR psychiatric diagnostic categories (for threat modeling purposes, not diagnostic claims)</li>
            <li><strong>NISS</strong> (Neural Impact Scoring System) — a proposed CVSS v4.0 extension adding six neural-specific metrics: biological impact, cognitive reconnaissance, cognitive disruption, consent violation, reversibility, and neuroplasticity</li>
            <li><strong>NSP</strong> (Neural Sensory Protocol) — a proposed five-layer, post-quantum wire protocol for securing BCI data links (hardware validation pending)</li>
          </ul>
        </div>
      </section>

      <!-- Derivation -->
      <section id="derivation" class="mb-20">
        <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-6">Derivation</h2>
        <div class="prose mb-8">
          <p>
            QIF's hourglass architecture was derived by finding a structural pattern across three independent models — each spanning approximately 7-8 layers, each covering roughly one order of magnitude per layer in spatial scale. The hourglass is where networking meets neuroscience at the physical interface.
          </p>
        </div>

        <div class="grid sm:grid-cols-3 gap-4 mb-8">
          <div class="glass rounded-xl p-6" style="border-top: 3px solid #3b82f6;">
            <div class="text-sm font-bold font-[family-name:var(--font-mono)] text-[#3b82f6] mb-2">01</div>
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2">OSI Model</h3>
            <p class="text-xs text-[var(--color-text-faint)] mb-3">ISO/IEC 7498-1, 1984</p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              The 7-layer networking stack. The pedagogical starting point for thinking about layered security — proving that complex systems become manageable when decomposed into well-defined abstraction boundaries.
            </p>
          </div>
          <div class="glass rounded-xl p-6" style="border-top: 3px solid #10b981;">
            <div class="text-sm font-bold font-[family-name:var(--font-mono)] text-[#10b981] mb-2">02</div>
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2">Kandel's Nervous System Hierarchy</h3>
            <p class="text-xs text-[var(--color-text-faint)] mb-3">Eric Kandel et al., <em>Principles of Neural Science</em></p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              The 7-level CNS organization from molecular to whole-brain. The neuroscience foundation for QIF's neural bands — demonstrating that the nervous system itself is a layered architecture with distinct security surfaces at each level.
            </p>
          </div>
          <div class="glass rounded-xl p-6" style="border-top: 3px solid #f59e0b;">
            <div class="text-sm font-bold font-[family-name:var(--font-mono)] text-[#f59e0b] mb-2">03</div>
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2">Campbell's Biology</h3>
            <p class="text-xs text-[var(--color-text-faint)] mb-3">Campbell et al., <em>Biology</em></p>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              The 8-level biological organization from atoms to organisms. Cross-domain validation that layered architecture is a recurring organizing principle — not just an engineering convenience, but a pattern that nature converges on independently.
            </p>
          </div>
        </div>

        <!-- OSI Consolidation Gap Callout -->
        <div class="glass rounded-xl p-6 border-l-4 border-[#3b82f6]">
          <h3 class="text-sm font-bold uppercase text-[var(--color-text-faint)] mb-2">Honest Derivation Note: OSI Consolidation</h3>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            QIF consolidates the OSI model's 7 layers into 3 synthetic bands (S1-S3). This is a design choice, not a discovery. The consolidation trades granularity for a shape that emphasizes the neural-synthetic boundary — the point where digital signals become neural stimulation and vice versa. A reasonable reviewer could argue that more granular synthetic layering is needed for certain use cases. QIF's 3-band synthetic zone is optimized for threat modeling at the interface, not for full-stack networking analysis.
          </p>
        </div>
      </section>

      <!-- Hourglass Model (Static CSS) -->
      <section id="hourglass" class="mb-20">
        <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-6">The Hourglass Model</h2>
        <div class="prose mb-8">
          <p>
            QIF v{QIF_VERSION} organizes BCI security into a proposed <strong>11-band hourglass</strong> — a 7-1-3 asymmetric architecture. The physical BCI device sits at the <strong>waist</strong> (I0, the Neural Interface), with seven neural bands above and three synthetic bands below.
          </p>
          <p>
            This topology mirrors how BCIs actually work: signals travel up from hardware through protocols to the brain, and commands travel down from cognition through processing to the device. The hourglass narrows at the exact point where biology meets synthetic systems — the most critical attack surface.
          </p>
        </div>

        <!-- Static CSS hourglass -->
        <div class="my-12">
          <div class="max-w-lg mx-auto space-y-3">
            {HOURGLASS_BANDS.map((band, i) => {
              const width = HOURGLASS_WIDTHS[i];
              return (
                <div
                  class="glass rounded-lg p-5 mx-auto transition-all hover:scale-[1.02]"
                  style={`max-width: ${width}%; border-left: 3px solid ${band.color};`}
                >
                  <div class="flex items-center gap-3">
                    <span class="text-xs font-bold font-[family-name:var(--font-mono)]" style={`color: ${band.color};`}>{band.id}</span>
                    <span class="text-sm font-semibold">{band.name}</span>
                    <span class="text-xs px-2 py-0.5 rounded-full border border-[var(--color-border)] text-[var(--color-text-faint)] ml-auto">
                      {band.zone}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Band Details -->
      <section id="bands" class="mb-20">
        <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-6">The 11 Bands</h2>
        <div class="space-y-8">
          {HOURGLASS_BANDS.map((band) => (
            <div class="glass rounded-xl p-6" style={`border-left: 3px solid ${band.color};`}>
              <div class="flex items-center gap-3 mb-3">
                <span class="text-sm font-bold font-[family-name:var(--font-mono)]" style={`color: ${band.color};`}>{band.id}</span>
                <h3 class="text-lg font-semibold font-[family-name:var(--font-heading)]">{band.name}</h3>
                <span class="text-xs px-2 py-0.5 rounded-full border border-[var(--color-border)] text-[var(--color-text-faint)] ml-auto">
                  {band.zone}
                </span>
              </div>
              <p class="text-sm text-[var(--color-text-muted)]">{band.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Threat Model -->
      <section id="threat-model" class="mb-20">
        <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-6">Threat Model</h2>
        <div class="prose mb-8">
          <p>
            QIF defines threat vectors at each band of the hourglass. The model spans from physical hardware attacks (S3) through protocol exploitation (S1), neural signal manipulation (N1-N5), and cognitive integrity threats (N6-N7).
          </p>
          <p>
            The Neural Interface (I0) represents the highest-risk surface — where digital signals become neural stimulation and neural readings become digital data. Every attack that crosses this boundary is potentially irreversible in ways that traditional cybersecurity does not encounter.
          </p>
        </div>

        <h3 id="taxonomy" class="text-lg font-semibold font-[family-name:var(--font-heading)] mb-4">TARA Atlas</h3>
        <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-accent-primary)] mb-4">Therapeutic Applications &amp; Risk Assessment &ensp;|&ensp; Proposed by Qinnovate</p>
        <div class="prose mb-6">
          <p>
            TARA is a proposed dual-use atlas where every entry is simultaneously a security threat, a clinical risk, and a potential therapeutic application. It is a proposed classification system designed for neural interfaces, organizing {totalTechniques} techniques by the anatomical or functional <em>locus</em> where they operate, across {totalDomains} domains and {totalTactics} tactics using a <code>QIF-[Domain].[Action]</code> format.
          </p>
          <p>
            Beyond threat classification, TARA maps each technique through four projections: modality (attack severity and coupling mechanism), clinical (therapeutic analog, FDA status, treated conditions), diagnostic (DSM-5-TR psychiatric diagnostic category references via the <a href="/research/whitepaper/#neural-impact">Neural Impact Chain</a>, for threat modeling purposes), and governance (consent tier and regulatory requirements).
          </p>
          <p>
            The taxonomy format (QIF-T0001 etc.) is designed for compatibility with MITRE ATT&CK-style technique IDs, though no formal MITRE affiliation or endorsement exists.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-8">
          {tacticsWithCounts.map((t) => {
            const color = tacticColors[t.domain_code] ?? '#94a3b8';
            return (
              <div class="glass rounded-lg p-3" style={`border-left: 3px solid ${color};`}>
                <div class="flex items-center justify-between">
                  <span class="text-xs font-bold font-[family-name:var(--font-mono)]" style={`color: ${color};`}>{t.id}</span>
                  <span class="text-xs font-[family-name:var(--font-mono)] text-[var(--color-text-faint)]">{t.count}</span>
                </div>
                <div class="text-sm font-medium mt-1">{t.name}</div>
              </div>
            );
          })}
        </div>

        <h3 id="niss" class="text-lg font-semibold font-[family-name:var(--font-heading)] mb-4">NISS v1.1 Scoring</h3>
        <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-accent-primary)] mb-4">A Proposed CVSS v4.0 Extension for Neural Security &ensp;|&ensp; by Qinnovate</p>
        <div class="prose mb-6">
          <p>
            Each technique is scored using <strong>NISS</strong> (Neural Impact Scoring System), a proposed CVSS v4.0 extension designed for neural security. Following FIRST.org's extension framework (CVSS v4.0 User Guide, Section 3.11), NISS adds six neural-specific dimensions that CVSS structurally cannot express: Biological Impact, Cognitive Reconnaissance (read-side attacks), Cognitive/Functional Disruption (write-side attacks), Consent Violation, Reversibility, and Neuroplasticity. All TARA techniques have been mapped to both CVSS v4.0 base vectors and MITRE ATT&amp;CK-style technique IDs, showing that 94.4% require NISS extension metrics for full-fidelity scoring.
          </p>
        </div>

        <!-- FIRST.org SIG Context -->
        <div class="glass rounded-xl p-6 border-l-4 border-[var(--color-accent-secondary)] mb-6">
          <h4 class="text-sm font-bold uppercase text-[var(--color-text-faint)] mb-2">FIRST.org CVSS SIG Context</h4>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
            NISS has been submitted as a formal proposal to the FIRST.org CVSS Special Interest Group for consideration as a registered CVSS v4.0 extension. This does not constitute endorsement or adoption by FIRST.org. The SIG process evaluates whether proposals meet the structural requirements of Section 3.11. NISS is currently in the proposal stage.
          </p>
        </div>

        <div class="glass rounded-xl p-6 mb-8">
          <p class="text-center font-[family-name:var(--font-mono)] text-[var(--color-accent-tertiary)] mb-4">
            NISS = (BI + CR + CD + CV + RV + NP) / 6
          </p>
          <div class="grid grid-cols-6 gap-3 text-center text-xs">
            <div>
              <div class="text-sm font-bold font-[family-name:var(--font-heading)] text-[var(--color-accent-primary)]">BI</div>
              <div class="text-[var(--color-text-faint)]">Biological Impact</div>
              <div class="text-[var(--color-text-muted)] mt-0.5">Weight 1.0</div>
            </div>
            <div>
              <div class="text-sm font-bold font-[family-name:var(--font-heading)] text-[var(--color-accent-primary)]">CR</div>
              <div class="text-[var(--color-text-faint)]">Cognitive Reconnaissance</div>
              <div class="text-[var(--color-text-muted)] mt-0.5">Weight 1.0</div>
            </div>
            <div>
              <div class="text-sm font-bold font-[family-name:var(--font-heading)] text-[var(--color-accent-primary)]">CD</div>
              <div class="text-[var(--color-text-faint)]">Cognitive/Functional Disruption</div>
              <div class="text-[var(--color-text-muted)] mt-0.5">Weight 1.0</div>
            </div>
            <div>
              <div class="text-sm font-bold font-[family-name:var(--font-heading)] text-[var(--color-accent-primary)]">CV</div>
              <div class="text-[var(--color-text-faint)]">Consent Violation</div>
              <div class="text-[var(--color-text-muted)] mt-0.5">Weight 1.0</div>
            </div>
            <div>
              <div class="text-sm font-bold font-[family-name:var(--font-heading)] text-[var(--color-accent-primary)]">RV</div>
              <div class="text-[var(--color-text-faint)]">Reversibility</div>
              <div class="text-[var(--color-text-muted)] mt-0.5">Weight 1.0</div>
            </div>
            <div>
              <div class="text-sm font-bold font-[family-name:var(--font-heading)] text-[var(--color-accent-primary)]">NP</div>
              <div class="text-[var(--color-text-faint)]">Neuroplasticity</div>
              <div class="text-[var(--color-text-muted)] mt-0.5">Weight 1.0</div>
            </div>
          </div>
        </div>

        <div class="prose">
          <p>
            For the complete scoring methodology, see the <a href="/atlas/scoring/">NISS Scoring page</a>. For the full technique atlas, explore the <a href="/atlas/tara/">TARA Atlas</a>. The complete taxonomy derivation and metric definitions are in the <a href="/research/whitepaper/#taxonomy">Whitepaper &sect;6.4&ndash;6.5</a>.
          </p>
        </div>
      </section>

      <!-- Signal Integrity (Future Work) -->
      <section id="signal-integrity" class="mb-20">
        <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-6">Signal Integrity</h2>
        <div class="prose mb-8">
          <p>
            QIF's security model depends on the ability to distinguish authentic neural signals from injected or manipulated ones. The framework identifies three key dimensions for signal validation: phase consistency, temporal stability, and spatial coherence across electrode channels.
          </p>
          <p>
            These dimensions draw on established physics — the wave equation, Boltzmann statistics, and Fries' Communication Through Coherence theory (2005/2015) — applied to the BCI security context. The mathematical formalization of how these combine into a composite signal integrity score is future work, pending collaboration with physicists and neuroscientists who can validate the approach against real hardware and biological data.
          </p>
        </div>

        <div class="glass rounded-xl p-6 border-l-4 border-[var(--color-accent-tertiary)]">
          <h3 class="text-sm font-bold uppercase text-[var(--color-text-faint)] mb-2">Future Work</h3>
          <p class="text-sm text-[var(--color-text-muted)]">
            Signal integrity calculations — including coherence scoring, frequency-band validation, and composite security metrics — will be developed through collaboration with domain experts in physics, neuroscience, and signal processing. Early explorations of these ideas are documented in the <a href="/research/whitepaper/" class="text-[var(--color-accent-primary)] hover:underline">Whitepaper</a> and <a href="/news/derivation/" class="text-[var(--color-accent-primary)] hover:underline">Derivation Log</a>.
          </p>
        </div>
      </section>

      <!-- Status & Limitations -->
      <section id="status" class="mb-20">
        <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-6">Status &amp; Limitations</h2>
        <div class="prose mb-8">
          <p>
            QIF, NISS, TARA, NSP, and all related components are proposed, unvalidated, and in development. They have not been adopted by any standards body, independently peer-reviewed, or replicated. The following table summarizes what has and has not been accomplished.
          </p>
        </div>

        <div class="glass rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[var(--color-border)]">
                <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wider text-[var(--color-text-faint)]">Evidence Type</th>
                <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wider text-[var(--color-text-faint)]">Status</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Literature synthesis (309+ verified sources)</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-status-safe)] font-medium">Complete</span></td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Threat taxonomy (TARA, {totalTechniques} techniques)</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-status-safe)] font-medium">Proposed</span></td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Severity scoring (NISS v1.1)</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-status-safe)] font-medium">Proposed</span></td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Simulation-based testing</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-status-safe)] font-medium">Yes (synthetic only)</span></td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Signal integrity / coherence metric</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-accent-secondary)] font-medium">Future work</span></td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Real-world adversarial validation</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-text-faint)]">No</span></td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Clinical validation</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-text-faint)]">No</span></td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Independent third-party audit</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-text-faint)]">No</span></td>
              </tr>
              <tr>
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Standards body adoption</td>
                <td class="px-5 py-3 text-right"><span class="text-[var(--color-text-faint)]">No</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Supporting Documents -->
      <section id="documents" class="mb-20">
        <h2 class="text-2xl font-bold font-[family-name:var(--font-heading)] mb-6">Supporting Documents</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/research/whitepaper/" class="glass rounded-xl p-6 block group hover:translate-y-[-2px] transition-transform">
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">QIF Whitepaper</h3>
            <p class="text-sm text-[var(--color-text-muted)]">Full derivation, taxonomy, and scoring methodology for the proposed framework.</p>
          </a>
          <a href="https://github.com/qinnovates/qinnovate/blob/main/qif-framework/qif-sec-guardrails.md" class="glass rounded-xl p-6 block group hover:translate-y-[-2px] transition-transform">
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">Security Guardrails</h3>
            <p class="text-sm text-[var(--color-text-muted)]">Physics-derived defense architecture for BCI systems, mapping signal integrity constraints to per-band protection rules.</p>
          </a>
          <a href="/atlas/tara/" class="glass rounded-xl p-6 block group hover:translate-y-[-2px] transition-transform">
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">TARA Atlas</h3>
            <p class="text-sm text-[var(--color-text-muted)]">Browse all {TARA_TECHNIQUES}+ techniques across the hourglass, filterable by category and severity.</p>
          </a>
          <a href="/guardrails/nsp/" class="glass rounded-xl p-6 block group hover:translate-y-[-2px] transition-transform">
            <h3 class="text-base font-semibold font-[family-name:var(--font-heading)] mb-2 group-hover:text-[var(--color-accent-secondary)] transition-colors">NSP Protocol</h3>
            <p class="text-sm text-[var(--color-text-muted)]">Post-quantum wire security for neural interfaces with signal-gated authentication.</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</PageLayout>
