---
interface Phase {
  id: string;
  techniques: string[];
  name: string;
  covidAnalog: string;
  ptsdAnalog: string;
  bands: string[];
  severity: string;
  color: string;
  neurorights: string[];
  population: string;
}

interface Props {
  phases: Phase[];
}

const { phases } = Astro.props;
const allBands = ['N1', 'N2', 'N3', 'N4', 'N5', 'N6', 'N7'];
---

<div class="attack-chain-flow flex flex-col items-center w-full" data-attack-chain>
  {phases.map((phase, i) => (
    <>
      {/* Phase Card */}
      <div
        class="acf-card glass rounded-xl p-6 w-full relative"
        style={`border-left: 4px solid ${phase.color}; --phase-color: ${phase.color}; --phase-index: ${i};`}
        data-severity={phase.severity}
      >
        {/* Phase ID Badge */}
        <span
          class="absolute top-3 left-3 text-[10px] font-bold font-[family-name:var(--font-mono)] px-2 py-0.5 rounded-full"
          style={`background: ${phase.color}20; color: ${phase.color};`}
        >
          Phase {phase.id}
        </span>

        {/* Technique Links */}
        <div class="flex flex-wrap gap-1.5 mt-5 mb-2">
          {phase.techniques.map((tech) => (
            <a
              href={`/threat-models/tara/QIF-${tech}/`}
              class="text-[10px] font-[family-name:var(--font-mono)] px-2 py-0.5 rounded border border-[var(--color-border)] text-[var(--color-accent-primary)] hover:bg-[var(--color-accent-primary)] hover:text-white transition-colors"
            >
              {tech}
            </a>
          ))}
        </div>

        {/* Phase Name */}
        <h3 class="text-lg font-semibold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] mb-3">
          {phase.name}
        </h3>

        {/* Two-Column Analogs */}
        <div class="grid sm:grid-cols-2 gap-4 mb-4">
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-3 py-2.5">
            <div class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-faint)] mb-1">
              COVID / Inflammatory
            </div>
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
              {phase.covidAnalog}
            </p>
          </div>
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-surface)] px-3 py-2.5">
            <div class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-faint)] mb-1">
              PTSD / Experiential
            </div>
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
              {phase.ptsdAnalog}
            </p>
          </div>
        </div>

        {/* Band Impact */}
        <div class="flex items-center gap-3 mb-3">
          <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-faint)]">
            Bands:
          </span>
          <div class="flex gap-1.5">
            {allBands.map((band, bi) => (
              <div class="flex flex-col items-center gap-0.5">
                <div
                  class="acf-band-dot w-3 h-3 rounded-full border"
                  style={
                    phase.bands.includes(band)
                      ? `--dot-color: ${phase.color}; --dot-index: ${bi}; background: transparent; border-color: #4b5563;`
                      : `background: transparent; border-color: #4b5563;`
                  }
                  data-active={phase.bands.includes(band) ? 'true' : 'false'}
                />
                <span class="text-[8px] text-[var(--color-text-faint)]">{band}</span>
              </div>
            ))}
          </div>
        </div>

        {/* Bottom Row: Neurorights + Population */}
        <div class="flex items-center justify-between">
          <div class="flex flex-wrap gap-1.5">
            {phase.neurorights.map((nr) => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 font-semibold">
                {nr}
              </span>
            ))}
          </div>
          <span class="acf-population text-xs text-[var(--color-text-faint)] font-[family-name:var(--font-mono)]">
            {phase.population}
          </span>
        </div>
      </div>

      {/* Downward Arrow Between Cards */}
      {i < phases.length - 1 && (
        <svg width="24" height="40" viewBox="0 0 24 40" class="acf-arrow my-1 shrink-0" aria-hidden="true">
          <line
            x1="12" y1="0" x2="12" y2="32"
            stroke={phases[i + 1].color}
            stroke-width="2"
            stroke-dasharray="32"
            stroke-dashoffset="32"
          />
          <polygon
            points="6,30 12,40 18,30"
            fill={phases[i + 1].color}
            opacity="0"
          />
        </svg>
      )}
    </>
  ))}

  {/* Feedback / Reinforcement Loop */}
  {phases.length > 1 && (
    <div class="relative w-full mt-2">
      <svg
        width="100%"
        height="120"
        viewBox="0 0 400 120"
        preserveAspectRatio="xMidYMid meet"
        class="acf-feedback-svg overflow-visible"
        aria-hidden="true"
      >
        <path
          class="acf-feedback-path"
          d="M 200,5 C 380,5 380,115 200,115"
          fill="none"
          stroke="#ef4444"
          stroke-width="2"
          stroke-dasharray="6 4"
        />
        <polygon class="acf-feedback-arrow" points="200,0 194,10 206,10" fill="#ef4444" opacity="0" />
        <text
          x="340" y="65"
          fill="#94a3b8" font-size="11" text-anchor="middle" font-family="sans-serif"
          class="acf-feedback-label"
        >
          Reinforcement
        </text>
        <text
          x="340" y="80"
          fill="#94a3b8" font-size="11" text-anchor="middle" font-family="sans-serif"
          class="acf-feedback-label"
        >
          Loop
        </text>
      </svg>
    </div>
  )}
</div>

<style>
  /* --- Card reveal: staggered slide-up --- */
  .acf-card {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  [data-attack-chain].revealed .acf-card {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--phase-index) * 150ms);
  }

  /* --- Pulsing severity border --- */
  @keyframes pulse-border {
    0%, 100% { border-left-color: var(--phase-color); }
    50% { border-left-color: color-mix(in srgb, var(--phase-color) 40%, transparent); }
  }
  [data-attack-chain].revealed .acf-card[data-severity="critical"] {
    animation: pulse-border 2s ease-in-out infinite;
    animation-delay: calc(var(--phase-index) * 150ms + 600ms);
  }
  [data-attack-chain].revealed .acf-card[data-severity="high"] {
    animation: pulse-border 3s ease-in-out infinite;
    animation-delay: calc(var(--phase-index) * 150ms + 600ms);
  }

  /* --- Band dots fill sequentially --- */
  .acf-band-dot[data-active="true"] {
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  [data-attack-chain].revealed .acf-band-dot[data-active="true"] {
    background: var(--dot-color) !important;
    border-color: var(--dot-color) !important;
    transition-delay: calc(var(--phase-index) * 150ms + var(--dot-index) * 80ms + 400ms);
  }

  /* --- Population text entrance --- */
  .acf-population {
    opacity: 0;
    transform: translateX(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  [data-attack-chain].revealed .acf-population {
    opacity: 1;
    transform: translateX(0);
    transition-delay: calc(var(--phase-index) * 150ms + 500ms);
  }

  /* --- Arrow path drawing --- */
  .acf-arrow line {
    transition: stroke-dashoffset 0.4s ease;
  }
  .acf-arrow polygon {
    transition: opacity 0.2s ease;
  }
  [data-attack-chain].revealed .acf-arrow line {
    stroke-dashoffset: 0;
  }
  [data-attack-chain].revealed .acf-arrow polygon {
    opacity: 1;
    transition-delay: 0.35s;
  }

  /* --- Feedback loop: continuous flowing dash --- */
  @keyframes feedback-flow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -40; }
  }
  .acf-feedback-path {
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  [data-attack-chain].revealed .acf-feedback-path {
    opacity: 1;
    animation: feedback-flow 4s linear infinite;
    transition-delay: 1.2s;
  }
  .acf-feedback-arrow {
    transition: opacity 0.4s ease;
  }
  [data-attack-chain].revealed .acf-feedback-arrow {
    opacity: 1;
    transition-delay: 1.5s;
  }
  .acf-feedback-label {
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  [data-attack-chain].revealed .acf-feedback-label {
    opacity: 1;
    transition-delay: 1.4s;
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .acf-card,
    .acf-population,
    .acf-arrow line,
    .acf-arrow polygon,
    .acf-feedback-path,
    .acf-feedback-arrow,
    .acf-feedback-label,
    .acf-band-dot[data-active="true"] {
      transition-duration: 0.01ms !important;
      transition-delay: 0ms !important;
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      stroke-dashoffset: 0 !important;
    }
    [data-attack-chain].revealed .acf-band-dot[data-active="true"] {
      transition-delay: 0ms !important;
    }
  }
</style>

<script>
  // Scroll-triggered reveal
  function initAttackChain() {
    const containers = document.querySelectorAll('[data-attack-chain]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    containers.forEach((el) => observer.observe(el));
  }
  // Run on initial load and on Astro page transitions
  initAttackChain();
  document.addEventListener('astro:page-load', initAttackChain);
</script>
