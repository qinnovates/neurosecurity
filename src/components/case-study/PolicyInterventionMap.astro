---
/**
 * PolicyInterventionMap.astro
 * Four intervention windows as glass cards with scroll-triggered animations.
 */

const windows = [
  {
    label: 'Before Phase 1',
    actions: [
      'Exercise access programs',
      'Nutritional supplementation',
      'Circadian hygiene protocols',
      'Social connection infrastructure',
    ],
    prevents: 'Slow drift onset',
    phaseAfter: 'Phase 1',
  },
  {
    label: 'Between Phases 1\u20132',
    actions: [
      'Population screening',
      'CRB-targeted outreach',
      'Trauma-informed messaging',
    ],
    prevents: 'Replay activation',
    phaseAfter: 'Phase 2',
  },
  {
    label: 'During Phases 2\u20133',
    actions: [
      'Scale mental health before demand peaks',
      'Substance use prevention',
      'Media literacy campaigns',
    ],
    prevents: 'Cascade formation',
    phaseAfter: 'Phase 3',
  },
  {
    label: 'After Phase 3',
    actions: [
      'Neuroplasticity rehabilitation',
      'Long-term monitoring programs',
      'Neurorights baseline assessment',
    ],
    prevents: 'Identity restructuring',
    phaseAfter: null,
  },
];
---

<div class="my-8" data-policy-map>
  <h3 class="text-lg font-semibold font-[family-name:var(--font-heading)] mb-1 text-[var(--color-text-primary)]">
    Policy Intervention Map
  </h3>
  <p class="text-xs text-[var(--color-text-faint)] mb-5">
    Four windows of opportunity to interrupt the attack chain
  </p>

  <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr_auto_1fr_auto_1fr] gap-4 md:gap-0 items-stretch">
    {windows.map((win, i) => (
      <>
        {/* Intervention Card */}
        <div
          class="pim-card glass rounded-xl p-5 flex flex-col justify-between card-hover"
          style={`--card-index: ${i};`}
        >
          {/* Green border draw-in */}
          <div class="pim-border-draw" />

          {/* Window Label */}
          <div>
            <span class="text-[10px] font-bold uppercase tracking-wider text-emerald-400">
              Window {i + 1}
            </span>
            <h4 class="text-sm font-semibold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)] mt-1 mb-3">
              {win.label}
            </h4>

            {/* Action Bullets */}
            <ul class="space-y-1.5 mb-4">
              {win.actions.map((action, ai) => (
                <li
                  class="pim-bullet text-xs text-[var(--color-text-muted)] leading-relaxed flex items-start gap-1.5"
                  style={`--bullet-index: ${ai};`}
                >
                  <span class="text-emerald-400 mt-0.5 shrink-0">&#8226;</span>
                  {action}
                </li>
              ))}
            </ul>
          </div>

          {/* Prevents Label */}
          <div class="mt-auto pt-3 border-t border-[var(--color-border)]">
            <span class="text-[10px] font-semibold uppercase tracking-wider text-[var(--color-text-faint)]">
              Prevents:
            </span>
            <span class="pim-prevents text-xs text-[var(--color-accent-primary)] ml-1 font-semibold">
              {win.prevents}
            </span>
          </div>
        </div>

        {/* Phase Arrow Between Cards (desktop only, not after last) */}
        {win.phaseAfter && (
          <div class="pim-phase-arrow hidden md:flex flex-col items-center justify-center px-2" style={`--card-index: ${i};`}>
            <span class="text-[10px] text-[var(--color-text-faint)] font-[family-name:var(--font-mono)] mb-1 whitespace-nowrap">
              {win.phaseAfter}
            </span>
            <svg width="24" height="16" viewBox="0 0 24 16" aria-hidden="true">
              <line
                x1="0" y1="8" x2="18" y2="8"
                stroke="#4b5563" stroke-width="1.5"
                stroke-dasharray="18"
                stroke-dashoffset="18"
                class="pim-arrow-line"
              />
              <polygon points="16,4 24,8 16,12" fill="#4b5563" class="pim-arrow-head" />
            </svg>
          </div>
        )}
      </>
    ))}
  </div>
</div>

<style>
  /* --- Card: relative for border pseudo-element --- */
  .pim-card {
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  [data-policy-map].revealed .pim-card {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(var(--card-index) * 300ms);
  }

  /* --- Green border draw-in via pseudo-element --- */
  .pim-border-draw {
    position: absolute;
    left: 0;
    top: 0;
    width: 4px;
    height: 100%;
    background: #10b981;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.5s ease;
  }
  [data-policy-map].revealed .pim-border-draw {
    transform: scaleY(1);
    transition-delay: calc(var(--card-index) * 300ms + 200ms);
  }

  /* --- Action bullets fade in sequentially --- */
  .pim-bullet {
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  [data-policy-map].revealed .pim-bullet {
    opacity: 1;
    transform: translateX(0);
    transition-delay: calc(var(--card-index) * 300ms + var(--bullet-index) * 100ms + 400ms);
  }

  /* --- Prevents label highlight flash --- */
  @keyframes prevents-flash {
    0% { color: var(--color-accent-primary); }
    30% { color: #10b981; text-shadow: 0 0 8px rgba(16, 185, 129, 0.4); }
    100% { color: var(--color-accent-primary); text-shadow: none; }
  }
  .pim-prevents {
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  [data-policy-map].revealed .pim-prevents {
    opacity: 1;
    animation: prevents-flash 1.2s ease;
    animation-delay: calc(var(--card-index) * 300ms + 700ms);
    transition-delay: calc(var(--card-index) * 300ms + 600ms);
  }

  /* --- Phase arrow between cards: path draw --- */
  .pim-phase-arrow {
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  [data-policy-map].revealed .pim-phase-arrow {
    opacity: 1;
    transition-delay: calc(var(--card-index) * 300ms + 250ms);
  }
  .pim-arrow-line {
    transition: stroke-dashoffset 0.4s ease;
  }
  [data-policy-map].revealed .pim-arrow-line {
    stroke-dashoffset: 0;
    transition-delay: calc(var(--card-index) * 300ms + 350ms);
  }
  .pim-arrow-head {
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  [data-policy-map].revealed .pim-arrow-head {
    opacity: 1;
    transition-delay: calc(var(--card-index) * 300ms + 550ms);
  }

  /* --- Reduced motion --- */
  @media (prefers-reduced-motion: reduce) {
    .pim-card,
    .pim-bullet,
    .pim-prevents,
    .pim-phase-arrow,
    .pim-border-draw {
      transition-duration: 0.01ms !important;
      transition-delay: 0ms !important;
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .pim-border-draw {
      transform: scaleY(1) !important;
    }
    .pim-arrow-line {
      stroke-dashoffset: 0 !important;
      transition-duration: 0.01ms !important;
    }
    .pim-arrow-head {
      opacity: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>

<script>
  function initPolicyMap() {
    const containers = document.querySelectorAll('[data-policy-map]');
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    containers.forEach((el) => observer.observe(el));
  }
  initPolicyMap();
  document.addEventListener('astro:page-load', initPolicyMap);
</script>
