---
<button id="theme-toggle" class="p-2 rounded-lg text-[var(--color-text-faint)] hover:text-[var(--color-text-primary)] hover:bg-black/5 transition-colors" aria-label="Toggle theme" style="width:36px;height:36px;display:inline-flex;align-items:center;justify-content:center;">
  <!-- Sun (visible in dark mode) -->
  <svg id="theme-sun" class="hidden w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5M12 19.5V21M4.219 4.219l1.061 1.061M17.72 17.72l1.06 1.06M3 12h1.5M19.5 12H21M4.219 19.781l1.061-1.061M17.72 6.28l1.06-1.06" />
    <circle cx="12" cy="12" r="4.5" />
  </svg>
  <!-- Moon (visible in light mode) -->
  <svg id="theme-moon" class="hidden w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0112.478 3.34a9.75 9.75 0 109.274 11.662z" />
  </svg>
</button>

<script is:inline>
(function initThemeToggle() {
  function update(theme) {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    document.getElementById('theme-sun').classList.toggle('hidden', theme !== 'dark');
    document.getElementById('theme-moon').classList.toggle('hidden', theme !== 'light');
  }
  function current() {
    return document.documentElement.getAttribute('data-theme') || 'light';
  }
  // Set icons on load
  var t = current();
  document.getElementById('theme-sun').classList.toggle('hidden', t !== 'dark');
  document.getElementById('theme-moon').classList.toggle('hidden', t !== 'light');
  // Toggle handler
  document.getElementById('theme-toggle').addEventListener('click', function() {
    update(current() === 'light' ? 'dark' : 'light');
  });
})();
</script>
