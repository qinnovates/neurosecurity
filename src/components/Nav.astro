---
import Search from 'astro-pagefind/components/Search';
import { TARA_TECHNIQUES } from '../lib/qif-constants';

const currentPath = Astro.url.pathname;

const frameworkLinks = [
  { href: '/framework/', label: 'Framework Overview', desc: 'QIF architecture and core concepts' },
  { href: '/security/', label: 'Signal Security', desc: '11-band hourglass architecture' },
  { href: '/research/whitepaper/', label: 'Research Proposal', desc: 'Latest QIF specification' },
  { href: '/glossary/', label: 'Glossary', desc: 'Terms and definitions' },
];

const atlasLinks = [
  { href: '/atlas/', label: 'Atlas Overview', desc: 'Threat landscape at a glance' },
  { href: '/atlas/tara/', label: 'TARA Atlas', desc: `${TARA_TECHNIQUES} BCI attack techniques, scored and mapped` },
{ href: '/atlas/scoring/', label: 'NISS Scoring', desc: 'Neural Impact Scoring — extending CVSS for neural harm' },
  { href: '/atlas/analysis/', label: 'Threat Analysis', desc: 'Case studies and hardware validation' },
];

const researchLinks = [
  { href: '/research/landscape/', label: 'Landscape', desc: 'BCI market and device landscape' },
  { href: '/research/bci-explorer/', label: 'BCI Explorer', desc: 'Interactive device explorer' },
  { href: '/research/neuroethics-landscape/', label: 'Neuroethics Landscape', desc: 'Timeline of neurorights and neuroethics scholarship' },
  { href: '/research/clinical/', label: 'Clinical Risk', desc: 'Psychiatric outcome references for threat modeling' },
  { href: '/research/validation/', label: 'Validation', desc: 'Methodology and testing results' },
];

const newsLinks = [
  { href: '/news/', label: 'News', desc: 'Field journals and research notes' },
  { href: '/news/roadmap/', label: 'Roadmap', desc: 'Milestones and version history' },
  { href: '/news/derivation/', label: 'Derivation Log', desc: 'Live research journal and hypothesis tracking' },
];

const aboutLinks = [
  { href: '/about/', label: 'About', desc: 'The researcher and the mission' },
  { href: '/licensing/', label: 'Licensing', desc: 'License terms and usage' },
  { href: '/governance/', label: 'Governance', desc: 'Ethics, consent, and regulatory compliance' },
];

const isFrameworkActive = ['/framework/', '/security/', '/glossary/'].some(p => currentPath.startsWith(p)) || currentPath === '/research/whitepaper/';
const isAtlasActive = currentPath.startsWith('/atlas/');
const isResearchActive = currentPath.startsWith('/research/') && currentPath !== '/research/whitepaper/';
const isNewsActive = currentPath.startsWith('/news/');
const isAboutActive = ['/about/', '/licensing/', '/governance/'].some(p => currentPath.startsWith(p));
---

<nav class="glass fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)]" id="main-nav" transition:persist>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <span class="text-2xl font-bold font-[family-name:var(--font-heading)] bg-gradient-to-r from-[var(--color-accent-primary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">Q</span>
        <span class="text-sm font-medium tracking-wider uppercase hidden sm:inline text-[var(--color-text-primary)]">innovate</span>
        <span class="text-xs text-[var(--color-text-faint)] hidden sm:inline ml-1">|</span>
        <span class="text-xs font-medium tracking-wide hidden sm:inline text-[var(--color-text-muted)]">Open Neural Atlas</span>
      </a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-1">
        <!-- Framework dropdown -->
        <div class="relative" data-dropdown="framework">
          <a
            href="/framework/"
            class:list={[
              "flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
              isFrameworkActive
                ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10"
                : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5"
            ]}
          >
            Framework
            <svg class="w-3.5 h-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </a>
          <div class="dropdown-menu absolute left-0 top-full pt-2 hidden">
            <div class="glass nav-dropdown rounded-xl border border-[var(--color-border)] shadow-xl w-80 overflow-hidden">
              <div class="p-2">
                {frameworkLinks.map((link) => (
                  <a
                    href={link.href}
                    class:list={[
                      "block px-3 py-2.5 rounded-lg transition-colors",
                      currentPath.startsWith(link.href)
                        ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10"
                        : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5"
                    ]}
                  >
                    <span class="text-sm font-medium block leading-snug">{link.label}</span>
                    <span class="text-xs text-[var(--color-text-faint)] block mt-0.5 leading-snug">{link.desc}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Atlas dropdown -->
        <div class="relative" data-dropdown="atlas">
          <a
            href="/atlas/"
            class:list={[
              "flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
              isAtlasActive
                ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10"
