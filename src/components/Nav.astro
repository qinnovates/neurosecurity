---
import Search from 'astro-pagefind/components/Search';
import { TARA_TECHNIQUES } from '../lib/qif-constants';

const currentPath = Astro.url.pathname;

// --- Nav structure: sections > groups > links ---
interface NavLink { href: string; label: string; desc?: string }
interface NavGroup { title: string; links: NavLink[] }
interface NavSection { id: string; label: string; href: string; groups: NavGroup[]; isActive?: boolean }

const missionGroups: NavGroup[] = [
  {
    title: 'About',
    links: [
      { href: '/mission/', label: 'Mission Statement', desc: 'Unified model for BCI risk, equity, and informed consent' },
      { href: '/vision/', label: 'Vision', desc: 'The future of neural interface security' },
      { href: '/about/', label: 'About Me', desc: 'Kevin L. Qi — from detection infrastructure to neurosecurity' },
      { href: '/news/roadmap/', label: 'Roadmap', desc: 'Milestones and version history' },
    ],
  },
  {
    title: 'Governance',
    links: [
      { href: '/research/neuroethics-landscape/', label: 'Neuroethics Landscape', desc: 'Modern timeline of neuroethics scholarship' },
      { href: '/governance/rights/', label: 'Neurorights', desc: '5 proposed neurorights mapped to hourglass bands' },
      { href: '/governance/ai-ethics/', label: 'AI Ethics', desc: 'Principles, frameworks, and regulatory landscape' },
      { href: '/governance/', label: 'Code of Ethics', desc: 'Ethical commitments and conduct standards' },
    ],
  },
];

const atlasGroups: NavGroup[] = [
  {
    title: 'Framework',
    links: [
      { href: '/atlas/', label: 'Atlas Dashboard', desc: 'Unified hourglass, brain, and threat landscape' },
      { href: '/framework/', label: 'QIF Framework', desc: '11-band hourglass architecture' },
      { href: '/atlas/tara/', label: 'TARA Catalog', desc: `${TARA_TECHNIQUES} techniques scored with NISS` },
      { href: '/atlas/scoring/', label: 'NISS Scoring', desc: 'Neural Impact Scoring — extending CVSS' },
    ],
  },
  {
    title: 'Analysis',
    links: [
      { href: '/atlas/tara/ttps/', label: 'TTPs Explained', desc: 'Tactics, techniques & procedures' },
      { href: '/atlas/tara/numbering/', label: 'QIF Numbering', desc: 'Technique IDs and tactic codes' },
      { href: '/atlas/analysis/', label: 'Case Studies', desc: 'Deep dives and attack chain analysis' },
      { href: '/research/bci-explorer/', label: 'BCI Explorer', desc: 'Interactive device and threat map' },
    ],
  },
  {
    title: 'Tools',
    links: [
      { href: '/tools/intel/', label: 'Intel Feed', desc: 'Automated BCI intelligence from 74+ sources' },
      { href: '/research/api/', label: 'APIs & Feeds', desc: 'STIX 2.1, Python SDK, Intel Feed, JSON APIs' },
      { href: '/research/data-lake/', label: 'Data Lake Dashboard', desc: 'Live metrics across all QIF data sources' },
      { href: '/research/landscape/', label: 'KQL Data Lake', desc: 'Query the threat and device databases' },
    ],
  },
];

const rndGroups: NavGroup[] = [
  {
    title: 'Research',
    links: [
      { href: '/research/', label: 'Overview', desc: 'All research areas and methodology' },
      { href: '/research/whitepaper/', label: 'Whitepaper', desc: 'Latest QIF specification' },
      { href: '/research/landscape/', label: 'BCI Landscape', desc: 'Market analysis and device landscape' },
      { href: '/research/clinical/', label: 'Clinical', desc: 'Therapeutic applications' },
      { href: '/research/physics/', label: 'Physics', desc: 'Physical constraints on BCI systems' },
    ],
  },
  {
    title: 'Neurosecurity Stack',
    links: [
      { href: '/development/', label: 'Overview', desc: 'Proposed neurosecurity stack for neural interfaces' },
      { href: '/guardrails/', label: 'Neurowall', desc: 'Signal-layer firewall at I0' },
      { href: '/guardrails/nsp/', label: 'NSP Protocol', desc: 'Post-quantum wire security' },
      { href: '/guardrails/runemate/', label: 'Runemate', desc: 'On-device policy compiler' },
    ],
  },
  {
    title: 'Updates',
    links: [
      { href: '/news/', label: 'Blog & Field Journals', desc: 'Announcements and research notes' },
      { href: '/news/derivation/', label: 'Derivation Log', desc: 'Live research journal' },
      { href: '/research/validation/', label: 'Validation', desc: 'Methodology and testing results' },
    ],
  },
];

const isMissionActive = ['/mission/', '/vision/', '/about/'].some(p => currentPath.startsWith(p))
  || currentPath.startsWith('/governance/') || currentPath === '/news/roadmap/';
const isAtlasActive = currentPath.startsWith('/atlas/') || currentPath.startsWith('/framework/')
  || currentPath.startsWith('/security/') || currentPath.startsWith('/tools/')
;
const isRndActive = currentPath.startsWith('/research/') || currentPath.startsWith('/development/')
  || currentPath.startsWith('/guardrails/') || (currentPath.startsWith('/news/') && !currentPath.startsWith('/news/roadmap/'));

const navSections: NavSection[] = [
  { id: 'mission', label: 'Mission', href: '/mission/', groups: missionGroups, isActive: isMissionActive },
  { id: 'atlas', label: 'Atlas', href: '/atlas/', groups: atlasGroups, isActive: isAtlasActive },
  { id: 'rnd', label: 'R&D', href: '/research/', groups: rndGroups, isActive: isRndActive },
];
---

<nav class="glass fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)]" id="main-nav" transition:persist>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <span class="text-2xl font-bold font-[family-name:var(--font-heading)] bg-gradient-to-r from-[var(--color-accent-primary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">Q</span>
        <span class="text-sm font-medium tracking-wider uppercase hidden sm:inline text-[var(--color-text-primary)]">innovate</span>
        <span class="text-xs text-[var(--color-text-faint)] hidden sm:inline ml-1">|</span>
        <span class="text-xs font-medium tracking-wide hidden sm:inline text-[var(--color-text-muted)]">Open Neural Atlas</span>
      </a>

      <!-- Desktop links -->
      <div class="hidden lg:flex items-center gap-0.5">
        {navSections.map((section) => (
          <div class="relative" data-dropdown={section.id}>
            <a
              href={section.href}
              class:list={[
                "flex items-center gap-1 px-2.5 py-2 rounded-lg text-sm font-medium transition-colors",
                section.isActive
                  ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10"
                  : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5"
              ]}
            >
              {section.label}
              <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </a>
            <div class="dropdown-menu absolute left-0 top-full pt-2 hidden">
              <div class="glass nav-dropdown rounded-xl border border-[var(--color-border)] shadow-xl overflow-hidden max-h-[75vh] overflow-y-auto"
                style={`width: ${section.groups.length > 2 ? '640px' : '420px'};`}
              >
                <div class={`p-3 ${section.groups.length > 2 ? 'grid grid-cols-3 gap-3' : section.groups.length === 2 ? 'grid grid-cols-2 gap-3' : ''}`}>
                  {section.groups.map((group) => (
                    <div>
                      <p class="text-[10px] font-semibold uppercase tracking-[0.12em] px-2 py-1.5 mb-1" style="color: var(--color-text-faint);">
                        {group.title}
                      </p>
                      {group.links.map((link) => (
                        <a
                          href={link.href}
                          class:list={[
                            "block px-2 py-2 rounded-lg transition-colors",
                            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                              ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10"
                              : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5"
                          ]}
                        >
                          <span class="text-sm font-medium block leading-snug">{link.label}</span>
                          {link.desc && (
                            <span class="text-[11px] block mt-0.5 leading-snug" style="color: var(--color-text-faint);">{link.desc}</span>
                          )}
                        </a>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Right side -->
      <div class="flex items-center gap-2">
        <!-- BCI Vision toggle -->
        <a
          href="/vision/"
          class:list={[
            "hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium transition-all border",
            currentPath === '/vision/'
              ? "bg-[var(--color-accent-tertiary)]/15 text-[var(--color-accent-tertiary)] border-[var(--color-accent-tertiary)]/30"
              : "bg-transparent text-[var(--color-text-faint)] border-[var(--color-border)] hover:text-[var(--color-accent-tertiary)] hover:border-[var(--color-accent-tertiary)]/30"
          ]}
        >
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent-tertiary)] animate-pulse"></span>
          BCI Vision
        </a>

        <!-- Explore Atlas CTA (desktop) -->
        <a
          href="/atlas/"
          class:list={[
            "hidden md:inline-flex items-center gap-1.5 px-4 py-1.5 rounded-lg text-sm font-medium transition-colors",
            currentPath.startsWith('/atlas')
              ? "bg-[var(--color-accent-secondary)] text-white"
              : "bg-[var(--color-accent-secondary)]/85 text-white hover:bg-[var(--color-accent-secondary)]"
          ]}
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 32 32" fill="none">
            <path d="M8 16 Q12 8 16 16 Q20 24 24 16" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
          </svg>
          Explore Atlas
        </a>

        <!-- Persistent CTA (desktop) -->
        <a
          href="/research/whitepaper/"
          class="hidden md:inline-flex px-4 py-1.5 rounded-lg bg-[var(--color-accent-primary)] text-white text-sm font-medium hover:bg-[var(--color-accent-primary)]/90 transition-colors"
        >
          Whitepaper
        </a>

        <!-- GitHub link -->
        <a
          href="https://github.com/qinnovates/qinnovate"
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5 transition-colors"
          aria-label="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>

        <!-- Search button -->
        <button
          id="search-btn"
          class="p-2 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5 transition-colors"
          aria-label="Search"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </button>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5 transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-[var(--color-border)] max-h-[80vh] overflow-y-auto">
    <div class="px-4 py-3 space-y-1">
      <!-- Mobile CTAs -->
      <div class="pb-2 mb-2 border-b border-[var(--color-border)] space-y-2">
        <a
          href="/atlas/"
          class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-lg bg-[var(--color-accent-secondary)] text-white text-sm font-medium text-center hover:bg-[var(--color-accent-secondary)]/90 transition-colors"
        >
          <svg class="w-4 h-4" viewBox="0 0 32 32" fill="none">
            <path d="M8 16 Q12 8 16 16 Q20 24 24 16" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
            <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
          </svg>
          Explore Atlas
        </a>
        <a
          href="/research/whitepaper/"
          class="block w-full px-4 py-2.5 rounded-lg bg-[var(--color-accent-primary)] text-white text-sm font-medium text-center hover:bg-[var(--color-accent-primary)]/90 transition-colors"
        >
          Read the Whitepaper
        </a>
      </div>

      <!-- Mobile BCI Vision link -->
      <a
        href="/vision/"
        class:list={[
          "flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium transition-colors",
          currentPath === '/vision/'
            ? "text-[var(--color-accent-tertiary)] bg-[var(--color-accent-tertiary)]/10"
            : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:bg-black/5"
        ]}
      >
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent-tertiary)] animate-pulse"></span>
        BCI Vision
      </a>

      <!-- Mobile nav sections with nested groups -->
      {navSections.map((section) => (
        <div class="border-t border-[var(--color-border)] pt-1 mt-1">
          <button
            data-mobile-toggle={section.id}
            class:list={[
              "flex items-center justify-between w-full px-3 py-2 rounded-lg text-sm font-semibold transition-colors",
              section.isActive
                ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/10"
                : "text-[var(--color-text-primary)] hover:bg-black/5"
            ]}
          >
            {section.label}
            <svg class="w-3.5 h-3.5 opacity-60 transition-transform" data-chevron={section.id} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>

          <div data-mobile-list={section.id} class="hidden mt-1 space-y-1">
            {section.groups.map((group) => (
              <div class="ml-2">
                <button
                  data-mobile-group={`${section.id}-${group.title.toLowerCase().replace(/\s+/g, '-')}`}
                  class="flex items-center justify-between w-full px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.1em] rounded-lg transition-colors hover:bg-black/5"
                  style="color: var(--color-text-faint);"
                >
                  {group.title}
                  <svg class="w-3 h-3 opacity-50 transition-transform" data-group-chevron={`${section.id}-${group.title.toLowerCase().replace(/\s+/g, '-')}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </button>
                <div data-mobile-group-list={`${section.id}-${group.title.toLowerCase().replace(/\s+/g, '-')}`} class="hidden ml-2 space-y-0.5 mt-0.5 mb-1">
                  {group.links.map((link) => (
                    <a
                      href={link.href}
                      class:list={[
                        "block px-3 py-1.5 rounded-lg text-sm transition-colors",
                        currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                          ? "text-[var(--color-accent-primary)] bg-[var(--color-accent-primary)]/5"
                          : "text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]"
                      ]}
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</nav>

<!-- Search modal -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden">
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative max-w-2xl mx-auto mt-20 px-4">
    <div class="glass rounded-xl p-4 shadow-2xl" id="search-container">
      <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false, showSubResults: true }} />
    </div>
  </div>
</div>

<script>
  function initNav() {
    // Mobile menu
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuBtn?.addEventListener('click', () => {
      const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
      menuBtn.setAttribute('aria-expanded', String(!expanded));
      mobileMenu?.classList.toggle('hidden');
    });

    document.addEventListener('astro:before-swap', () => {
      mobileMenu?.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
    });

    // Desktop dropdowns (hover + focus)
    document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((dropdown) => {
      const menu = dropdown.querySelector<HTMLElement>('.dropdown-menu');
      let timeout: ReturnType<typeof setTimeout>;

      function show() {
        document.querySelectorAll<HTMLElement>('.dropdown-menu').forEach(m => {
          if (m !== menu) m.classList.add('hidden');
        });
        clearTimeout(timeout);
        menu?.classList.remove('hidden');
      }

      function hide() {
        timeout = setTimeout(() => {
          menu?.classList.add('hidden');
        }, 150);
      }

      dropdown.addEventListener('mouseenter', show);
      dropdown.addEventListener('mouseleave', hide);
      dropdown.addEventListener('focusin', show);
      dropdown.addEventListener('focusout', (e) => {
        if (!dropdown.contains((e as FocusEvent).relatedTarget as Node)) {
          hide();
        }
      });
    });

    // Mobile section accordion toggles
    document.querySelectorAll<HTMLElement>('[data-mobile-toggle]').forEach((btn) => {
      const key = btn.getAttribute('data-mobile-toggle');
      const list = document.querySelector<HTMLElement>(`[data-mobile-list="${key}"]`);
      const chevron = document.querySelector<HTMLElement>(`[data-chevron="${key}"]`);

      btn.addEventListener('click', () => {
        list?.classList.toggle('hidden');
        chevron?.classList.toggle('rotate-180');
      });
    });

    // Mobile group sub-accordion toggles
    document.querySelectorAll<HTMLElement>('[data-mobile-group]').forEach((btn) => {
      const key = btn.getAttribute('data-mobile-group');
      const list = document.querySelector<HTMLElement>(`[data-mobile-group-list="${key}"]`);
      const chevron = document.querySelector<HTMLElement>(`[data-group-chevron="${key}"]`);

      btn.addEventListener('click', () => {
        list?.classList.toggle('hidden');
        chevron?.classList.toggle('rotate-90');
      });
    });

    // Search modal
    const searchBtn = document.getElementById('search-btn');
    const searchModal = document.getElementById('search-modal');
    const searchBackdrop = document.getElementById('search-backdrop');

    function openSearch() {
      searchModal?.classList.remove('hidden');
      setTimeout(() => {
        const input = searchModal?.querySelector<HTMLInputElement>('.pagefind-ui__search-input');
        input?.focus();
      }, 50);
    }

    function closeSearch() {
      searchModal?.classList.add('hidden');
    }

    searchBtn?.addEventListener('click', openSearch);
    searchBackdrop?.addEventListener('click', closeSearch);

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (searchModal?.classList.contains('hidden')) {
          openSearch();
        } else {
          closeSearch();
        }
      }
      if (e.key === 'Escape') {
        closeSearch();
      }
    });

    document.addEventListener('astro:before-swap', closeSearch);
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
