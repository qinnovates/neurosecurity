---
import { QIF_VERSION, QIF_ARCHITECTURE } from '../lib/qif-constants';
const year = new Date().getFullYear();

const sections = [
  {
    title: 'Framework',
    links: [
      { href: '/framework/', label: 'QIF Framework' },
      { href: '/security/', label: 'Signal Security' },
      { href: '/atlas/tara/', label: 'TARA Atlas' },
      { href: '/atlas/scoring/', label: 'NISS Scoring' },
      { href: '/research/whitepaper/', label: 'Whitepaper' },
    ],
  },
  {
    title: 'Research',
    links: [
      { href: '/research/landscape/', label: 'BCI Landscape' },
      { href: '/research/bci-explorer/', label: 'BCI Explorer' },
      { href: '/research/clinical/', label: 'Clinical Risk' },
      { href: '/news/', label: 'News' },
      { href: '/rss.xml', label: 'RSS Feed' },
    ],
  },
  {
    title: 'Connect',
    links: [
      { href: '/about/', label: 'About' },
      { href: '/licensing/', label: 'Licensing' },
      { href: '/governance/', label: 'Governance' },
      { href: 'https://github.com/qinnovates', label: 'GitHub' },
    ],
  },
];
---

<footer class="border-t border-[var(--color-border)] mt-24 relative overflow-hidden">
  <!-- Background brand mark -->
  <div class="footer-brand-bg select-none pointer-events-none" aria-hidden="true">
    <span class="footer-brand font-bold font-[family-name:var(--font-heading)] leading-none bg-gradient-to-r from-[var(--color-accent-primary)] via-[var(--color-accent-secondary)] to-[var(--color-accent-tertiary)] bg-clip-text text-transparent">
      QINNOVATE
    </span>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-xl font-bold font-[family-name:var(--font-heading)] text-[var(--color-text-primary)]">
          Qinnovate Open Neural Atlas
        </a>
        <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
          Neurostandards — open frameworks for the security of neurotechnology.
        </p>
        <p class="mt-4 text-xs text-[var(--color-text-faint)]">
          QIF v{QIF_VERSION} {QIF_ARCHITECTURE} &middot; Open Framework
        </p>
      </div>

      {sections.map((section) => (
        <div>
          <h3 class="text-sm font-semibold text-[var(--color-text-primary)] uppercase tracking-wider mb-4">
            {section.title}
          </h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent-primary)] transition-colors"
                  {...(link.href.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- AI Transparency Disclosure -->
    <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
      <p class="text-xs text-[var(--color-text-faint)] leading-relaxed max-w-3xl">
        <strong class="text-[var(--color-text-muted)]">AI Transparency:</strong> This project was developed with AI assistance (Claude, Gemini, ChatGPT). All architectural decisions, threat mappings, and scoring are the author's. AI contributions are documented in the
        <a href="https://github.com/qinnovates/qinnovate/blob/main/governance/TRANSPARENCY.md" class="underline hover:text-[var(--color-text-muted)] transition-colors" target="_blank" rel="noopener noreferrer">Transparency Statement</a>,
        <a href="/news/derivation/" class="underline hover:text-[var(--color-text-muted)] transition-colors">Derivation Log</a>, and
        <a href="/research/validation/" class="underline hover:text-[var(--color-text-muted)] transition-colors">Validation Status</a>.
        QIF is a proposed, unvalidated framework. All results are simulation-only unless otherwise noted.
      </p>
    </div>

    <div class="mt-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-[var(--color-text-faint)]">
        &copy; {year} Qinnovate Open Neural Atlas. An open research framework.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-brand-bg {
    position: absolute;
    bottom: 0;
    right: -10%;
    display: flex;
    align-items: flex-end;
    z-index: 0;
  }

  .footer-brand {
    font-size: clamp(5rem, 18vw, 16rem);
    letter-spacing: -0.03em;
    opacity: 0.07;
    line-height: 0.8;
  }
</style>
