---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  articleMeta?: { publishedTime: string; author: string; tags: string[] };
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, description = "Quantum Indeterministic Framework for Brain-Computer Interface Security", ogImage, ogType = "website", articleMeta, breadcrumbs } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const resolvedOgImage = ogImage || new URL('/images/og-default.png', Astro.site).toString();
---

<!DOCTYPE html>
<html lang="en-US" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Kevin L. Qi" />
  <link rel="canonical" href={canonicalURL} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90' font-family='system-ui' fill='%2306b6d4'%3EQ%3C/text%3E%3C/svg%3E" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Qinnovate" />
  <meta property="og:type" content={ogType} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_US" />
  {articleMeta && <meta property="article:published_time" content={articleMeta.publishedTime} />}
  {articleMeta && <meta property="article:author" content={articleMeta.author} />}
  {articleMeta?.tags.map((tag) => <meta property="article:tag" content={tag} />)}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />
  <meta name="twitter:creator" content="@qikevinl" />

  <!-- JSON-LD Structured Data (escape </script> to prevent injection) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Qinnovate",
    "url": "https://qinnovate.com",
    "description": "Open research on brain-computer interface security and governance.",
    "foundingDate": "2026",
    "sameAs": ["https://github.com/qinnovates"]
  }).replace(/<\//g, '<\\/')} />

  <!-- WebSite schema with SearchAction for sitelinks search box -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Qinnovate",
    "url": "https://qinnovate.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://qinnovate.com/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }).replace(/<\//g, '<\\/')} />

  {breadcrumbs && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": new URL('/', Astro.site).toString() },
        ...breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          "position": i + 2,
          "name": crumb.label,
          ...(crumb.href ? { "item": new URL(crumb.href, Astro.site).toString() } : {}),
        })),
      ],
    }).replace(/<\//g, '<\\/')} />
  )}

  <!-- RSS autodiscovery -->
  <link rel="alternate" type="application/rss+xml" title="Qinnovate Intel" href="/rss.xml" />

  <!-- Security headers (meta tags for non-CSP headers; Cloudflare adds HTTP headers too) -->
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta http-equiv="X-Frame-Options" content="DENY" />
  <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
  <!-- CSP is enforced via _headers file (Cloudflare Pages). Meta-tag CSP removed to avoid conflict. -->
  <meta http-equiv="Permissions-Policy" content="camera=(), microphone=(), geolocation=(), interest-cohort=()" />
  <meta http-equiv="Cross-Origin-Opener-Policy" content="same-origin" />

  <title>{title} | Qinnovate</title>

  <!-- Additional head content from child layouts -->
  <slot name="head" />

  <!-- View Transitions -->
  <ViewTransitions />


  <!-- Theme + Vision mode + Lens initialization (prevent flash) -->
  <script is:inline>
    (function(){
      try {
        var path = window.location.pathname;
        var isVisionPage = path.startsWith('/vision');
        var vision = isVisionPage && localStorage.getItem('bci-vision') === 'on';
        // Theme: vision pages force dark when vision is on, otherwise use saved preference or system
        var savedTheme = localStorage.getItem('theme');
        var theme = vision ? 'dark' : (savedTheme || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'));
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.setAttribute('data-vision', vision ? 'on' : 'off');
        var lens = localStorage.getItem('qif-lens') || 'both';
        document.documentElement.setAttribute('data-lens', lens);
      } catch(e) {
        document.documentElement.setAttribute('data-theme', 'light');
        document.documentElement.setAttribute('data-vision', 'off');
        document.documentElement.setAttribute('data-lens', 'both');
      }
    })();
  </script>
</head>
<body class="min-h-screen">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[200] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-[var(--color-accent-primary)] focus:text-white focus:text-sm focus:font-bold">Skip to content</a>
  <main id="main-content">
    <slot />
  </main>

  <!-- Scroll-driven reveal observer -->
  <script>
    function initScrollReveal() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale').forEach((el) => observer.observe(el));
    }

    initScrollReveal();
    document.addEventListener('astro:after-swap', initScrollReveal);
  </script>
  <!-- Cloudflare Web Analytics -->
  <!-- TODO: Add SRI integrity hash when Cloudflare publishes one for this beacon version -->
  <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "7e92b0e996474c9e9502b816aa36beed"}' crossorigin="anonymous"></script>
  <!-- End Cloudflare Web Analytics -->
</body>
</html>
