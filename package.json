{
  "name": "qinnovate-com",
  "type": "module",
  "version": "2.0.0",
  "license": "Apache-2.0",
  "scripts": {
    "prebuild": "bash src/scripts/prebuild.sh",
    "dev": "npm run prebuild && astro dev",
    "build": "npm run prebuild && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fetch-news": "node src/scripts/fetch-news.mjs",
    "fetch-intel": "node src/scripts/fetch-intel.mjs",
    "type-check": "tsc --noEmit",
    "sync": "node src/scripts/sync-agents.mjs",
    "verify": "python3 src/scripts/verify/run_all.py",
    "verify:citations": "python3 src/scripts/verify/verify_citations.py",
    "verify:facts": "python3 src/scripts/verify/verify_facts.py",
    "verify:blogs": "python3 src/scripts/verify/audit_blog_claims.py",
    "verify:crossrefs": "python3 src/scripts/verify/verify_crossrefs.py",
    "generate:ethics": "npx tsx src/scripts/generate-ethics-md.ts",
    "changelog": "node src/scripts/changelog-update.mjs",
    "citations": "node src/scripts/generate-citations.mjs",
    "citations:check": "node src/scripts/generate-citations.mjs --check",
    "compute:chains": "node datalake/src/scripts/compute-impact-chains.mjs",
    "eeg:list": "python3 datalake/src/scripts/download-eeg-samples.py --list",
    "eeg:download": "python3 datalake/src/scripts/download-eeg-samples.py --all",
    "eeg:download:adhd": "python3 datalake/src/scripts/download-eeg-samples.py --dataset adhd-mendeley-resting",
    "eeg:process": "python3 src/scripts/process-eeg-to-parquet.py",
    "eeg:process:dry": "python3 src/scripts/process-eeg-to-parquet.py --dry-run",
    "eeg:process:list": "python3 src/scripts/process-eeg-to-parquet.py --list",
    "decisions": "node src/scripts/generate-governance.mjs decisions",
    "transparency": "node src/scripts/generate-governance.mjs transparency",
    "governance": "node src/scripts/generate-governance.mjs",
    "health": "node src/scripts/propagation-check.mjs",
    "version:show": "bash src/scripts/version.sh show",
    "version:patch": "bash src/scripts/version.sh patch",
    "version:minor": "bash src/scripts/version.sh minor",
    "version:major": "bash src/scripts/version.sh major"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@react-hook/window-size": "^3.1.1",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/katex": "^0.16.0",
    "@types/three": "^0.172.0",
    "astro": "^6.1.3",
    "astro-pagefind": "^1.8.5",
    "fast-xml-parser": "^5.5.6",
    "katex": "^0.16.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-3d": "^1.29.1",
    "tailwindcss": "^4.0.0",
    "three": "^0.183.2",
    "three-forcegraph": "^1.43.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "fast-xml-parser": "^5.5.6"
  }
}
